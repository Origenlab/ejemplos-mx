---
{/* BaseLayout — cascarón <html>/<head> raíz: SEO (buildMeta) + JSON-LD (buildSchema). Raíz | Origen: BOMBERO (Base→Page limpio) + contrato lib/seo del Master System */}

// ============================================================================
// BaseLayout.astro — LAYOUT RAÍZ. Todo el sitio cuelga de aquí.
//
// Jerarquía canónica (origen BOMBERO): BaseLayout → PageLayout → {Producto,
// Servicio, Articulo}Layout. Este archivo NO incluye Header/Footer: solo arma
// el documento HTML, el <head> completo y el JSON-LD. El chrome (Header,
// Footer, Breadcrumbs, WhatsAppFloat) lo añade PageLayout.
//
// CONTRATO (interopera EXACTO con src/lib/seo.ts y src/config/site.ts del Master
// System — respeta firmas):
//   - buildMeta({ title, description, canonical, image, type, noindex,
//                 publishedTime?, modifiedTime? })  → MetaOutput PLANO
//        { title, description, canonical, image, type, robots, locale,
//          siteName, twitterCard, twitterSite?, publishedTime?, modifiedTime? }
//   - buildSchema(pageType, schemaData)  → Record<string,unknown>[] de JSON-LD.
//        Grafo base (Organization+WebSite+LocalBusiness) por @id + el nodo del
//        tipo + BreadcrumbList UNA sola vez (B3) si schemaData.breadcrumbs.
//
// REGLA DE ORO (PROYECTORED/PODIUMEX): cero datos estructurados fabricados.
// buildSchema NO emite aggregateRating/Review sin reseñas verificables (B4).
// ============================================================================

import { SITE } from "@config/site";
import { buildMeta, buildSchema, buildKeywordTitle, buildKeywordDescription, type PageType, type SchemaData } from "@lib/seo";

// Tokens de diseño (FUENTE ÚNICA, C2). Se importa UNA sola vez aquí — todo el
// sitio cuelga de BaseLayout, así que basta este import para exponer las
// variables :root a cada página/componente. NO reimportar tokens.css en otro lado.
import "../styles/tokens.css";
// Overrides responsive de LAYOUT — ÚLTIMO en el cascade global (vence a los
// estilos scoped de cada componente con !important quirúrgico). Breakpoints
// canónicos 1024/768/640/480/380. Ver src/styles/mobile.css.
import "../styles/mobile.css";

export interface Props {
  /** Título de la página (sin marca; ≤60). Opcional si pasas `keywords`. */
  title?: string;
  /**
   * Tripleta de keywords [kw1, kw2, kw3] (regla de metas keyword-first). Si se
   * pasa, el title se arma con buildKeywordTitle() (kw1 primero, sin marca) y la
   * description se obliga a abrir con kw1. Ver KEYWORDS en src/config/site.ts.
   */
  keywords?: readonly string[];
  /** Meta description 140–160 chars. Default: SITE.seo.description. */
  description?: string;
  /** Override del canonical. Default: ruta de la página actual (se absolutiza). */
  canonical?: string;
  /** Imagen OG/Twitter (1200×630). Default: imagen por defecto del sitio. */
  image?: string;
  /**
   * Tipo de página → selecciona el grafo JSON-LD en buildSchema (B2).
   * Determina también og:type ('article' para artículos; 'website' para el resto).
   */
  pageType?: PageType;
  /** Datos para el schema del tipo (product, service, article, faqs, list, breadcrumbs…). */
  schemaData?: SchemaData;
  /** true → robots noindex,nofollow (drafts, /gracias, etc.). */
  noindex?: boolean;
}

const {
  title,
  keywords,
  description,
  canonical,
  image,
  pageType = "page",
  schemaData = {},
  noindex = false,
} = Astro.props;

// Ruta canónica de la página actual (relativa; buildMeta la absolutiza).
const path = canonical ?? Astro.url.pathname;

// og:type: 'article' solo en artículos; el resto 'website'.
const ogType = pageType === "article" ? "article" : "website";

// Regla de metas keyword-first: si la página declara `keywords`, el title se
// genera con la tripleta (kw1 | kw2 | kw3, sin marca) y la description se obliga
// a abrir con kw1. Si no, se usan title/description tal cual (compatibilidad).
const hasKw = Array.isArray(keywords) && keywords.length > 0;
const resolvedTitle = hasKw ? buildKeywordTitle(keywords!) : title;
const resolvedDescription = hasKw
  ? buildKeywordDescription(keywords!, description ?? SITE.seo?.description ?? "")
  : description;

// SEO centralizado: metas resueltas (title ≤60, description ≤160, canonical abs).
const meta = buildMeta({
  title: resolvedTitle,
  description: resolvedDescription,
  canonical: path,
  image,
  type: ogType,
  noindex,
  publishedTime: (schemaData as any)?.article?.datePublished,
  modifiedTime: (schemaData as any)?.article?.dateModified,
});

// JSON-LD por tipo de página (firma posicional: pageType, schemaData).
const jsonLd = buildSchema(pageType, schemaData);
---

<!doctype html>
<html lang={SITE.lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    {/* ── SEO: title, description, canonical, robots ── */}
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={meta.canonical} />
    <meta name="robots" content={meta.robots} />

    {/* ── Open Graph (derivado de los campos planos de buildMeta) ── */}
    <meta property="og:type" content={meta.type} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={meta.canonical} />
    <meta property="og:image" content={meta.image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={meta.title} />
    <meta property="og:site_name" content={meta.siteName} />
    <meta property="og:locale" content={meta.locale} />
    {meta.publishedTime && <meta property="article:published_time" content={meta.publishedTime} />}
    {meta.modifiedTime && <meta property="article:modified_time" content={meta.modifiedTime} />}

    {/* ── Twitter ── */}
    <meta name="twitter:card" content={meta.twitterCard} />
    {meta.twitterSite && <meta name="twitter:site" content={meta.twitterSite} />}
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={meta.image} />
    <meta name="twitter:image:alt" content={meta.title} />

    {/* ── Iconos y manifest ── */}
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#5b3df5" />

    {/*
      ── Fuentes self-hosted anti-CLS (C3) ──
      Esta PLANTILLA usa la pila system-ui de tokens.css (sin woff2 propios), por
      eso los preload van comentados: descomentándolos sin el archivo real darían
      404. Al elegir tipografía propia, coloca los woff2 en /public/fonts, ajusta
      --font-body / --font-heading en src/styles/tokens.css y descomenta:
        <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
        <link rel="preload" href="/fonts/outfit-700.woff2" as="font" type="font/woff2" crossorigin />
      Self-host + font-display:swap + preload. NO Google Fonts CDN.
    */}

    {/*
      ── Preconnect CDN de imágenes (E3) — opcional ──
      Si usas ExactDN/EWWW (rewrite-cdn.mjs post-build), descomenta:
      <link rel="preconnect" href="https://{{CDN_HOST}}" crossorigin />
    */}

    {/*
      ── Slot 'head' ── layouts/páginas hijas inyectan <head> extra
      (preload de imagen LCP, RSS alternate, JSON-LD puntual). Patrón PROYECTORED.
    */}
    <slot name="head" />

    {/* ── JSON-LD: un <script> por nodo del grafo, generado por buildSchema ──
       is:inline obligatorio: JSON-LD es DATA, no JS — saltar el bundler
       de Astro evita el hint astro(4000) y mantiene el script tal cual. */}
    {jsonLd.map((node) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(node)} />
    ))}
  </head>

  <body>
    {/*
      Skip-link de accesibilidad (WCAG 2.4.1 Bypass Blocks).
      Oculto hasta recibir foco (clase .skip-link en tokens.css). Apunta al
      <main id="main-content"> que PageLayout renderiza siempre. Para páginas
      que extienden BaseLayout directo (raras, p. ej. 404 técnicas) el target
      puede faltar; no rompe nada — solo desperdicia el primer Tab.
    */}
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <slot />
  </body>
</html>
