<span class="fm__k">description:</span> <span class="fm__s">"Diagnóstico claro y propuesta…"</span>
<span class="fm__pin fm__pin--2">2</span><span class="fm__k">category:</span> <span class="fm__s">"general"</span>
<span class="fm__k">order:</span> <span class="fm__n">1</span>
<span class="fm__pin fm__pin--3">3</span><span class="fm__k">image:</span> <span class="fm__s">"/images/servicios/consultoria.avif"</span>
