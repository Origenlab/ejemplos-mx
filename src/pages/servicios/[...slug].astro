  /* ── PROPUESTA (consultoría) ─────────────────────────────────────────────── */
  .mck-propuesta {
    margin-top: var(--sp-6);
    border: 1px solid var(--c-border); border-radius: var(--radius-lg);
    background: var(--c-white); overflow: hidden;
    max-width: 560px; box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }
  .mp__header {
    display: flex; align-items: center; justify-content: space-between;
    padding: var(--sp-3) var(--sp-5);
    background: var(--c-primary); color: #fff;
  }
  .mp__label { font-family: var(--font-heading); font-size: var(--text-xs); font-weight: var(--weight-bold); letter-spacing: .08em; }
  .mp__date  { font-size: var(--text-xs); opacity: .75; }
  .mp__body  { padding: var(--sp-4) var(--sp-5); display: flex; flex-direction: column; gap: var(--sp-3); }
  .mp__row   { display: flex; align-items: center; gap: var(--sp-3); padding: var(--sp-3); border-radius: var(--radius-md); border: 1px solid var(--c-border); background: var(--c-surface); }
  .mp__row--active { background: var(--c-primary-light); border-color: var(--c-primary); }
  .mp__num   { flex-shrink: 0; font-family: var(--font-heading); font-size: var(--text-sm); font-weight: var(--weight-black); color: var(--c-muted); width: 28px; }
  .mp__num--active { color: var(--c-primary); }
  .mp__content { flex: 1; display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .mp__title { font-size: var(--text-sm); font-weight: var(--weight-semibold); color: var(--c-ink); }
  .mp__line  { height: 6px; width: 70%; border-radius: 3px; background: var(--c-border); }
