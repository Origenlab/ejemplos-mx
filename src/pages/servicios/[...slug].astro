---
// ============================================================================
// /servicios/<id> — Detalle de servicio (Nivel L3).
// ----------------------------------------------------------------------------
// Molde de 9 secciones: mismo kit Mod* que /modulos/*. Mockups bespoke por
// servicio: documento de propuesta (consultoría), pipeline de deploy
// (implementación), chat de soporte (soporte). DisenoCards con mini-UIs vivas.
// ============================================================================
import PageLayout    from '@layouts/PageLayout.astro'
import Hero          from '@components/Hero.astro'
import SectionMenu   from '@components/SectionMenu.astro'
import GaleriaDisenos from '@components/GaleriaDisenos.astro'
import DisenoCard    from '@components/DisenoCard.astro'
import MarcoMovil    from '@components/MarcoMovil.astro'
import ModSection    from '@components/modulos/ModSection.astro'
import ModBenefits   from '@components/modulos/ModBenefits.astro'
import ModAnatomy    from '@components/modulos/ModAnatomy.astro'
import ModResponsive from '@components/modulos/ModResponsive.astro'
import ModPattern    from '@components/modulos/ModPattern.astro'
import ModProse      from '@components/modulos/ModProse.astro'
import ModDosDonts   from '@components/modulos/ModDosDonts.astro'
import { getCollection, render } from 'astro:content'
import { SERVICES, COVERAGE_STATES, waUrl, WA_MESSAGES } from '@config/site'
import { siblingsServicios } from '@lib/servicios'

export async function getStaticPaths() {
  const entries = await getCollection('servicios', ({ data }) => !data.draft)
  return SERVICES.map((s) => ({
    params: { slug: s.id },
    props: { servicio: s, entry: entries.find((e) => e.id === s.id) ?? null },
  }))
}

const { servicio, entry } = Astro.props
const { id, label, desc } = servicio
const ServiceContent = entry ? (await render(entry)).Content : null
const pricingNote = entry?.data.pricing?.note
const includes = entry?.data.includes ?? []
const faqs = entry?.data.faqs?.length ? entry.data.faqs : [
  { question: '¿Cómo se cotiza?', answer: 'Por WhatsApp con la descripción del proyecto. Respondemos con propuesta de alcance y precio en menos de 24 h hábiles.' },
  { question: '¿Atienden mi zona?', answer: 'Atendemos en todo México de forma remota. Para CDMX podemos coordinar reuniones presenciales cuando se requiera.' },
]

// ── Datos ricos por servicio ─────────────────────────────────────────────────
const DATA: Record<string, {
  accent: string
  subtitle: string
  descRight: [string, string]
  defTitle: string; defDesc: string; defBody: [string, string]
  beneficios: { titulo: string; desc: string }[]
  partes: { n: number; nombre: string; que: string; dato: string }[]
  disenos: { nombre: string; tag: string; desc: string }[]
  posBody: [string, string]
  procesoTitle: string; procesoBody: [string, string]
  sis: string[]; nos: string[]
}> = {

  consultoria: {
    accent: 'diagnóstico y propuesta',
    subtitle: 'Antes de construir, decidir bien. Definimos qué necesita tu proyecto — en lenguaje claro, por escrito, sin venderte de más.',
    descRight: [
      'La consultoría es la etapa que más se saltea y la que más errores evita. No es una reunión informal: es un diagnóstico de tu caso específico que termina en una propuesta por escrito con alcance, tiempos y costo.',
      'El entregable no es una presentación de ventas: es la herramienta con la que decides si avanzas, con quién y sobre qué. Si el proyecto no tiene sentido, te lo decimos antes de cobrarte un peso.',
    ],
    defTitle: '¿Qué es la consultoría?',
    defDesc: 'El diagnóstico que convierte una idea vaga en un plan accionable — antes de invertir en ejecución.',
    defBody: [
      'La consultoría es la etapa de análisis y recomendación que viene antes de cualquier trabajo ejecutivo. No construimos nada todavía: escuchamos tu caso, identificamos qué resuelve de verdad tu necesidad y te lo explicamos con claridad. El diagnóstico es el primer entregable, no un paso de ventas.',
      'Es útil siempre que haya incertidumbre sobre el qué: qué tipo de sitio conviene, cuántas páginas tienen sentido, qué tan prioritario es el blog, si vale la pena una ficha por servicio o basta con una landing. Esas decisiones tomadas mal al inicio cuestan mucho más después.',
    ],
    beneficios: [
      { titulo: 'Decisión informada', desc: 'Sabes qué construir y por qué antes de comprometerte. El diagnóstico elimina el «creo que necesito» y lo reemplaza por un plan con fundamento.' },
      { titulo: 'Propuesta honesta', desc: 'El alcance lo define el problema, no el presupuesto máximo. Si algo no aporta, no entra en la propuesta.' },
      { titulo: 'Menos retrabajo', desc: 'Cambiar de dirección a mitad de la implementación cuesta mucho más que tomar bien la decisión al inicio. La consultoría se paga sola.' },
    ],
    partes: [
      { n: 1, nombre: 'Escucha del caso',    que: 'Entendemos el objetivo, la audiencia y el contexto antes de hacer cualquier recomendación.',         dato: 'WhatsApp / videollamada' },
      { n: 2, nombre: 'Diagnóstico',         que: 'Análisis del proyecto: tipo de sitio, arquitectura de páginas, prioridades técnicas y de contenido.',  dato: 'Documento escrito' },
      { n: 3, nombre: 'Recomendación',       que: 'Qué conviene hacer, en qué orden y por qué. Incluye lo que no conviene hacer ahora.',                  dato: 'Mapa de URLs · Alcance' },
      { n: 4, nombre: 'Propuesta ejecutiva', que: 'Alcance específico, entregables, tiempos y costo — por escrito y en lenguaje claro.',                   dato: 'PDF / doc compartido' },
    ],
    disenos: [
      { nombre: 'Proyecto nuevo',        tag: 'Desde cero',          desc: 'No existe sitio todavía. La consultoría define qué construir: tipo de sitio, páginas clave, taxonomía, y qué contenido se necesita antes de diseñar.' },
      { nombre: 'Sitio sin conversiones', tag: 'Revisión existente',  desc: 'Hay sitio pero no genera contactos. El diagnóstico identifica dónde se pierde el visitante: velocidad, copy, falta de CTA, arquitectura de información.' },
      { nombre: 'Presupuesto acotado',   tag: 'Priorización',         desc: 'Hay un límite claro y hay que decidir en qué invertirlo. La consultoría prioriza qué tiene más impacto para el objetivo y qué puede esperar.' },
      { nombre: 'Propuesta interna',     tag: 'Justificación',         desc: 'Hay que presentarle el proyecto a un socio o consejo. La consultoría produce el documento que sustenta la decisión con datos y argumentos.' },
    ],
    posBody: [
      'La consultoría va al inicio: es el paso 0, antes de diseñar, escribir contenido o elegir herramientas. Sin ella, la implementación parte de supuestos — y los supuestos se corrigen durante el trabajo, que es cuando más cuesta.',
      'Puede contratarse sola (para quien quiere el diagnóstico y ejecutará por su cuenta) o como primera etapa de un proyecto completo. En ambos casos, el entregable es el mismo: un documento que deja claro qué se hace y por qué.',
    ],
    procesoTitle: 'Del primer mensaje al diagnóstico',
    procesoBody: [
      'Empieza con una conversación por WhatsApp o llamada — sin formularios. Preparamos un cuestionario breve para entender el negocio, la audiencia y los objetivos con detalle. El diagnóstico se hace sobre esas respuestas y sobre una revisión directa del contexto.',
      'El entregable llega en 3 a 5 días hábiles: un documento con el análisis, la recomendación de alcance y la propuesta ejecutiva. Si algo no queda claro, lo revisamos en una segunda sesión sin costo adicional. Sin presión para avanzar.',
    ],
    sis: [
      'Llega con tu objetivo claro, aunque no sepas cómo lograrlo — ese es el trabajo de la consultoría.',
      'Pide el diagnóstico por escrito: si no está en papel, no hay forma de comparar ni de rendirle cuentas.',
      'Usa la propuesta para comparar con otras opciones: el documento es tuyo y puedes mostrarlo a quien quieras.',
      'Contrata la consultoría antes de la implementación, incluso si parece «obvio» lo que necesitas.',
    ],
    nos: [
      'No saltes directo a la implementación «para ahorrar»: el retrabajo posterior cuesta más que el diagnóstico.',
      'No des por bueno un diagnóstico que no explica el porqué de cada recomendación.',
      'No confundas propuesta con presupuesto: la propuesta define el alcance; el presupuesto sale del alcance.',
      'No aceptes un alcance vago («hacemos el sitio completo»): exige entregables con nombre y definición de terminado.',
    ],
  },

  implementacion: {
    accent: 'del plan a la entrega',
    subtitle: 'Ejecutamos lo acordado con un proceso claro, comunicación en cada paso y un resultado documentado que puedes verificar.',
    descRight: [
      'La implementación construye sobre lo que ya se decidió. El alcance está fijado en la propuesta y cualquier cambio se discute antes de ejecutarlo: nunca recibes trabajo que no aprobaste ni facturas inesperadas.',
      'Entregamos un sitio Astro estático: rápido, editable en Markdown y publicado en Cloudflare Pages. El código y el contenido son tuyos — sin dependencia del proveedor, sin licencias que pagar.',
    ],
    defTitle: '¿Qué es la implementación?',
    defDesc: 'La ejecución del alcance acordado: del repositorio vacío al sitio publicado, documentado y verificado contigo.',
    defBody: [
      'La implementación es la etapa de construcción: levantamos el sitio sobre el diagnóstico o propuesta aprobados. Configuramos el repositorio, integramos las colecciones de contenido, conectamos el dominio, desplegamos en Cloudflare Pages y hacemos la verificación final contigo.',
      'La diferencia con «hacemos un sitio» es que aquí el alcance está delimitado por escrito desde antes de empezar. Cada entregable tiene un nombre y una definición de terminado; cuando todos están listos, la implementación cierra.',
    ],
    beneficios: [
      { titulo: 'Velocidad real', desc: 'Sitio estático Astro: Lighthouse > 95, TTFB < 300 ms en Cloudflare CDN global. Sin plugins que ralenticen ni bases de datos que fallen.' },
      { titulo: 'Contenido en tus manos', desc: 'Todo el contenido vive en archivos Markdown. Puedes editarlo tú mismo desde el primer día, sin tocar código ni depender del proveedor.' },
      { titulo: 'Sin sorpresas en la factura', desc: 'Cada cambio fuera del alcance se comunica con su impacto antes de ejecutarse. Nunca recibes trabajo que no aprobaste.' },
    ],
    partes: [
      { n: 1, nombre: 'Configuración del entorno', que: 'Repositorio, estructura de proyecto, Astro 6, integraciones y variables. La base sobre la que todo corre.',          dato: 'GitHub · Node 22 · Astro 6' },
      { n: 2, nombre: 'Colecciones y contenido',   que: 'Cada tipo de contenido en su colección Markdown con esquema Zod. Separar el dato del diseño es lo que hace el sitio editable.', dato: 'src/content/ · Zod schema' },
      { n: 3, nombre: 'Deploy y dominio',           que: 'Publicación en Cloudflare Pages, configuración de dominio y DNS. El sitio es verificable desde el primer build parcial.',      dato: 'Cloudflare Pages · GitHub Actions' },
      { n: 4, nombre: 'Verificación y entrega',    que: 'Revisión conjunta, guía de edición y sesión de transferencia. El cliente opera con autonomía desde el primer día.',            dato: 'Checklist de entrega · Guía .md' },
    ],
    disenos: [
      { nombre: 'Sitio nuevo completo',    tag: 'Desde propuesta',    desc: 'El caso más común: sitio completo sobre propuesta aprobada. Home, servicios o productos, blog y contacto. Entrega en 3 a 5 semanas.' },
      { nombre: 'Landing de lanzamiento', tag: 'MVP rápido',          desc: 'Una sola página de alta conversión para validar una propuesta de valor. Sin blog ni catálogo. Una semana de trabajo, lista para probar.' },
      { nombre: 'Migración a Astro',      tag: 'Desde WordPress',     desc: 'Contenido migrado a Markdown, tema reemplazado por componentes Astro, publicado en Cloudflare. Sin tiempo de caída y con mejor rendimiento.' },
      { nombre: 'Módulo adicional',       tag: 'Sitio existente',     desc: 'Se agrega una sección que no estaba en el alcance original: catálogo de productos, sección de blog, integración de reseñas o formulario.' },
    ],
    posBody: [
      'La implementación es el paso 2: entra cuando la consultoría terminó o cuando el cliente llega con el alcance definido. Sin un alcance claro no puede comprometerse a tiempos ni a entregables concretos — por eso la propuesta previa no es opcional.',
      'Cuando termina, abre el soporte. La implementación cierra con la guía de edición y la sesión de transferencia precisamente para que el siguiente paso sea fluido: el cliente sabe operar el sitio y el soporte sabe de dónde partir.',
    ],
    procesoTitle: 'Del repositorio al sitio en vivo',
    procesoBody: [
      'Arrancamos con la revisión de la propuesta y la configuración del entorno. Desde el inicio tienes acceso al repositorio para seguir el avance. A mitad del proyecto publicamos en un subdominio de staging para que revises con calma antes de la entrega final.',
      'La entrega incluye el sitio en tu dominio, la guía de edición en Markdown y una sesión de transferencia donde explicamos cómo actualizar contenido, agregar páginas y publicar en el blog. El sitio es 100 % tuyo: código, dominio y contenido.',
    ],
    sis: [
      'Aprueba el alcance por escrito antes de que empiece el trabajo: es tu garantía de lo que recibirás.',
      'Aprovecha el staging para revisar con tiempo: los cambios antes de la entrega final no tienen costo adicional.',
      'Haz la sesión de transferencia aunque creas que no la necesitas: vale más de lo que parece.',
      'Pide la guía de edición en texto y guárdala: es el manual de operación de tu sitio.',
    ],
    nos: [
      'No agregues requerimientos nuevos durante la ejecución sin acordar el impacto en tiempos y costo primero.',
      'No ignores las preguntas técnicas del equipo: cada duda sin respuesta detiene el avance.',
      'No saltes la verificación final: es el momento para señalar lo que no quedó como se acordó.',
      'No pierdas acceso al repositorio ni al dashboard de Cloudflare — son tuyos, no los cedas.',
    ],
  },

  soporte: {
    accent: 'acompañamiento continuo',
    subtitle: 'El trabajo no termina en la entrega. Mantenemos, mejoramos y respondemos para que tu sitio siga funcionando con el tiempo.',
    descRight: [
      'El soporte entra donde termina la implementación. Se encarga de lo que ningún sitio se ahorra: actualizaciones de contenido, corrección de errores, nuevas necesidades que van surgiendo y comunicación directa cuando algo falla.',
      'El canal es WhatsApp, la respuesta es en horario hábil y el principio es el mismo que en todo: alcance claro antes de ejecutar. Sin sorpresas, sin tareas fantasma, sin facturas por trabajo que no acordaste.',
    ],
    defTitle: '¿Qué es el soporte?',
    defDesc: 'El servicio continuo que mantiene el sitio operando, actualizado y respondiendo a las necesidades que van surgiendo.',
    defBody: [
      'El soporte cubre tres tipos de trabajo: el mantenimiento preventivo (que el sitio no se rompa), el correctivo (arreglar lo que se rompe) y las mejoras (lo que va creciendo con el negocio: nuevas secciones, precios actualizados, artículos de blog).',
      'La diferencia con el soporte estándar de agencia es el canal: WhatsApp. La solicitud entra como conversación — con contexto, sin demora. Y para trabajos que van más allá del mantenimiento rutinario, el alcance se acuerda antes de ejecutar.',
    ],
    beneficios: [
      { titulo: 'Respuesta directa', desc: 'WhatsApp en horario hábil, sin tickets ni formularios. La solicitud entra como conversación — con nombre, contexto y sin intermediarios.' },
      { titulo: 'Sin retención forzada', desc: 'Por evento o plan periódico, según lo que encaje mejor. No hay contrato mínimo ni penalización por no continuar. Pagas por el trabajo realizado.' },
      { titulo: 'Alcance previo siempre', desc: 'Para trabajos más allá de una actualización puntual, el alcance se acuerda antes. Nunca recibes sorpresas en la factura.' },
    ],
    partes: [
      { n: 1, nombre: 'Actualización de contenido', que: 'Textos, precios, imágenes, fichas de producto o servicio. Lo más frecuente — se resuelve en horas desde la solicitud.',     dato: 'WhatsApp → Markdown → Push' },
      { n: 2, nombre: 'Corrección de errores',      que: 'Enlace roto, formulario que no envía, layout descuadrado. Se prioriza sobre el resto del trabajo del día.',              dato: 'Diagnóstico → fix → verif.' },
      { n: 3, nombre: 'Mejoras y nuevas secciones', que: 'Funcionalidades nuevas que no estaban en el alcance original. Siempre con propuesta de alcance escrita antes de ejecutar.', dato: 'Propuesta → ejecución' },
      { n: 4, nombre: 'Mantenimiento preventivo',   que: 'Revisión periódica de Core Web Vitals, dependencias y configuración. Evita que los problemas pequeños se conviertan en urgencias.', dato: 'Reporte mensual opcional' },
    ],
    disenos: [
      { nombre: 'Plan mensual',              tag: 'Operación continua',   desc: 'Horas reservadas cada mes para actualizaciones, correcciones y mejoras. Ideal si el contenido cambia con frecuencia o el sitio es parte activa del negocio.' },
      { nombre: 'Atención puntual',          tag: 'Por evento',           desc: 'Algo concreto ahora: un error urgente, un cambio de precios, una nueva sección. Se cotiza y ejecuta sin compromiso de continuidad.' },
      { nombre: 'Post-lanzamiento',          tag: 'Primeras semanas',     desc: 'El período después de publicar siempre trae ajustes. Cobertura específica para ese período crítico donde surgen correcciones de copy, imágenes y formularios.' },
      { nombre: 'Traspaso de mantenimiento', tag: 'Sitio de terceros',    desc: 'Ya tienes un sitio Astro y quieres que alguien lo mantenga. Diagnóstico del estado actual antes de tomar el mantenimiento — sin sorpresas.' },
    ],
    posBody: [
      'El soporte es el tercer paso: viene después de la implementación y mantiene vivo lo que se construyó. Puede contratarse de forma independiente — para quien ya tiene un sitio Astro y necesita mantenimiento — o como continuación natural de la implementación.',
      'Su relación con la consultoría también es directa: cuando las mejoras acumuladas llegan a un punto donde tiene más sentido redefinir el alcance del sitio que seguir sumando piezas, la consultoría vuelve a entrar. El soporte bien llevado identifica ese momento antes de que sea urgente.',
    ],
    procesoTitle: 'De la solicitud al cambio publicado',
    procesoBody: [
      'Escribes por WhatsApp con la solicitud, respondemos con un tiempo estimado y ejecutamos. Para actualizaciones de contenido el ciclo es de horas; para correcciones urgentes, priorizamos sobre el resto del trabajo del día.',
      'Para cambios que implican desarrollo (nueva sección, integración, rediseño parcial), la respuesta inicial es un alcance por escrito con tiempo y costo antes de cualquier línea de código. Sabes exactamente qué estás aprobando antes de decir que sí.',
    ],
    sis: [
      'Sé específico en las solicitudes: «cambiar el precio de X a $Y» es mejor que «actualizar precios».',
      'Guarda el acceso al repositorio y al dashboard de Cloudflare — aunque no lo uses, son tuyos.',
      'Pide el reporte mensual si quieres visibilidad de lo que se hizo y el estado del sitio.',
      'Comunica los cambios de negocio antes de que lleguen urgentes: el soporte planificado cuesta menos.',
    ],
    nos: [
      'No acumules cambios pequeños durante semanas y los mandes todos juntos como urgente.',
      'No des por hecho el alcance: si hay duda sobre si algo está incluido, pregunta antes de asumir.',
      'No pierdas el acceso a Cloudflare ni al repositorio — recuperarlo toma tiempo y dinero.',
      'No esperes a que algo se rompa para contratar mantenimiento: el preventivo es más barato que el correctivo.',
    ],
  },
}

const d = DATA[id] ?? DATA['consultoria']

// Recetas responsive
const recetaWA = `<!-- waUrl() construye el enlace — nunca wa.me a mano.
     El mensaje precargado sale de WA_MESSAGES en site.ts. -->
<a href={waUrl(WA_MESSAGES.servicios)}
   class="btn-wa" target="_blank" rel="noopener noreferrer">
  Cotizar por WhatsApp
</a>

// site.ts:
export const WA_MESSAGES = {
  servicios: 'Hola, quiero cotizar un servicio',
}`

const recetaCierre = `/* CTA principal: full-width en móvil, auto en escritorio.
   safe-area evita que lo tape la barra de gestos del iPhone. */
.cta-wa {
  display: grid; place-items: center;
  width: 100%; min-height: 52px;
  padding-bottom: env(safe-area-inset-bottom);
}
@media (min-width: 640px) {
  .cta-wa { width: auto; min-width: 220px; }
}`

// Cierre
const cierreItems = siblingsServicios(id)
const cierreCta = {
  label: 'Cotizar por WhatsApp',
  href: waUrl(WA_MESSAGES.servicios),
  sub: 'Respuesta en < 24 h',
  external: true,
}
---

<PageLayout
  title={`${label} — servicio profesional`}
  description={entry?.data.seoDescription ?? desc}
  pageType="service"
  schemaData={{
    service: {
      name: label,
      description: desc,
      path: `/servicios/${id}`,
      serviceType: label,
      areaServed: COVERAGE_STATES.map((z) => z.label),
    },
    faqs,
  }}
  breadcrumbs={[{ label: 'Servicios', href: '/servicios' }, { label }]}
  guia={false}
>

  <Hero
    badge={`Servicio · ${id === 'consultoria' ? 'Diagnóstico' : id === 'implementacion' ? 'Construcción' : 'Mantenimiento'}`}
    title={`${label}:`}
    accent={d.accent}
    subtitle={d.subtitle}
    descRight={[d.descRight[0], d.descRight[1]]}
  />

  {/* ── 1) DEFINICIÓN ── */}
  <ModSection
    eyebrow="Definición"
    title={d.defTitle}
    desc={d.defDesc}
    body={[d.defBody[0], d.defBody[1]]}
  />

  {/* ── 2) POR QUÉ IMPORTA — beneficios ── */}
  <ModSection
    surface
    eyebrow="Por qué importa"
    title="¿Para qué sirve?"
    desc={`Las tres razones concretas por las que ${label.toLowerCase()} pertenece en todo proyecto bien hecho.`}
    body={[
      'Cada beneficio sale de la misma fuente: la claridad antes de empezar. Cuando el alcance está definido, el proceso documentado y la comunicación es directa, los problemas se reducen a una fracción.',
      'El denominador común es la confianza: saber qué va a pasar antes de que pase. No es un lujo de proyectos grandes — es lo mínimo que cualquier cliente merece.',
    ]}
  >
    <ModBenefits items={d.beneficios} />
  </ModSection>

  {/* ── 3) ANATOMÍA — entregables + mockup en vivo ── */}
  <ModSection
    eyebrow="Anatomía"
    title="Qué recibes"
    desc={`Los cuatro entregables de ${label.toLowerCase()}: qué es cada uno, para qué sirve y cómo llega.`}
    body={[
      'Cada pieza tiene un propósito — no son pasos burocráticos, sino los elementos que hacen el trabajo verificable.',
      includes.length > 0
        ? `Incluye: ${includes.join(', ')}.${pricingNote ? ' · ' + pricingNote : ''}`
        : 'Los cuatro entregables se producen en orden. El último — verificación o transferencia — es el que cierra el servicio formalmente.',
    ]}
  >
    <ModAnatomy partes={d.partes}>
      {/* ── Mockup bespoke: propuesta (consultoria) ── */}
      {id === 'consultoria' && (
        <div class="mck-propuesta" role="img" aria-label="Propuesta de proyecto por escrito">
          <div class="mp__header">
            <span class="mp__label">PROPUESTA DE PROYECTO</span>
            <span class="mp__date">junio 2026</span>
          </div>
          <div class="mp__body">
            <div class="mp__row">
              <span class="mp__num">01</span>
              <div class="mp__content">
                <span class="mp__title">Escucha y objetivo</span>
                <span class="mp__line"></span>
              </div>
              <span class="mp__check">✓</span>
            </div>
            <div class="mp__row">
              <span class="mp__num">02</span>
              <div class="mp__content">
                <span class="mp__title">Diagnóstico del proyecto</span>
                <span class="mp__line"></span>
              </div>
              <span class="mp__check">✓</span>
            </div>
            <div class="mp__row">
              <span class="mp__num">03</span>
              <div class="mp__content">
                <span class="mp__title">Recomendación de alcance</span>
                <span class="mp__line mp__line--short"></span>
              </div>
              <span class="mp__check">✓</span>
            </div>
            <div class="mp__row mp__row--active">
              <span class="mp__num mp__num--active">04</span>
              <div class="mp__content">
                <span class="mp__title">Propuesta ejecutiva</span>
                <div class="mp__pills">
                  <span>Alcance</span><span>Tiempos</span><span>Costo</span>
                </div>
              </div>
