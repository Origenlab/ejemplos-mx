---
// ============================================================================
// /modulos/topbar — PÁGINA DEL MÓDULO «Topbar».
// ----------------------------------------------------------------------------
// Documenta a fondo UNA pieza del chrome: qué es, para qué sirve, su importancia,
// qué lleva y dónde va (capa conceptual / diseño-UX), y al final cómo está
// construido en esta plantilla (capa técnica: componente, SSoT, helpers, responsive).
// Primera de la serie /modulos/*; las siguientes (header, hero, menú) seguirán el
// mismo molde. Todo dato real sale de site.ts (SSoT); los enlaces, de telUrl()/waUrl().
// ============================================================================
import PageLayout from '@layouts/PageLayout.astro'
import Hero from '@components/Hero.astro'
import SectionHeading from '@components/SectionHeading.astro'
import SectionMenu from '@components/SectionMenu.astro'
import GaleriaDisenos from '@components/GaleriaDisenos.astro'
import DisenoCard from '@components/DisenoCard.astro'
import MarcoMovil from '@components/MarcoMovil.astro'
import Receta from '@components/Receta.astro'
import { SITE, CONTACT, WA_MESSAGES, waUrl } from '@config/site'

const schedule = CONTACT.schedule?.display as string | undefined

// Menú de cierre (reemplaza al antiguo CTABanner): navegación de la serie + el sitio.
// Patrón canónico del home: «el menú reparte, el último botón (WhatsApp) convierte».
const cierreItems = [
  { label: 'Todos los módulos', href: '/modulos', sub: 'Índice de la serie' },
  { label: 'Inicio', href: '/', sub: 'Volver a la home' },
  { label: 'Productos', href: '/productos', sub: 'Catálogo del sitio' },
  { label: 'Servicios', href: '/servicios', sub: 'Lo que ofreces' },
]
const cierreCta = {
  label: 'Cotizar por WhatsApp',
  href: waUrl(WA_MESSAGES.cotizar),
  sub: 'Respuesta inmediata',
  external: true,
}

// Las 4 piezas del topbar (misma fuente que la leyenda del componente).
const partes = [
  {
    n: 1,
    nombre: 'Propuesta principal',
    que: 'Una frase corta que posiciona la marca: lo primero que se lee. No es un eslogan vacío, sino la línea que dice a qué te dedicas. Ojo: el logotipo NO va aquí, va en el Header.',
    dato: 'SITE.tagline',
  },
  {
    n: 2,
    nombre: 'Horario',
    que: 'Señal de disponibilidad y confianza —«hay alguien y atiende a estas horas»—. Es información de apoyo, así que en móvil se oculta para cederle el espacio a las acciones.',
    dato: 'CONTACT.schedule.display',
  },
  {
    n: 3,
    nombre: 'Teléfono',
    que: 'Contacto directo con clic-para-llamar en el celular. El enlace tel: no se escribe a mano: lo arma telUrl() con el número en formato E.164.',
    dato: 'CONTACT.phone · telUrl()',
  },
  {
    n: 4,
    nombre: 'WhatsApp',
    que: 'La acción principal de la barra, resaltada como pastilla. El enlace SIEMPRE se arma con waUrl() y el mensaje precargado sale de WA_MESSAGES, para que el lead entre en materia desde el primer toque.',
    dato: 'waUrl(WA_MESSAGES.cotizar)',
  },
]

const beneficios = [
  {
    titulo: 'Alcance inmediato',
    desc: 'El teléfono y el WhatsApp están a un toque desde cualquier página, sin buscar. Menos fricción para contactar = más conversaciones.',
  },
  {
    titulo: 'Confianza a primera vista',
    desc: 'Horario y propuesta visibles dicen, sin palabras, «este es un negocio real y disponible». Esa señal pesa antes de leer una sola línea del contenido.',
  },
  {
    titulo: 'Constancia en todo el sitio',
    desc: 'Va en todas las páginas, idéntica. El visitante siempre sabe dónde encontrar el contacto, esté donde esté dentro del sitio.',
  },
]

const sis = [
  'Mantenla ligera: propuesta + 2 o 3 datos de contacto, nada más.',
  'En móvil, conserva las acciones (llamar / WhatsApp) y suelta lo accesorio (propuesta, horario).',
  'Usa datos reales y una sola fuente (site.ts); cámbialos una vez y se actualizan en todo el sitio.',
  'Arma los enlaces con telUrl() / waUrl(): centralizan el número y el encoding.',
]
const nos = [
  'No metas el logotipo aquí: la marca vive en el Header, justo debajo.',
  'No escribas el tel: o el wa.me a mano dentro de un componente (regla dura D4).',
  'No la satures de enlaces ni la conviertas en un segundo menú.',
  'No dejes datos DEMO en producción: teléfono, horario y mensaje deben ser los reales.',
]

// Variantes de topbar (galería de diseños). Cada objeto describe una variante;
// su réplica en vivo se monta abajo como slot `vista-<i>` (mismo orden). Patrones
// reales documentados (NN/g, Material Design, guías de e-commerce) — ver memory.
const disenos = [
  {
    nombre: 'Barra de contacto',
    tag: 'Negocio local · Servicios',
    desc: 'La de esta plantilla: propuesta breve más teléfono, WhatsApp y horario. Deja el contacto a un toque y transmite disponibilidad. Ideal para despachos, clínicas, talleres y todo negocio que vive de que le llamen o le escriban.',
  },
  {
    nombre: 'Barra de anuncio',
    tag: 'E-commerce · Promoción',
    desc: 'Un solo mensaje corto —«Envío gratis desde $999»— con su enlace de acción y un cierre. La regla es menos de diez palabras: el envío gratis ataca de frente la causa número uno de carritos abandonados.',
  },
  {
    nombre: 'Envío gratis con progreso',
    tag: 'E-commerce · Ticket promedio',
    desc: 'Le dice al cliente cuánto le falta para el envío gratis y lo pinta con una barra de avance. Es un empujón sutil al valor del pedido: bien usado, puede subir el ticket promedio entre un 10 % y un 20 %.',
  },
  {
    nombre: 'Barra rotativa',
    tag: 'Varias campañas',
    desc: 'Tres o cuatro mensajes que rotan —automático o con flechas— cuando hay más de una promo viva a la vez: envío, devoluciones, nueva colección. Con dos o más mensajes, rotar rinde más que amontonarlos en una línea.',
  },
  {
    nombre: 'Barra global',
    tag: 'Marcas internacionales',
    desc: 'Idioma, moneda y accesos de servicio —cuenta, ayuda, seguimiento de pedido— alineados a la derecha. Es la barra de las tiendas que venden a varios países: ordena lo «de sistema» arriba y deja el menú principal limpio.',
  },
  {
    nombre: 'Top app bar',
    tag: 'SaaS · Aplicaciones',
    desc: 'La barra de una aplicación, no de un sitio de marketing: menú, título de la pantalla actual y acciones —buscar, notificaciones, perfil—. Sigue el patrón de Material Design; se usa en paneles, dashboards y herramientas web.',
  },
]

// ── Recetas de implementación (móvil) — strings que pinta <Receta> ───────────
// 1 · Prioridad / progressive disclosure: la barra suelta lo accesorio por pasos.
const recetaPrioridad = `/* TOPBAR · patrón «prioridad» (progressive disclosure)
   Regla de oro: lo informativo cae primero; las ACCIONES nunca.
   En cada breakpoint la barra suelta lo menos crítico. */

.topbar__tagline,
.topbar__schedule { display: inline-flex; }   /* visibles en escritorio */

@media (max-width: 900px) {
  .topbar__tagline { display: none; }          /* 1º cae la propuesta */
}

@media (max-width: 600px) {
  .topbar__schedule { display: none; }         /* 2º cae el horario */
}

@media (max-width: 420px) {
  /* En lo más estrecho, el teléfono se reduce a su ícono (☎),
     pero el enlace tel: y el WhatsApp SIEMPRE permanecen. */
  .topbar__phone-label { display: none; }
}`

// 2 · Zona del pulgar: la acción principal baja al borde inferior en móvil.
const recetaPulgar = `/* ACCIÓN EN LA «ZONA DEL PULGAR»
   En el teléfono, la acción que más convierte baja al borde
   inferior: es el área más cómoda de alcanzar con una mano. */

@media (max-width: 600px) {
  .acciones-movil {
    position: fixed;
    inset: auto 0 0 0;            /* fija abajo, de borde a borde */
    z-index: 50;
    display: flex;
    gap: .5rem;
    padding: .5rem;
    /* No quedar tapada por la barra de gestos del iPhone: */
    padding-bottom: calc(.5rem + env(safe-area-inset-bottom));
    background: #fff;
    border-top: 1px solid #e8e8e8;
  }

  .acciones-movil a {
    flex: 1 1 0;
    min-height: 44px;             /* objetivo táctil mínimo (iOS HIG) */
    display: grid;
    place-items: center;
  }
}`

// 3 · Barra de anuncio compacta y descartable (recuerda el cierre en la sesión).
const recetaAviso = `<!-- BARRA DE ANUNCIO · compacta y DESCARTABLE
     En móvil el espacio es oro: una sola acción, < 45 caracteres,
     alto 36–42px y un botón para cerrarla. Recordamos el cierre
     para no repetirla en cada página de la sesión. -->
<aside id="aviso" class="aviso">
  <p class="aviso__txt">Envío gratis desde $999</p>
  <button class="aviso__x" type="button" aria-label="Cerrar aviso">✕</button>
</aside>

<script>
  const aviso = document.getElementById('aviso');
  // Si ya se cerró antes en esta sesión, no se vuelve a mostrar.
  if (sessionStorage.getItem('aviso:cerrado')) aviso.hidden = true;
  aviso.querySelector('.aviso__x').addEventListener('click', () => {
    aviso.hidden = true;
    sessionStorage.setItem('aviso:cerrado', '1');
  });
</script>`

// 4 · Overflow nativo (sin JS) para las acciones secundarias.
const recetaOverflow = `<!-- MENÚ DE OVERFLOW · acciones secundarias, SIN JavaScript
     Lo primario (llamar / WhatsApp) queda siempre visible; lo
     secundario se pliega en <details>: accesible por teclado y
     lectores de pantalla de fábrica, sin una línea de script. -->
<details class="overflow">
  <summary class="overflow__btn" aria-label="Más opciones">⋯</summary>
  <nav class="overflow__panel">
    <a href="#horario">Horario</a>
    <a href="#ubicacion">Ubicación</a>
    <a href="#redes">Redes sociales</a>
  </nav>
</details>`
---

<PageLayout
  title="El Topbar — la barra utilitaria superior"
  description="Topbar: barra utilitaria superior con teléfono, horario y WhatsApp. Datos desde site.ts (CONTACT · waUrl); el logo va en el header, no aquí."
  pageType="page"
  guia={false}
  breadcrumbs={[{ label: 'Módulos', href: '/modulos/topbar' }, { label: 'Topbar' }]}
>
  <Hero
    badge="Módulo del sitio · Topbar"
    title="El Topbar:"
    accent="la barra utilitaria"
    subtitle="La franja delgada que corona el sitio, por encima del logotipo y el menú. Pequeña en tamaño, grande en función: es la capa de «siempre disponible» —contacto y confianza a un golpe de vista—."
    descRight={[
      'No es una ficha técnica más: es el módulo entero, abierto y explicado. Qué problema resuelve y por qué se gana su lugar, de qué piezas se compone, dónde encaja en el layout y cómo está construido —el recorrido completo, del criterio de diseño a la implementación.',
      'Y todo se apoya en un mismo principio: una única fuente de verdad. El contenido y el diseño van por separado —los datos en site.ts, la apariencia en el componente—; por eso ajustas un valor una sola vez y el cambio se propaga, idéntico y sin sorpresas, a cada página.',
    ]}
  />

  {/* ── 1) ¿QUÉ ES? ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Definición"
        title="¿Qué es un topbar?"
        desc="La barra utilitaria superior: una franja fina, de un solo color de marca, que va por encima del menú y se repite en todas las páginas."
        body={[
          'El topbar (o barra utilitaria) es esa tira delgada que corona el sitio, antes del logotipo y la navegación. No es decoración ni un segundo menú: es el lugar donde pones lo que el visitante puede necesitar en cualquier momento —cómo te llama, en qué horario, por dónde escribirte— sin que estorbe al mensaje principal de la página.',
          'Por eso es discreta: poca altura, un color sobrio de marca y texto pequeño. Su trabajo no es llamar la atención, sino estar ahí cuando se la busca. Piensa en ella como el mostrador de información de una tienda: nadie entra por él, pero todos agradecen que exista y esté siempre en el mismo sitio.',
        ]}
      />
    </div>
  </section>

  {/* ── 2) ¿PARA QUÉ SIRVE? — función e importancia ── */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Función e importancia"
        title="¿Para qué sirve?"
        desc="Cumple dos funciones a la vez: acercar el contacto y transmitir confianza, en todas las páginas y sin pedir nada a cambio."
        body={[
          'Su función es ser la capa de «siempre disponible». Mientras el hero presenta y el catálogo vende, el topbar resuelve una pregunta muy concreta que el visitante trae en la cabeza: «si me interesa, ¿cómo los contacto?». Tener esa respuesta a la vista, en cada página, baja la fricción justo en el momento en que alguien decide dar el paso.',
          'Y ahí está su importancia: una parte enorme de las consultas se pierden por un detalle tonto —el visitante no encontró el teléfono o el WhatsApp rápido y se fue—. El topbar elimina ese punto de fuga. Es de los elementos más pequeños del sitio y, sin embargo, de los que más trabajan por la conversión.',
        ]}
      />
      <div class="bene">
        {beneficios.map((b) => (
          <article class="bene__card">
            <h3 class="bene__title">{b.titulo}</h3>
            <p class="bene__desc">{b.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ── 3) ¿QUÉ LLEVA? — anatomía con ejemplo en vivo ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Anatomía"
        title="¿Qué va en el topbar?"
        desc="Cuatro piezas, ni una más: una propuesta corta y tres formas de contacto."
        body={[
          'Cada pieza se gana su lugar por una razón. La propuesta posiciona la marca en una línea; el teléfono y el WhatsApp dejan el contacto a un toque; el horario aporta la señal de disponibilidad. Si un elemento no trabaja para el visitante, no entra en la barra.',
          'Abajo la ves montada con los datos reales de la plantilla. Cada punto numerado se desglosa en su tarjeta —qué resuelve y de qué campo de site.ts toma su valor—, para que distingas de un vistazo qué es diseño y qué es dato.',
        ]}
      />

      {/* Ejemplo estático del topbar (réplica con los datos reales de site.ts). */}
      <div class="tbx" role="img" aria-label="Ejemplo de barra utilitaria superior">
        <span class="tbx__promo"><span class="tbx__n">1</span>{SITE.tagline}</span>
        {schedule && (
          <span class="tbx__item"><span class="tbx__n">2</span>{schedule}</span>
        )}
        <span class="tbx__item"><span class="tbx__n">3</span>{CONTACT.phone}</span>
        <span class="tbx__item tbx__wa"><span class="tbx__n">4</span>WhatsApp</span>
      </div>

      <div class="partes">
        {partes.map((p) => (
          <article class="parte">
            <span class="parte__num">{p.n}</span>
            <div class="parte__body">
              <h3 class="parte__nombre">{p.nombre}</h3>
              <p class="parte__que">{p.que}</p>
              <p class="parte__dato"><span>Dato</span> <code>{p.dato}</code></p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ── 3b) VARIANTES — otros diseños y aplicaciones (galería en vivo) ── */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Variantes"
        title="Otros diseños y aplicaciones"
        desc="El de esta plantilla es una barra de contacto, pero el topbar adopta muchas formas según el negocio."
        body={[
          'No hay un único topbar: hay una franja superior que cada tipo de sitio adapta a su objetivo. Una tienda la usa para promociones; una aplicación, para navegación y acciones; una marca global, para idioma y moneda. Mismo lugar, intención distinta.',
          'Abajo, seis variantes reales —cada una con una réplica en vivo y el tipo de proyecto donde brilla—. Sirven para reconocer cuál te conviene y para ver cómo el mismo molde se reescribe sin perder su sitio.',
        ]}
      />

      <GaleriaDisenos ariaLabel="Variantes de topbar">
        {/* 0 · Barra de contacto (la de esta plantilla) */}
        <DisenoCard {...disenos[0]}>
          <div class="tbv tbv--contacto" role="img" aria-label="Barra de contacto: propuesta, horario, teléfono y WhatsApp">
            <span class="tbv__t tbv__lead">Tu taller de confianza</span>
            <span class="tbv__t tbv__min">Lun–Sáb 9–18 h</span>
            <span class="tbv__t">55 1234 5678</span>
            <span class="tbv__pill">WhatsApp</span>
          </div>
        </DisenoCard>

        {/* 1 · Barra de anuncio / promoción */}
        <DisenoCard {...disenos[1]}>
          <div class="tbv tbv--anuncio" role="img" aria-label="Barra de anuncio: envío gratis con enlace y cierre">
            <span class="tbv__c">Envío gratis desde $999 <span class="tbv__a">Comprar →</span></span>
            <span class="tbv__x" aria-hidden="true">✕</span>
          </div>
        </DisenoCard>

        {/* 2 · Envío gratis con barra de progreso */}
        <DisenoCard {...disenos[2]}>
          <div class="tbv tbv--progreso" role="img" aria-label="Barra de progreso hacia el envío gratis">
            <span class="tbv__t">Te faltan <strong>$200</strong> para envío gratis</span>
            <span class="tbv__track" aria-hidden="true"><span class="tbv__fill"></span></span>
          </div>
        </DisenoCard>

        {/* 3 · Barra rotativa (multi-mensaje) */}
        <DisenoCard {...disenos[3]}>
          <div class="tbv tbv--rotativa" role="img" aria-label="Barra rotativa con varios mensajes">
            <span class="tbv__nav" aria-hidden="true">‹</span>
            <span class="tbv__c">Devoluciones gratis · 30 días</span>
            <span class="tbv__nav" aria-hidden="true">›</span>
            <span class="tbv__dots" aria-hidden="true"><i></i><i class="on"></i><i></i></span>
          </div>
        </DisenoCard>

        {/* 4 · Barra global: idioma / moneda / cuenta */}
        <DisenoCard {...disenos[4]}>
          <div class="tbv tbv--global" role="img" aria-label="Barra global: idioma, moneda y cuenta">
            <span class="tbv__t tbv__min">Ayuda</span>
            <span class="tbv__t tbv__min">Seguir pedido</span>
            <span class="tbv__sp"></span>
            <span class="tbv__chip">ES ▾</span>
            <span class="tbv__chip">MXN ▾</span>
            <span class="tbv__t">Mi cuenta</span>
          </div>
        </DisenoCard>

        {/* 5 · Top app bar (aplicación) */}
        <DisenoCard {...disenos[5]}>
          <div class="tbv tbv--app" role="img" aria-label="Top app bar: menú, título de pantalla y acciones">
            <span class="tbv__ic" aria-hidden="true">≡</span>
            <span class="tbv__title">Panel</span>
            <span class="tbv__sp"></span>
            <span class="tbv__ic" aria-hidden="true">⌕</span>
            <span class="tbv__ic" aria-hidden="true">○</span>
            <span class="tbv__av" aria-hidden="true">A</span>
          </div>
        </DisenoCard>
      </GaleriaDisenos>
    </div>
  </section>

  {/* ── 3c) RESPONSIVE Y MÓVIL — patrones + recetas comentadas ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Responsive y móvil"
        title="Cómo se comporta en el teléfono"
        desc="En móvil un topbar no es «el de escritorio encogido»: es decidir qué sobrevive y dónde se toca."
        body={[
          'La pantalla del teléfono no da para todo, así que la barra se piensa al revés: primero, qué es imprescindible. Lo informativo —propuesta, horario— cae primero; la razón de ser de la barra, la acción de contacto, nunca se va. Es el patrón de «prioridad» o divulgación progresiva: mostrar lo esencial y revelar el resto solo si se pide.',
          'Y manda la ergonomía: en una mano, lo cómodo es la franja inferior —la «zona del pulgar»—, los objetivos se tocan a partir de 44 px y un aviso que ocupa pantalla debe poder cerrarse. Abajo, cuatro patrones, cada uno con su vista en el teléfono y una receta comentada lista para copiar.',
        ]}
      />

      <div class="pats">
        {/* 1 · Prioridad / progressive disclosure */}
        <article class="pat">
          <div class="pat__demo">
            <MarcoMovil ariaLabel="Topbar en móvil: solo sobreviven las acciones de contacto">
              <div class="tbm tbm--header">
                <span class="tbm__brand">Taller</span>
                <span class="tbm__sp"></span>
                <span class="tbm__ic" aria-hidden="true">☎</span>
                <span class="tbm__wa">WhatsApp</span>
              </div>
              <div class="skel"><span></span><span></span><span></span><span></span></div>
            </MarcoMovil>
          </div>
          <div class="pat__info">
            <h3 class="pat__title">1 · Prioridad: que sobrevivan las acciones</h3>
            <p class="pat__desc">Conforme se angosta la pantalla, la barra suelta primero la propuesta, luego el horario; el teléfono y el WhatsApp se quedan siempre —y en lo más estrecho el tel se vuelve solo ícono—.</p>
            <Receta titulo="CSS · ocultar por prioridad" lang="css" code={recetaPrioridad} />
          </div>
        </article>

        {/* 2 · Zona del pulgar (acción abajo) */}
        <article class="pat">
          <div class="pat__demo">
            <MarcoMovil ariaLabel="Acción principal anclada abajo, en la zona del pulgar">
              <div class="tbm tbm--header">
                <span class="tbm__brand">Taller</span>
                <span class="tbm__sp"></span>
                <span class="tbm__ic" aria-hidden="true">≡</span>
              </div>
              <div class="skel"><span></span><span></span><span></span><span></span></div>
              <div class="tbm-bottom" aria-hidden="true">
                <span class="tbm-bottom__btn">Llamar</span>
                <span class="tbm-bottom__btn tbm-bottom__btn--wa">WhatsApp</span>
              </div>
            </MarcoMovil>
          </div>
          <div class="pat__info">
            <h3 class="pat__title">2 · La acción, en la zona del pulgar</h3>
            <p class="pat__desc">En el teléfono, el contacto baja al borde inferior —lo más cómodo de alcanzar con una mano—, con objetivos de 44 px y respetando el área segura del iPhone.</p>
            <Receta titulo="CSS · barra inferior + safe-area" lang="css" code={recetaPulgar} />
          </div>
        </article>

        {/* 3 · Barra de anuncio descartable */}
        <article class="pat">
          <div class="pat__demo">
            <MarcoMovil ariaLabel="Barra de anuncio compacta y descartable en móvil">
              <div class="tbm tbm--aviso">
                <span>Envío gratis desde $999</span>
                <span class="tbm__x" aria-hidden="true">✕</span>
              </div>
              <div class="tbm tbm--header">
                <span class="tbm__brand">Tienda</span>
                <span class="tbm__sp"></span>
                <span class="tbm__ic" aria-hidden="true">⌕</span>
                <span class="tbm__ic" aria-hidden="true">≡</span>
              </div>
              <div class="skel"><span></span><span></span><span></span></div>
