---
// ============================================================================
// /modulos/whatsapp-flotante — PÁGINA DEL MÓDULO «WhatsApp flotante».
// ----------------------------------------------------------------------------
// Documenta a fondo el botón flotante de WhatsApp (FAB). PILOTO del «kit de
// módulo»: el armazón de secciones (ModSection, ModBenefits, ModAnatomy,
// ModResponsive/ModPattern, ModProse, ModDosDonts) vive en src/components/modulos/
// con su CSS scoped UNA vez. Esta página = DATOS + mockups bespoke (.wax/.wav/.wam).
// Todo enlace de WhatsApp con waUrl() (regla D4); el copy «a fondo» en MODULE_AFONDO.
// ============================================================================
import PageLayout from '@layouts/PageLayout.astro'
import Hero from '@components/Hero.astro'
import SectionMenu from '@components/SectionMenu.astro'
import GaleriaDisenos from '@components/GaleriaDisenos.astro'
import DisenoCard from '@components/DisenoCard.astro'
import MarcoMovil from '@components/MarcoMovil.astro'
import ModSection from '@components/modulos/ModSection.astro'
import ModBenefits from '@components/modulos/ModBenefits.astro'
import ModAnatomy from '@components/modulos/ModAnatomy.astro'
import ModResponsive from '@components/modulos/ModResponsive.astro'
import ModPattern from '@components/modulos/ModPattern.astro'
import ModProse from '@components/modulos/ModProse.astro'
import ModDosDonts from '@components/modulos/ModDosDonts.astro'
import { WA_MESSAGES, waUrl } from '@config/site'
import { siblingsModules } from '@lib/modules'

// Menú de cierre — derivado de MODULOS (SSoT) con siblingsModules.
const cierreItems = siblingsModules('whatsapp-flotante')
const cierreCta = { label: 'Cotizar por WhatsApp', href: waUrl(WA_MESSAGES.cotizar), sub: 'Respuesta inmediata', external: true }

// Ícono de WhatsApp (SVG inline, currentColor) — el MISMO del componente real.
const waIcon = `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`

const partes = [
  { n: 1, nombre: 'Ícono de WhatsApp', que: 'El logo de WhatsApp en SVG inline (sin imagen que cargar). Es el código universal de «escríbeme por aquí»: se reconoce al instante y no necesita texto para entenderse.', dato: 'SVG inline · currentColor' },
  { n: 2, nombre: 'Etiqueta', que: 'Un texto corto junto al ícono —«¿Necesitas ayuda?»— que invita a la acción en escritorio. En móvil se colapsa y queda solo el círculo, para no robarle pantalla al contenido.', dato: 'prop label' },
  { n: 3, nombre: 'Enlace + mensaje', que: 'El destino: abre wa.me con un mensaje ya escrito para que la conversación empiece con contexto, no en «hola». El enlace SIEMPRE se arma con waUrl() y el texto sale de WA_MESSAGES.', dato: 'waUrl(WA_MESSAGES.x)' },
  { n: 4, nombre: 'Anclaje fijo', que: 'Lo que lo vuelve «flotante»: queda pegado a una esquina, por encima de todo (z-index alto) y respeta el área segura del iPhone para no caer bajo la barra de gestos.', dato: 'position: fixed · z-index · safe-area' },
]

const beneficios = [
  { titulo: 'Contacto a un toque, siempre', desc: 'Está visible en cualquier página y en cualquier punto del scroll. El visitante nunca tiene que buscar «¿cómo los contacto?»: la respuesta lo acompaña a donde vaya.' },
  { titulo: 'Cero fricción a su canal favorito', desc: 'WhatsApp es donde la gente ya conversa a diario. Llevar el contacto a ese terreno —con el mensaje pre-armado— convierte una duda en una conversación, sin formularios ni esperas.' },
  { titulo: 'Convierte sin robar protagonismo', desc: 'Ocupa una esquina, no el contenido. Está cuando se le busca y se aparta cuando no, así suma conversaciones sin estorbar la lectura ni competir con el CTA principal.' },
]

const sis = [
  'Precarga un mensaje con contexto (WA_MESSAGES): la conversación arranca en materia, no en «hola».',
  'Arma el enlace con waUrl(): centraliza el número y el encoding (regla dura D4).',
  'Respeta el área segura del iPhone (env(safe-area-inset-bottom)) para que no caiga bajo la barra de gestos.',
  'En móvil colápsalo a solo ícono y deja un objetivo táctil de 44–52 px.',
  'Un solo botón flotante y un solo canal principal: claridad, no ruido.',
]
const nos = [
  'No escribas el wa.me ni el número a mano dentro del componente (regla dura D4).',
  'No tapes el contenido ni el CTA principal: súbelo cuando aparezcan el footer o un formulario.',
  'No abuses de pop-ups que salten solos ni de animaciones que distraigan.',
  'No multipliques botones flotantes (WhatsApp + Messenger + llamar + subir…): se vuelve ruido.',
  'No dejes el mensaje DEMO en producción: el texto pre-armado debe ser el real.',
]

const disenos = [
  { nombre: 'Pastilla con etiqueta', tag: 'Negocio local · Servicios', desc: 'La de esta plantilla: el ícono de WhatsApp más un texto corto que invita —«¿Necesitas ayuda?»—. La etiqueta empuja el primer toque en escritorio y se colapsa a solo ícono en móvil. Ideal para despachos, clínicas y talleres que viven de que les escriban.' },
  { nombre: 'Botón circular', tag: 'Minimal · Marca cuidada', desc: 'Solo el ícono en un círculo verde, sin texto. La opción más discreta: ocupa lo mínimo y confía en que el logo de WhatsApp se reconoce solo. Encaja en sitios de diseño limpio donde un texto flotante sobraría.' },
  { nombre: 'Con globo de aviso', tag: 'Tiendas · Campañas', desc: 'El círculo con un globo de notificación («1») o un mensaje que asoma a los pocos segundos. Simula una conversación que empieza y sube la tasa de clic, a cambio de ser más intrusivo: úsalo con mesura.' },
  { nombre: 'Multi-canal (speed dial)', tag: 'Varios contactos', desc: 'Un botón que, al tocarlo, despliega varias acciones —WhatsApp, llamar, correo—. Útil cuando de verdad ofreces varios canales; el riesgo es diluir la acción principal, así que pon primero el que más convierte.' },
  { nombre: 'Burbuja con mensaje', tag: 'Captación · Soporte', desc: 'Una burbuja estilo chat con una línea de bienvenida y, debajo, el botón de WhatsApp. Imita un widget de soporte sin su peso: da la sensación de «hay alguien» y baja la barrera de escribir.' },
  { nombre: 'Barra inferior (móvil)', tag: 'Mobile-first', desc: 'En el teléfono, en vez de un círculo, una barra fija abajo con una o dos acciones —Llamar · WhatsApp— en la zona del pulgar. Maximiza el toque cómodo cuando el móvil es el grueso del tráfico.' },
]

// ── Recetas de implementación — strings que pinta <Receta> (dentro de ModPattern) ──
const recetaColapsable = `/* WHATSAPP FLOTANTE · etiqueta colapsable
   En escritorio: ícono + un texto que invita a la acción.
   En móvil el espacio es oro → queda solo el círculo. */

.wa-float {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .75rem 1rem;                 /* pastilla con texto */
  border-radius: 9999px;
  background: #25D366; color: #fff;
}

@media (max-width: 640px) {
  .wa-float__label { display: none; }   /* 1º cae el texto */
  .wa-float { padding: .75rem; }        /* vuelve círculo */
}`

const recetaSafeArea = `/* ANCLAJE QUE RESPETA EL iPhone
   Fijo en la esquina inferior derecha, por encima de todo, y
   separado de la barra de gestos con la safe-area (iOS). */

.wa-float {
  position: fixed;
  right:  max(1rem, env(safe-area-inset-right));
  bottom: max(1rem, env(safe-area-inset-bottom));
  z-index: 9999;                        /* por encima del contenido */
  box-shadow: 0 4px 16px rgba(37,211,102,.4);
}`

const recetaClear = `<!-- NO TAPAR EL CIERRE
     Cuando el footer (o un CTA importante) entra en pantalla,
     el botón sube un poco para no taparlo. Sin librerías. -->
<script>
  const fab = document.querySelector('.wa-float');
  const footer = document.querySelector('footer');
  new IntersectionObserver(([e]) => {
    fab.classList.toggle('wa-float--up', e.isIntersecting);
  }).observe(footer);
</script>

<style>
  .wa-float { transition: transform .2s ease; }
  .wa-float--up { transform: translateY(-72px); }
</style>`

const recetaTap = `/* OBJETIVO TÁCTIL CÓMODO
   En móvil el círculo crece a 52px y el enlace ya es un <a>:
   tocable por teclado y lectores de pantalla de fábrica. */

@media (max-width: 640px) {
  .wa-float {
    width: 52px; height: 52px;          /* ≥ 44px (iOS HIG · WCAG) */
    display: grid; place-items: center;
  }
}

.wa-float:focus-visible {
  outline: 3px solid rgba(37,211,102,.5);
  outline-offset: 2px;
}`
---

<PageLayout
  title="El WhatsApp flotante — el botón de contacto que te sigue"
  description="Botón flotante de WhatsApp: contacto a un toque en cualquier página. Enlace con waUrl() y mensaje de WA_MESSAGES; nunca número hardcodeado (regla D4)."
  pageType="page"
  schemaType="TechArticle"
  guia={false}
  breadcrumbs={[{ label: 'Módulos', href: '/modulos' }, { label: 'WhatsApp flotante' }]}
>
  <Hero
    badge="Módulo del sitio · WhatsApp flotante"
    title="El WhatsApp flotante:"
    accent="el contacto que te sigue"
    subtitle="El botón verde fijo en una esquina, visible en cada página y en cada punto del scroll. Pequeño y discreto, pero deja el canal de contacto favorito de la gente a un solo toque, siempre."
    descRight={[
      'No es una ficha técnica más: es el módulo entero, abierto y explicado. Qué problema resuelve y por qué se gana su lugar, de qué piezas se compone, dónde encaja en el layout y cómo está construido —el recorrido completo, del criterio de diseño a la implementación.',
      'Y todo se apoya en un mismo principio: una única fuente de verdad. El número y el mensaje viven en site.ts y el enlace se arma con waUrl(); por eso lo ajustas una sola vez y el cambio se propaga, idéntico y sin sorpresas, a cada página del sitio.',
    ]}
  />

  {/* 1) ¿QUÉ ES? */}
  <ModSection
    eyebrow="Definición"
    title="¿Qué es el WhatsApp flotante?"
    desc="Un botón fijo, anclado a una esquina de la pantalla, que abre WhatsApp con un mensaje ya listo. Acompaña al visitante por todo el sitio."
    body={[
      'El WhatsApp flotante (o FAB de contacto, por «floating action button») es ese botón verde que se queda quieto en una esquina mientras el resto de la página se desplaza. No pertenece a una sección concreta: flota por encima del contenido, así que está presente lo mismo en el hero que al final de un artículo largo.',
      'Su forma dice lo que hace sin leerse: el logo de WhatsApp es reconocible al instante y el verde lo confirma. Piensa en él como el timbre junto a la puerta: no es la fachada ni el escaparate, pero cuando alguien decide tocar, está justo donde la mano lo busca.',
    ]}
  />

  {/* 2) ¿PARA QUÉ SIRVE? */}
  <ModSection
    surface
    eyebrow="Función e importancia"
    title="¿Para qué sirve?"
    desc="Quita la fricción del «¿cómo los contacto?»: pone el canal favorito de la gente a un toque, en cualquier página y en cualquier momento."
    body={[
      'Su función es ser la vía de escape rápida hacia una conversación. Mientras el contenido informa y convence, el botón resuelve la pregunta práctica que aparece en cuanto hay interés: «quiero preguntar algo, ¿por dónde?». Tener esa respuesta siempre a la vista atrapa la intención justo en el instante en que surge.',
      'Y ahí está su importancia: muchas consultas se pierden por un segundo de duda —el visitante no vio claro cómo escribir y se fue—. El botón flotante elimina ese punto de fuga llevando el contacto al canal donde la gente ya se siente cómoda. Es de los elementos más pequeños del sitio y de los que más trabajan por la conversión.',
    ]}
  >
    <ModBenefits items={beneficios} />
  </ModSection>

  {/* 3) ¿QUÉ LLEVA? — anatomía con ejemplo en vivo */}
  <ModSection
    eyebrow="Anatomía"
    title="¿Qué lleva el botón?"
    desc="Poco y bien elegido: un ícono que se reconoce, una etiqueta que invita, un enlace con mensaje y un anclaje que lo mantiene siempre a mano."
    body={[
      'Cada pieza se gana su lugar. El ícono comunica el canal sin palabras; la etiqueta empuja el primer toque; el enlace abre WhatsApp con el mensaje ya escrito; y el anclaje fijo es lo que lo vuelve «flotante», por encima del contenido y respetando el borde del teléfono.',
      'Abajo lo ves montado como aparece en una esquina de la página. Cada punto numerado se desglosa en su tarjeta —qué resuelve y de qué pieza de la plantilla sale—, para que distingas de un vistazo qué es diseño y qué es dato.',
    ]}
  >
    <ModAnatomy partes={partes}>
      <div class="wax" role="img" aria-label="Ejemplo del botón flotante de WhatsApp en la esquina inferior de una página">
        <div class="wax__page" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></div>
        <span class="wax__fab">
          <span class="wax__n wax__n--ic">1</span>
          <span class="wax__ic" set:html={waIcon}></span>
          <span class="wax__label"><span class="wax__n">2</span>¿Necesitas ayuda?</span>
        </span>
        <span class="wax__tag wax__tag--link" aria-hidden="true"><span class="wax__n">3</span>wa.me + mensaje</span>
        <span class="wax__tag wax__tag--anchor" aria-hidden="true"><span class="wax__n">4</span>fijo · esquina</span>
      </div>
    </ModAnatomy>
  </ModSection>

  {/* 3b) VARIANTES */}
  <ModSection
    surface
    eyebrow="Variantes"
    title="Otros diseños y aplicaciones"
    desc="El de esta plantilla es una pastilla con etiqueta, pero el botón flotante adopta muchas formas según el negocio y el canal."
    body={[
      'No hay un único botón flotante: hay una acción anclada a una esquina que cada sitio adapta a su objetivo. Un negocio local quiere que le escriban por WhatsApp; una tienda lanza una campaña; una marca cuidada prefiere lo mínimo. Mismo lugar, intención distinta.',
      'Abajo, seis variantes reales —cada una con una réplica en vivo y el tipo de proyecto donde brilla—. Sirven para reconocer cuál te conviene y para ver cómo el mismo patrón se reescribe sin perder su sitio.',
    ]}
  >
    <GaleriaDisenos ariaLabel="Variantes del botón flotante de contacto">
      {/* 0 · Pastilla con etiqueta */}
      <DisenoCard {...disenos[0]}>
        <div class="wav" role="img" aria-label="Pastilla verde con ícono de WhatsApp y la etiqueta «¿Necesitas ayuda?»">
          <div class="wav__page" aria-hidden="true"><span></span><span></span><span></span></div>
          <span class="wav__pill">
            <span class="wav__ic" set:html={waIcon}></span>
            <span class="wav__txt">¿Necesitas ayuda?</span>
          </span>
        </div>
      </DisenoCard>

      {/* 1 · Botón circular */}
      <DisenoCard {...disenos[1]}>
        <div class="wav" role="img" aria-label="Botón circular verde con solo el ícono de WhatsApp">
          <div class="wav__page" aria-hidden="true"><span></span><span></span><span></span></div>
          <span class="wav__circle"><span class="wav__ic" set:html={waIcon}></span></span>
        </div>
      </DisenoCard>

      {/* 2 · Con globo de aviso */}
      <DisenoCard {...disenos[2]}>
        <div class="wav" role="img" aria-label="Botón circular con un globo de notificación y un mensaje que asoma">
          <div class="wav__page" aria-hidden="true"><span></span><span></span><span></span></div>
          <span class="wav__hint">¿Te ayudo? 👋</span>
          <span class="wav__circle"><span class="wav__ic" set:html={waIcon}></span><span class="wav__badge">1</span></span>
        </div>
      </DisenoCard>

      {/* 3 · Multi-canal (speed dial) */}
      <DisenoCard {...disenos[3]}>
        <div class="wav" role="img" aria-label="Botón que despliega WhatsApp, teléfono y correo (speed dial)">
          <div class="wav__page" aria-hidden="true"><span></span><span></span><span></span></div>
          <span class="wav__dial" aria-hidden="true">
            <i class="wav__mini wav__mini--wa"><span class="wav__ic" set:html={waIcon}></span></i>
            <i class="wav__mini">☎</i>
            <i class="wav__mini">✉</i>
          </span>
          <span class="wav__circle wav__circle--plus">＋</span>
        </div>
      </DisenoCard>

      {/* 4 · Burbuja con mensaje */}
      <DisenoCard {...disenos[4]}>
        <div class="wav" role="img" aria-label="Burbuja de chat con una línea de bienvenida y el botón de WhatsApp">
          <div class="wav__page" aria-hidden="true"><span></span><span></span><span></span></div>
          <span class="wav__bubble">
            <b>¡Hola! 👋</b>
            <i>¿Te ayudamos a cotizar?</i>
            <span class="wav__cta"><span class="wav__ic" set:html={waIcon}></span>Escríbenos</span>
          </span>
        </div>
      </DisenoCard>

      {/* 5 · Barra inferior (móvil) */}
      <DisenoCard {...disenos[5]}>
        <div class="wav" role="img" aria-label="Barra inferior fija con las acciones Llamar y WhatsApp">
          <div class="wav__page" aria-hidden="true"><span></span><span></span><span></span></div>
          <span class="wav__bar">
            <i class="wav__baritem">☎ Llamar</i>
            <i class="wav__baritem wav__baritem--wa"><span class="wav__ic" set:html={waIcon}></span>WhatsApp</i>
          </span>
        </div>
      </DisenoCard>
    </GaleriaDisenos>
  </ModSection>

  {/* 3c) RESPONSIVE Y MÓVIL */}
  <ModSection
    eyebrow="Responsive y móvil"
    title="Cómo se comporta en el teléfono"
    desc="En móvil el botón no es «el de escritorio encogido»: decide qué se ve, dónde se ancla y cómo no estorbar el pulgar ni el contenido."
    body={[
      'En el teléfono cada píxel cuenta, así que el botón se adelgaza: la etiqueta se va y queda el círculo, que se reconoce solo. Pero su razón de ser —ser tocable y estar a mano— se cuida más que nunca: crece al objetivo táctil de 44–52 px y se ancla en la zona cómoda para una sola mano.',
      'Y manda la convivencia: el botón vive sobre el contenido, así que no debe tapar el cierre ni un CTA, y tiene que respetar el borde del iPhone para no caer bajo la barra de gestos. Abajo, cuatro patrones, cada uno con su vista en el teléfono y una receta comentada lista para copiar.',
    ]}
  >
    <ModResponsive>
      <ModPattern
        title="1 · La etiqueta se colapsa"
        desc="En escritorio es una pastilla con texto que invita; al estrecharse la pantalla cae la etiqueta y queda solo el círculo verde, que ya comunica el canal sin ayuda. Menos ancho ocupado, mismo mensaje."
        receta={{ titulo: 'CSS · etiqueta colapsable', lang: 'css', code: recetaColapsable }}
      >
        <MarcoMovil ariaLabel="En móvil la pastilla con texto se colapsa a solo el círculo verde">
          <div class="wam-skel"><span></span><span></span><span></span><span></span></div>
          <span class="wam-fab"><span class="wam-fab__ic" set:html={waIcon}></span></span>
        </MarcoMovil>
      </ModPattern>

      <ModPattern
        title="2 · Respeta el borde del iPhone"
        desc="Con <code>viewport-fit=cover</code> el sitio usa toda la pantalla, así que el botón se separa del borde con <code>env(safe-area-inset-bottom)</code> para no quedar bajo la barra de gestos ni el notch. Siempre tocable, nunca a medias."
        receta={{ titulo: 'CSS · anclaje + safe-area', lang: 'css', code: recetaSafeArea }}
      >
        <MarcoMovil ariaLabel="El botón se separa de la barra de gestos respetando el área segura del iPhone">
          <div class="wam-skel"><span></span><span></span><span></span><span></span></div>
          <span class="wam-fab"><span class="wam-fab__ic" set:html={waIcon}></span></span>
          <span class="wam-safe" aria-hidden="true"></span>
        </MarcoMovil>
      </ModPattern>

      <ModPattern
        title="3 · No tapar el contenido ni el cierre"
        desc="El botón flota sobre la página, así que no debe sentarse encima de un CTA o del footer. Un patrón simple: cuando el cierre entra en pantalla, el botón sube unos píxeles para cederle el paso —sin librerías, con un observador nativo—."
        receta={{ titulo: 'HTML + JS · subir sobre el footer', lang: 'html', code: recetaClear }}
      >
        <MarcoMovil ariaLabel="Cuando el footer entra en pantalla, el botón sube para no taparlo">
          <div class="wam-skel"><span></span><span></span></div>
          <div class="wam-foot" aria-hidden="true"><span></span><span></span></div>
          <span class="wam-fab wam-fab--up"><span class="wam-fab__ic" set:html={waIcon}></span></span>
        </MarcoMovil>
      </ModPattern>

      <ModPattern
        title="4 · Cómodo de tocar con el pulgar"
        desc="En el teléfono el círculo crece a 52 px —por encima del mínimo de 44 px de Apple y WCAG— y al ser un enlace real es accesible por teclado y lectores de pantalla, con un foco visible claro al tabular."
        receta={{ titulo: 'CSS · objetivo táctil + foco', lang: 'css', code: recetaTap }}
      >
        <MarcoMovil ariaLabel="El círculo crece a 52 px para ser cómodo de tocar con el pulgar">
          <div class="wam-skel"><span></span><span></span><span></span><span></span></div>
          <span class="wam-fab wam-fab--big"><span class="wam-fab__ic" set:html={waIcon}></span><i class="wam-ruler">52px</i></span>
        </MarcoMovil>
      </ModPattern>
    </ModResponsive>
  </ModSection>

  {/* 4) ¿DÓNDE VA? */}
  <ModSection
    surface
    eyebrow="Posición"
    title="¿Dónde se coloca?"
    desc="Fijo en la esquina inferior derecha, por encima de todo y en todas las páginas. No pertenece a una sección: flota sobre el contenido."
    body={[
