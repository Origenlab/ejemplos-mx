  'No mezcles layouts en la misma página sin criterio: duo para contenido, simple solo para catálogos.',
]

// Variantes de encabezado de sección (galería). Réplica en vivo abajo, mismo
// orden. Las primeras son configuraciones REALES del componente (cambiar
// `layout`, `align`, `as`, `titleAccent`, `dark`); la última es una extensión
// propuesta que requeriría añadir un slot o prop al componente.
const disenos = [
  {
    nombre: 'Duo: título · body (esta plantilla)',
    tag: 'Contenido · Documentación',
    desc: 'El layout por defecto del sitio: eyebrow + título (H2) + descripción a la izquierda, y dos párrafos de body[] a la derecha. Equilibra promesa y contexto sin romper el ancho del container. Configuración real: layout="duo" · body=[…].',
  },
