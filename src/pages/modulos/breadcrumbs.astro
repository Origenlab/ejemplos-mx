            <span class="bcv__lnk">Inicio</span>
            <span class="bcv__sep" aria-hidden="true">›</span>
            <span class="bcv__lnk">Servicios</span>
            <span class="bcv__sep" aria-hidden="true">›</span>
            <span class="bcv__cur">Diseño</span>
          </div>
        </DisenoCard>

        {/* 1 · Con icono home */}
        <DisenoCard {...disenos[1]}>
          <div class="bcv bcv--home" role="img" aria-label="Migas con icono de casa en la raíz">
            <span class="bcv__home" aria-hidden="true">⌂</span>
            <span class="bcv__sep" aria-hidden="true">›</span>
            <span class="bcv__lnk">Productos</span>
            <span class="bcv__sep" aria-hidden="true">›</span>
            <span class="bcv__lnk">Calzado</span>
            <span class="bcv__sep" aria-hidden="true">›</span>
            <span class="bcv__cur">Botas</span>
          </div>
        </DisenoCard>

        {/* 2 · Cápsulas (pills) */}
        <DisenoCard {...disenos[2]}>
          <div class="bcv bcv--pills" role="img" aria-label="Migas en cápsulas con chevron entre ellas">
            <span class="bcv__pill">Panel</span>
            <span class="bcv__sep" aria-hidden="true">›</span>
            <span class="bcv__pill">Clientes</span>
            <span class="bcv__sep" aria-hidden="true">›</span>
            <span class="bcv__pill bcv__pill--cur">Detalle</span>
