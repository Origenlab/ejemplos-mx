                  <b class="scm__t"></b>
                  <span class="scm__d"></span>
                </div>
                <div class="scm__full">
                  <span class="scm__icon"></span>
                  <b class="scm__t"></b>
                </div>
                <span class="scm__sticky" aria-hidden="true">Cotizar por WhatsApp</span>
