<PageLayout
  title="Formulario de contacto: WCAG 2.2, anti-spam y WhatsApp"
  description="Módulo ContactForm: accesibilidad WCAG 2.2, honeypot canónico, Turnstile, consentimiento LFPDPPP. Envío directo a WhatsApp con waUrl()."
  pageType="page"
  guia={false}
  breadcrumbs={[{ label: 'Módulos', href: '/modulos' }, { label: 'Formulario de contacto' }]}
>
