---
// ============================================================================
// /modulos/section-menu — PÁGINA DEL MÓDULO «Menú de secciones».
// ----------------------------------------------------------------------------
// Quinta de la serie /modulos/* (topbar · header · breadcrumbs · hero · menu),
// MISMO molde (docs/MODULOS.md). NOTA propia del menú de secciones: a diferencia
// del hero (contenido per-página) o del topbar/header (chrome global), esta
// franja es un MÓDULO DE NAVEGACIÓN compartido. En la home se alimenta de NAV
// (la MISMA fuente que el Header) para que «agregar una sección al menú =
// agregar una sección a la franja»; en páginas internas se reutiliza como
// cierre/interlinking con OTROS datos. La regla canónica «el hero presenta,
// la franja convierte» vive aquí: el último botón siempre es el CTA (WhatsApp,
// armado con waUrl(WA_MESSAGES.cotizar) — regla D4, nunca wa.me a mano).
// ============================================================================
import PageLayout from '@layouts/PageLayout.astro'
import Hero from '@components/Hero.astro'
import SectionHeading from '@components/SectionHeading.astro'
import SectionMenu from '@components/SectionMenu.astro'
import GaleriaDisenos from '@components/GaleriaDisenos.astro'
import DisenoCard from '@components/DisenoCard.astro'
import MarcoMovil from '@components/MarcoMovil.astro'
import Receta from '@components/Receta.astro'
import { WA_MESSAGES, waUrl } from '@config/site'
import { siblingsModules } from '@lib/modules'

// Menú de cierre — derivado de MODULOS (SSoT) con el helper siblingsModules:
// índice de la serie + dos vecinos en estado 'listo' + la home. Los 'proximo'
// no enlazan (aún no tienen página → evitan 404s).
const cierreItems = siblingsModules('section-menu')
const cierreCta = { label: 'Cotizar por WhatsApp', href: waUrl(WA_MESSAGES.cotizar), sub: 'Respuesta inmediata', external: true }

// Las 4 piezas de la franja — mapean con los pines del ejemplo en vivo.
const partes = [
  {
    n: 1,
    nombre: 'Botón de sección',
    que: 'Un atajo a una de las secciones grandes del sitio (Productos, Servicios, Cobertura, Blog…). Llena su celda, se centra y muestra el destino con una sola etiqueta corta. En la home, esta lista de botones se genera desde NAV: el mismo array que alimenta el header.',
    dato: 'items[].label · href',
  },
  {
    n: 2,
    nombre: 'Sublabel',
    que: 'Una micro-descripción debajo de la etiqueta («Catálogo del sitio», «Lo que ofreces»). Aclara qué hay detrás del botón sin obligar a entrar; es opcional, pero hace mucho con dos o tres palabras.',
    dato: 'items[].sub',
  },
  {
    n: 3,
    nombre: 'Divisores',
    que: 'Las líneas que separan los botones. En móvil son horizontales (apilados); en escritorio (≥768 px), verticales (una sola fila). Se dibujan con border de las celdas, sin pintar el botón mismo: la barra queda continua.',
    dato: '.secmenu__cell · border',
  },
  {
    n: 4,
    nombre: 'CTA de conversión',
    que: 'El último botón, en color de marca. No es una sección más: es la acción —Cotizar por WhatsApp—. Su enlace no se teclea: lo arma waUrl() con el mensaje precargado de WA_MESSAGES, para que la conversación empiece con contexto.',
    dato: 'cta · waUrl(WA_MESSAGES.cotizar)',
  },
]

const beneficios = [
  {
    titulo: 'Atajo a la sección que busca',
    desc: 'En lugar de obligar a volver al menú del header, el visitante encuentra los destinos clave —catálogo, servicios, blog— justo donde el ojo ya bajó después del hero. Menos pasos, menos rebote, más páginas vistas por sesión.',
  },
  {
    titulo: 'Conversión a un clic',
    desc: 'El último botón es Cotizar por WhatsApp, destacado en color de marca. La regla canónica del sitio se aplica literalmente aquí: «el hero presenta, la franja convierte». Si el visitante decidió, no tiene que bajar a buscar dónde escribir.',
  },
  {
    titulo: 'Una sola fuente, cero desincronización',
    desc: 'En la home los botones nacen de NAV —el mismo array que alimenta el header—. Agregar una sección al menú la añade automáticamente a la franja; quitarla la borra. El menú y la franja siempre dicen lo mismo, sin mantenerse a mano.',
  },
]

const sis = [
  'Deriva los botones de la MISMA fuente que el header (NAV en site.ts); no escribas una segunda lista a mano.',
  'Mantén el CTA de conversión como ÚLTIMO botón y arma su enlace con waUrl() (regla D4).',
  'Limita la franja a 4–6 botones: si la lista crece, gana ruido y pierde atajo.',
  'Mantén la etiqueta corta y reconocible («Productos», no «Nuestro catálogo de productos»).',
