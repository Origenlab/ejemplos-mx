---
// ============================================================================
// /modulos/ — PÁGINA ÍNDICE de los módulos del sitio.
// ----------------------------------------------------------------------------
// Presenta el concepto de «módulo» y lista TODOS los módulos del sitio (roadmap),
// cada uno enlazando a su página de detalle (/modulos/<slug>). Data-driven desde
// MODULOS (site.ts, SSoT) — la misma fuente del dropdown «Módulos» del Header.
// Los 'listo' enlazan; los 'proximo' se muestran como roadmap (sin enlace).
// ============================================================================
import PageLayout from '@layouts/PageLayout.astro'
import Hero from '@components/Hero.astro'
import SectionHeading from '@components/SectionHeading.astro'
import CategoryCard from '@components/CategoryCard.astro'
import CategoryDetail from '@components/CategoryDetail.astro'
import SectionMenu from '@components/SectionMenu.astro'
import MarcoMovil from '@components/MarcoMovil.astro'
import Receta from '@components/Receta.astro'
import GuiaNota from '@components/GuiaNota.astro'
import { MODULOS, waUrl, WA_MESSAGES } from '@config/site'
import { MODULE_CARD_META as MOD_META } from '@lib/modules'

// Misma fuente y mismo filtro que la home (index.astro): solo los 'listo'. Así
// /modulos muestra EXACTAMENTE los mismos módulos en sus cards y en su a-fondo.
const modulosListos = MODULOS.filter((m) => m.estado === 'listo')
const listos = modulosListos.length

// ── Recetas de la sección «Responsive y móvil» — código real del sistema
//    (src/styles/mobile.css · tokens.css). Las pinta <Receta>. ──
const recetaGrid = `/* La vitrina es mobile-first: 1 → 2 → 4 por fila.
   Arranca en UNA columna y CRECE con min-width (nunca al revés). */
.showcase { display: grid; grid-template-columns: 1fr; gap: var(--sp-5); }
@media (min-width: 640px)  { .showcase { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .showcase { grid-template-columns: repeat(4, 1fr); } }`

const recetaImg = `/* tokens.css + mobile.css · imágenes fluidas, sin desbordar ni deformar. */
img, picture, video, canvas, svg { max-width: 100%; }  /* nunca más anchas que su caja */

@media (max-width: 768px) {
  img, video { height: auto; }   /* escala manteniendo la proporción */
}`

const recetaCard = `/* mobile.css · la card entera se toca cómodo en el teléfono. */
@media (max-width: 1024px) {
  a, button, [role="button"], label {
    -webkit-tap-highlight-color: rgba(91, 61, 245, .15);  /* feedback al tap */
  }
}
@media (max-width: 768px) {
  /* chips de subcategoría con altura tappable */
  .ccard__sub { min-height: 40px; display: inline-flex; align-items: center; }
}`

// La presentación de cada card de módulo (foto + chips) es SSoT COMPARTIDO en
// lib/modules.ts (MODULE_CARD_META, importado arriba como MOD_META) — reusado por
// la home (vitrina «el sistema»). IMG se queda aquí porque POOL (galerías «a
// fondo») también lo usa.
const IMG = '/images'

// Menú de cierre (reemplaza al antiguo CTABanner): siguiente paso útil + el sitio.
// Patrón canónico del home: «el menú reparte, el último botón (WhatsApp) convierte».
const cierreItems = [
  { label: 'Módulo Topbar', href: '/modulos/topbar', sub: 'El primero, a fondo' },
  { label: 'Inicio', href: '/', sub: 'Volver a la home' },
  { label: 'Productos', href: '/productos', sub: 'Catálogo del sitio' },
  { label: 'Servicios', href: '/servicios', sub: 'Lo que ofreces' },
]
const cierreCta = {
  label: 'Cotizar por WhatsApp',
  href: waUrl(WA_MESSAGES.cotizar),
  sub: 'Respuesta inmediata',
  external: true,
}

// «El módulo a fondo» — UN bloque CategoryDetail por módulo (info izq · galería der,
// SIN zig-zag), MISMO patrón que «categoría a fondo» del home. Data-driven: el copy
// vive en AFONDO (por slug); la galería reusa las fotos demo del POOL. El CTA solo
// aparece en los módulos 'listo' (los 'proximo' aún no tienen página → sin enlace).
const POOL = [
  `${IMG}/showcase/imagen-optimizada-avif-sitio-web.avif`,
  `${IMG}/showcase/jerarquia-titulos-seo-pagina-web.avif`,
  `${IMG}/showcase/texto-venta-contenido-markdown.avif`,
  `${IMG}/showcase/enlaces-internos-navegacion-web.avif`,
  `${IMG}/productos/desarrollo-web-astro-profesional.avif`,
  `${IMG}/productos/componentes-plantilla-astro-markdown.avif`,
  `${IMG}/productos/sitio-web-rapido-astro.avif`,
  `${IMG}/servicios/consultoria-desarrollo-web-astro.avif`,
  `${IMG}/servicios/implementacion-deploy-sitio-astro.avif`,
  `${IMG}/servicios/soporte-mantenimiento-web-astro.avif`,
  `${IMG}/articulos/guia-plantilla-astro-contenido-markdown.avif`,
  `${IMG}/articulos/novedades-sistema-produccion-web-astro.avif`,
  `${IMG}/casos/caso-exito-proyecto-web-astro.avif`,
  `${IMG}/zonas/cobertura-desarrollo-web-ciudad-de-mexico.avif`,
]
