---
// ============================================================================
// /modulos/ — PÁGINA ÍNDICE de los módulos del sitio.
// ----------------------------------------------------------------------------
// Presenta el concepto de «módulo» y lista TODOS los módulos del sitio (roadmap),
// cada uno enlazando a su página de detalle (/modulos/<slug>). Data-driven desde
// MODULOS (site.ts, SSoT) — la misma fuente del dropdown «Módulos» del Header.
// Los 'listo' enlazan; los 'proximo' se muestran como roadmap (sin enlace).
// ============================================================================
import PageLayout from '@layouts/PageLayout.astro'
import Hero from '@components/Hero.astro'
import SectionHeading from '@components/SectionHeading.astro'
import CategoryCard from '@components/CategoryCard.astro'
import CategoryDetail from '@components/CategoryDetail.astro'
import SectionMenu from '@components/SectionMenu.astro'
import MarcoMovil from '@components/MarcoMovil.astro'
import Receta from '@components/Receta.astro'
import GuiaNota from '@components/GuiaNota.astro'
import { MODULOS, waUrl, WA_MESSAGES } from '@config/site'

const listos = MODULOS.filter((m) => m.estado === 'listo').length

// ── Recetas de la sección «Responsive y móvil» — código real del sistema
//    (src/styles/mobile.css · tokens.css). Las pinta <Receta>. ──
const recetaGrid = `/* La vitrina es mobile-first: 1 → 2 → 4 por fila.
   Arranca en UNA columna y CRECE con min-width (nunca al revés). */
.showcase { display: grid; grid-template-columns: 1fr; gap: var(--sp-5); }
@media (min-width: 640px)  { .showcase { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .showcase { grid-template-columns: repeat(4, 1fr); } }`

const recetaImg = `/* tokens.css + mobile.css · imágenes fluidas, sin desbordar ni deformar. */
img, picture, video, canvas, svg { max-width: 100%; }  /* nunca más anchas que su caja */

@media (max-width: 768px) {
  img, video { height: auto; }   /* escala manteniendo la proporción */
}`

const recetaCard = `/* mobile.css · la card entera se toca cómodo en el teléfono. */
@media (max-width: 1024px) {
  a, button, [role="button"], label {
    -webkit-tap-highlight-color: rgba(91, 61, 245, .15);  /* feedback al tap */
  }
}
@media (max-width: 768px) {
  /* chips de subcategoría con altura tappable */
  .ccard__sub { min-height: 40px; display: inline-flex; align-items: center; }
}`

// Presentación de cada card (foto demo + chips) — homologa el card del catálogo.
// Las fotos son AVIF ya optimizadas que REUSAMOS (contenido DEMO, igual que los
// «beneficios» del home). En un sitio real cada módulo llevaría su propia imagen.
// chips = las piezas que componen cada módulo (valor didáctico, anticipan el detalle).
const IMG = '/images'
const MOD_META: Record<string, { image: string; chips: string[] }> = {
  'topbar':              { image: `${IMG}/showcase/imagen-optimizada-avif-sitio-web.avif`,        chips: ['Contacto', 'Horario', 'WhatsApp'] },
  'header':              { image: `${IMG}/productos/desarrollo-web-astro-profesional.avif`,        chips: ['Logotipo', 'Navegación', 'Menú móvil'] },
  'breadcrumbs':         { image: `${IMG}/showcase/enlaces-internos-navegacion-web.avif`,          chips: ['Ruta', 'Jerarquía', 'Volver'] },
  'hero':                { image: `${IMG}/showcase/jerarquia-titulos-seo-pagina-web.avif`,         chips: ['H1 único', 'Subtítulo', 'Llamada'] },
  'section-menu':        { image: `${IMG}/servicios/implementacion-deploy-sitio-astro.avif`,       chips: ['Botones', 'Saltos', 'CTA'] },
  'section-heading':     { image: `${IMG}/showcase/texto-venta-contenido-markdown.avif`,           chips: ['Eyebrow', 'Título', 'Descripción'] },
  'cards-categoria':     { image: `${IMG}/productos/componentes-plantilla-astro-markdown.avif`,    chips: ['Foto', 'Título', 'Chips'] },
  'categoria-a-fondo':   { image: `${IMG}/productos/sitio-web-rapido-astro.avif`,                  chips: ['Dos columnas', 'Galería', 'CTA'] },
  'cards-catalogo':      { image: `${IMG}/servicios/consultoria-desarrollo-web-astro.avif`,        chips: ['Producto', 'Servicio', 'Markdown'] },
  'resenas':             { image: `${IMG}/casos/caso-exito-proyecto-web-astro.avif`,               chips: ['Estrellas', 'Cita', 'Cliente'] },
  'faq':                 { image: `${IMG}/articulos/guia-plantilla-astro-contenido-markdown.avif`, chips: ['Pregunta', 'Respuesta', 'Schema'] },
  'cta-banner':          { image: `${IMG}/servicios/soporte-mantenimiento-web-astro.avif`,         chips: ['Gancho', 'Botón', 'Cierre'] },
  'formulario-contacto': { image: `${IMG}/articulos/novedades-sistema-produccion-web-astro.avif`,  chips: ['Campos', 'Validación', 'WhatsApp'] },
  'footer':              { image: `${IMG}/zonas/cobertura-desarrollo-web-ciudad-de-mexico.avif`,   chips: ['Marca', 'Enlaces', 'Legales'] },
  'whatsapp-flotante':   { image: `${IMG}/showcase/imagen-optimizada-avif-sitio-web.avif`,         chips: ['Botón', 'Fijo', 'Mensaje'] },
}

