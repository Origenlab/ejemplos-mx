---
// ============================================================================
// /modulos/ — PÁGINA ÍNDICE de los módulos del sitio.
// ----------------------------------------------------------------------------
// Presenta el concepto de «módulo» y lista TODOS los módulos del sitio (roadmap),
// cada uno enlazando a su página de detalle (/modulos/<slug>). Data-driven desde
// MODULOS (site.ts, SSoT) — la misma fuente del dropdown «Módulos» del Header.
// Los 'listo' enlazan; los 'proximo' se muestran como roadmap (sin enlace).
// ============================================================================
import PageLayout from '@layouts/PageLayout.astro'
import Hero from '@components/Hero.astro'
import SectionHeading from '@components/SectionHeading.astro'
import CTABanner from '@components/CTABanner.astro'
import { MODULOS, waUrl, WA_MESSAGES } from '@config/site'

const n2 = (i: number) => String(i + 1).padStart(2, '0')
const listos = MODULOS.filter((m) => m.estado === 'listo').length
---

<PageLayout
  title="Módulos del sitio — las piezas que lo arman"
  description="Qué es un módulo y el índice de todos los módulos del sitio (topbar, header, hero, menú, footer). Cada uno con su página de detalle: qué es, para qué sirve y cómo se arma."
  pageType="page"
  breadcrumbs={[{ label: 'Módulos' }]}
>
  <Hero
    badge="Guía del sitio · Módulos"
    title="Los módulos:"
    accent="las piezas del sitio"
    subtitle="Un sitio profesional no es una página suelta: es un puñado de piezas reutilizables —topbar, header, hero, menú, footer— que se repiten y se combinan. Aquí están todas, cada una con su página de detalle."
    descRight={[
      'Cada módulo se documenta por separado: qué es, para qué sirve, qué lleva, dónde va y cómo se arma en esta plantilla.',
      'Empezamos por el Topbar; el resto se publica con el mismo molde. Esta página es el mapa de la serie.',
    ]}
    ctas={[
      { text: 'Ver el módulo Topbar', href: '/modulos/topbar', variant: 'primary' },
      { text: 'Volver al inicio', href: '/', variant: 'outline' },
    ]}
  />

  {/* ── 1) ¿QUÉ ES UN MÓDULO? ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Concepto"
        title="¿Qué es un módulo?"
        desc="Una pieza con una función clara que se construye una vez y se reutiliza: el ladrillo con el que se arma el sitio."
        body={[
          'Un módulo es una parte del sitio con un trabajo concreto —el topbar acerca el contacto, el header guía, el hero presenta, el footer cierra—. Cada uno se diseña y se programa una sola vez, y luego se reutiliza en todas las páginas. Pensar el sitio en módulos, y no como pantallas sueltas, es lo que lo mantiene coherente y fácil de mantener.',
          'La ventaja es doble. Para quien lo usa, todo se ve y se comporta igual en cada rincón del sitio. Para quien lo edita, un cambio en un módulo se refleja en todas partes a la vez —sin perseguir copias dispersas—. En esta plantilla cada módulo tiene su página: qué es, para qué sirve, qué lleva, dónde va y cómo está construido.',
        ]}
      />
    </div>
  </section>

  {/* ── 2) EL ÍNDICE — todos los módulos (roadmap) ── */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        eyebrow="El índice"
        title="Todos los módulos del"
        titleAccent="sitio"
        desc={`Estos son los módulos de la serie. ${listos === 1 ? 'El primero ya está documentado' : `${listos} ya documentados`}; el resto se irá publicando con el mismo molde. Entra a cualquiera para verlo a fondo.`}
      />
      <div class="mods">
        {MODULOS.map((m, i) => (
          m.estado === 'listo' ? (
            <a class="mod mod--listo" href={m.href}>
              <span class="mod__n">{n2(i)}</span>
              <span class="mod__body">
                <span class="mod__head">
                  <span class="mod__title">{m.label}</span>
                  <span class="mod__badge">Listo</span>
                </span>
                <span class="mod__desc">{m.desc}</span>
                <span class="mod__cta">Ver módulo →</span>
              </span>
            </a>
          ) : (
            <div class="mod mod--proximo" aria-disabled="true">
              <span class="mod__n">{n2(i)}</span>
              <span class="mod__body">
                <span class="mod__head">
                  <span class="mod__title">{m.label}</span>
                  <span class="mod__badge mod__badge--soon">Próximamente</span>
                </span>
                <span class="mod__desc">{m.desc}</span>
              </span>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="¿Listo para documentar el siguiente módulo?"
    desc="El Topbar marca el molde: qué es, para qué sirve, qué lleva, dónde va y cómo se arma. Header, Hero, menú y footer siguen el mismo patrón."
    btns={[
      { label: 'Ver el módulo Topbar', href: '/modulos/topbar', icon: 'arrow', primary: true },
      { label: 'Escríbenos por WhatsApp', href: waUrl(WA_MESSAGES.cotizar), icon: 'wa', external: true },
    ]}
    badge="Serie · Módulos del sitio"
    variant="dark"
    centered={true}
  />
</PageLayout>

<style>
  /* Estructura (tokens.css = fuente única; scoped por página). */
  .container { max-width: var(--container-max); margin-inline: auto; padding-inline: var(--container-px); }
  .section { padding: var(--sp-8) 0; }
  .section--surface { background: var(--c-surface); }
  @media (min-width: 768px) { .section { padding: var(--sp-10) 0; } }

  /* ── Grid de módulos ── */
  .mods { display: grid; grid-template-columns: 1fr; gap: var(--sp-4); margin-top: var(--sp-6); }
  @media (min-width: 600px)  { .mods { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) { .mods { grid-template-columns: repeat(3, 1fr); } }

  .mod {
    display: flex; gap: var(--sp-3); align-items: start;
    background: var(--c-white); border: 1px solid var(--c-border);
    border-radius: var(--radius-md); padding: var(--sp-4) var(--sp-5);
    text-decoration: none;
  }
  .mod--listo { transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition); }
  .mod--listo:hover { border-color: var(--c-primary); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .mod--listo:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }
  .mod--proximo { opacity: .72; }

  .mod__n {
    flex-shrink: 0; font-family: var(--font-heading); font-weight: var(--weight-black);
    font-size: var(--text-xl); line-height: 1; color: var(--c-primary);
  }
  .mod--proximo .mod__n { color: var(--c-muted); }
  .mod__body { display: grid; gap: 4px; min-width: 0; }
  .mod__head { display: flex; align-items: center; gap: var(--sp-2); flex-wrap: wrap; }
  .mod__title { font-family: var(--font-heading); font-weight: var(--weight-semibold); font-size: var(--text-lg); color: var(--c-ink); }
  .mod__badge {
    font-size: .625rem; font-weight: var(--weight-bold); letter-spacing: .04em; text-transform: uppercase;
    color: var(--c-primary); background: rgba(var(--c-primary-rgb), .1);
    border: 1px solid rgba(var(--c-primary-rgb), .22); padding: .1rem .45rem; border-radius: var(--radius-full);
  }
  .mod__badge--soon { color: var(--c-muted); background: var(--c-surface); border-color: var(--c-border); }
  .mod__desc { font-size: var(--text-sm); line-height: var(--leading-normal); color: var(--c-ink-2); }
  .mod__cta { margin-top: 2px; font-size: var(--text-xs); font-weight: var(--weight-bold); letter-spacing: .04em; text-transform: uppercase; color: var(--c-primary); }
</style>
