              <div class="fm__brand"><b class="fm__logo">E</b><span class="fm__nap"></span></div>
              <div class="fm__bot"><span></span><span class="fm__top">↑</span></div>
            </div>
          </MarcoMovil>
        </ModPattern>

        {/* 4 · Hoja de impresión */}
        <ModPattern
          title="4 · Hoja de impresión (@media print)"
          desc="Una página impresa (recibo, propuesta, ficha) NO necesita la fila de redes ni el botón «volver arriba» —no se tocan en papel—. La hoja de impresión reduce el footer al bloque NAP + legales en blanco y negro: cumple con la información esencial sin gastar tinta en gradientes ni iconos sociales. Patrón a11y barato."
          receta={{ titulo: 'CSS · @media print del footer', lang: 'css', code: recetaPrintMov }}
        >
          <MarcoMovil ariaLabel="Vista de impresión: solo NAP y legales en blanco y negro, sin redes ni scroll-top">
            <div class="fm fm--print">
              <div class="fm__paper"><b>NEGOCIO S.A.</b><span>Av. Demo 123, Col. Centro</span><span>CDMX 06000 · Tel. 55 0000 0000</span><span>hola@negocio.mx</span></div>
              <div class="fm__paper fm__paper--legal"><span>© 2026 Negocio S.A. · Privacidad · Términos</span></div>
            </div>
          </MarcoMovil>
        </ModPattern>
      </ModResponsive>

      <GuiaNota titulo="El footer es CSS puro: cero librerías, cero JS adicional" archivo="src/components/Footer.astro">
        <p>
          Todo el responsive del footer vive en <code>&lt;style&gt;</code> scoped del componente
          —ningún breakpoint depende de <code>mobile.css</code> (la hoja central) ni de un
          framework—. Es por diseño: el footer es lo bastante autocontenido como para
          mover su responsive consigo mismo, y así una refactorización de la hoja central
