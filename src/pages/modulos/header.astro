---
// ============================================================================
// /modulos/header — PÁGINA DEL MÓDULO «Header».
// ----------------------------------------------------------------------------
// Segunda de la serie /modulos/* (después de topbar), MISMO molde (docs/MODULOS.md):
// qué es, para qué sirve, qué lleva (anatomía + ejemplo en vivo), variantes,
// responsive/móvil, dónde va, cómo está construido y buenas prácticas. Todo dato
// real sale de site.ts (SSoT: SITE.brand, NAV); el CTA, de waUrl(WA_MESSAGES).
// ============================================================================
import PageLayout from '@layouts/PageLayout.astro'
import Hero from '@components/Hero.astro'
import SectionHeading from '@components/SectionHeading.astro'
import SectionMenu from '@components/SectionMenu.astro'
import GaleriaDisenos from '@components/GaleriaDisenos.astro'
import DisenoCard from '@components/DisenoCard.astro'
import MarcoMovil from '@components/MarcoMovil.astro'
import Receta from '@components/Receta.astro'
import { SITE, NAV, WA_MESSAGES, waUrl } from '@config/site'

// Menú de cierre (mismo patrón que topbar): navegación de la serie + el sitio.
const cierreItems = [
  { label: 'Todos los módulos', href: '/modulos', sub: 'Índice de la serie' },
  { label: 'Módulo Topbar', href: '/modulos/topbar', sub: 'La barra de arriba' },
  { label: 'Inicio', href: '/', sub: 'Volver a la home' },
  { label: 'Productos', href: '/productos', sub: 'Catálogo del sitio' },
]
const cierreCta = { label: 'Cotizar por WhatsApp', href: waUrl(WA_MESSAGES.cotizar), sub: 'Respuesta inmediata', external: true }

// Las 4 piezas del header (misma fuente que la leyenda guía del componente Header).
const partes = [
  {
    n: 1,
    nombre: 'Logotipo',
    que: 'La marca, a la izquierda, enlazando a la home. Es el ancla de identidad y el «volver al inicio» que todos esperan por instinto. Aquí SÍ va el logo (en el topbar, no).',
    dato: 'SITE.brand · SITE.name',
  },
  {
    n: 2,
    nombre: 'Navegación',
    que: 'Las secciones del sitio. No se hardcodea ningún enlace: se itera NAV, la misma fuente para escritorio y móvil. En móvil colapsa en el menú ☰.',
    dato: 'NAV',
  },
  {
    n: 3,
    nombre: 'Paneles (mega / dropdown)',
    que: 'Las secciones con hijos despliegan un panel al pasar el cursor o con el teclado; su contenido sale de la taxonomía, no de una lista aparte.',
    dato: 'NAV[].panel · items',
  },
  {
    n: 4,
    nombre: 'CTA · Cotizar',
    que: 'El botón de conversión a WhatsApp, siempre visible a la derecha. El enlace se arma con waUrl(); el mensaje precargado sale de WA_MESSAGES.',
    dato: 'waUrl(WA_MESSAGES.cotizacion)',
  },
]

const beneficios = [
  {
    titulo: 'Orientación constante',
    desc: 'El visitante siempre sabe dónde está y a dónde puede ir. La navegación, idéntica en cada página, es el mapa que evita que alguien se pierda o se vaya por no encontrar el camino.',
  },
  {
    titulo: 'Identidad a la vista',
    desc: 'El logotipo, siempre arriba a la izquierda, ancla la marca y ofrece el «volver al inicio» que casi todos buscan por instinto al primer clic.',
  },
  {
    titulo: 'Conversión siempre cerca',
    desc: 'Un único botón de acción (Cotizar) viaja en cada página: la puerta de conversión nunca queda a más de un clic, sin competir con otros botones.',
  },
]

const sis = [
  'Deriva TODO el menú de una sola fuente (NAV en site.ts); no hardcodees ningún <li>.',
  'Logo a la izquierda, enlazando a la home: es el «volver al inicio» que el visitante espera.',
  'Un solo CTA de conversión visible (Cotizar); que no compita con otros botones.',
  'En móvil colapsa en ☰ con un panel accesible (foco por teclado, aria-expanded), del MISMO NAV.',
  'Mantén ~7 ítems de primer nivel; agrupa el resto en paneles mega/dropdown.',
]
const nos = [
  'No metas el logotipo en el topbar: la marca vive aquí, en el header.',
  'No dupliques el menú a mano para móvil: misma fuente NAV, un solo array.',
  'No abras los paneles solo por hover: deja también clic y teclado (accesibilidad).',
  'No amontones dos o tres CTAs compitiendo; el header lleva uno.',
  'No dejes datos DEMO (marca, enlaces) en producción.',
]

// Variantes de header (galería). Réplica en vivo abajo, mismo orden. Patrones
// reales de la industria (NN/g, Material Design, guías de e-commerce y SaaS).
const disenos = [
  {
    nombre: 'Clásico: logo · nav · CTA',
    tag: 'Negocio local · Servicios',
    desc: 'El de esta plantilla: logotipo a la izquierda, navegación a la derecha y un botón de conversión. Claro, predecible y probado; el que mejor funciona para la mayoría de sitios de negocio y servicios.',
  },
  {
    nombre: 'Logo centrado, nav partida',
    tag: 'Marca · Moda · Restaurante',
    desc: 'El logotipo manda al centro y la navegación se reparte a sus lados. Da protagonismo a la identidad; luce en sitios donde la marca pesa más que el tamaño del catálogo.',
  },
  {
    nombre: 'Mega-menú por categorías',
    tag: 'E-commerce · Catálogo grande',
    desc: 'Una entrada abre un panel ancho con columnas de subcategorías. Cuando hay mucho que ordenar, el mega-menú deja todo a la vista en un gesto, sin perder al visitante en niveles.',
  },
  {
    nombre: 'Buscador, cuenta y carrito',
    tag: 'E-commerce',
    desc: 'Suma a la marca y al menú un buscador prominente y los accesos de tienda —cuenta y carrito— a la derecha. Es el header de quien vende en línea: encontrar y comprar, a un clic.',
  },
  {
    nombre: 'Header de aplicación',
    tag: 'SaaS · Paneles',
    desc: 'Logo compacto, buscador global y acciones de usuario —notificaciones, perfil—. No es marketing: es la barra de una herramienta web, centrada en hacer, no en presentar.',
  },
  {
    nombre: 'Transparente sobre el hero',
    tag: 'Landing · Marca visual',
    desc: 'El header flota encima de una imagen o gradiente, sin fondo propio, y se vuelve sólido al hacer scroll. Inmersivo para landings con foto potente; exige cuidar el contraste.',
  },
]

// ── Recetas de implementación (móvil) — strings que pinta <Receta> ───────────
const recetaHamburguesa = `/* HEADER MÓVIL · hamburguesa + panel (drawer)
   El estándar: en móvil la nav colapsa en un botón ☰ que
   abre un panel a pantalla completa. MISMO NAV que escritorio. */

@media (max-width: 1024px) {
  .hdr-nav  { display: none; }          /* se oculta la barra de enlaces */
  .hdr-burger { display: inline-flex; } /* aparece el botón ☰ */
}

/* JS: abrir/cerrar el panel y bloquear el scroll del fondo */
const btn = document.querySelector('.hdr-burger');
const nav = document.getElementById('mobile-nav');
btn.addEventListener('click', () => {
  const open = nav.getAttribute('aria-hidden') === 'false';
  nav.setAttribute('aria-hidden', open ? 'true' : 'false');
  btn.setAttribute('aria-expanded', open ? 'false' : 'true');
  document.body.style.overflow = open ? '' : 'hidden';
});`

const recetaAcordeon = `/* PANEL MÓVIL · secciones en acordeón
   Los mega/dropdown del escritorio se vuelven acordeón:
   un toque expande sus hijos; solo una sección abierta a la vez. */

document.querySelectorAll('.mob-item__trigger').forEach((btn) => {
  btn.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    // cerrar las demás (una abierta a la vez)
    document.querySelectorAll('.mob-item__trigger')
      .forEach((o) => o.setAttribute('aria-expanded', 'false'));
    btn.setAttribute('aria-expanded', open ? 'false' : 'true');
  });
});`

const recetaBottomNav = `/* NAVEGACIÓN INFERIOR (bottom nav) · estilo app
   3–5 destinos en la «zona del pulgar». Objetivos ≥ 44px
   y respeta el área segura del iPhone. */

@media (max-width: 640px) {
  .bottom-nav {
    position: fixed; inset: auto 0 0 0; z-index: 50;
    display: grid; grid-auto-flow: column; grid-auto-columns: 1fr;
    background: #fff; border-top: 1px solid #e8e8e8;
    padding-bottom: env(safe-area-inset-bottom);
  }
  .bottom-nav a {
    min-height: 44px; display: grid; place-items: center;
    gap: 2px; font-size: 11px; color: #374151; text-decoration: none;
  }
}`

const recetaCondensado = `/* HEADER QUE SE CONDENSA AL HACER SCROLL
   Al bajar, el header encoge (menos alto + sombra) para
   ceder pantalla; al volver arriba, recupera su tamaño. */

.site-header { transition: height .2s ease, box-shadow .2s ease; }
.site-header.is-shrink { height: 56px; box-shadow: 0 2px 10px rgba(0,0,0,.08); }

addEventListener('scroll', () => {
  document.querySelector('.site-header')
    .classList.toggle('is-shrink', scrollY > 40);
}, { passive: true });`
---

<PageLayout
  title="El Header — logotipo y navegación principal"
  description="Qué es un header, para qué sirve, qué lleva (logo, navegación, paneles, CTA) y dónde va — más cómo está construido en esta plantilla: menú data-driven desde NAV en site.ts, accesible y responsive."
  pageType="page"
  guia={false}
  breadcrumbs={[{ label: 'Módulos', href: '/modulos' }, { label: 'Header' }]}
>
  <Hero
    badge="Módulo del sitio · Header"
    title="El Header:"
    accent="logotipo y navegación"
    subtitle="La barra de marca y menú que va justo debajo del topbar. Es el mapa del sitio: dice quién eres, a dónde se puede ir y deja la conversión a un clic, en cada página."
    descRight={[
      'No es una ficha técnica más: es el módulo entero, abierto y explicado. Qué problema resuelve y por qué se gana su lugar, de qué piezas se compone, dónde encaja en el layout y cómo está construido —el recorrido completo, del criterio de diseño a la implementación.',
      'Y todo se apoya en un mismo principio: una única fuente de verdad. El menú no se escribe a mano en el componente: se genera iterando NAV en site.ts, la misma fuente para escritorio y móvil. Cambias una entrada y se actualiza, idéntica, en toda la navegación.',
    ]}
  />

  {/* ── 1) ¿QUÉ ES? ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Definición"
        title="¿Qué es un header?"
        desc="La barra de cabecera: logotipo + navegación principal, fija en la parte alta y repetida idéntica en todas las páginas."
        body={[
          'El header (o cabecera) es la barra que corona cada página, justo debajo del topbar. Reúne dos cosas que el visitante busca por reflejo: la marca —arriba a la izquierda, como botón de «volver al inicio»— y el menú con las secciones del sitio. Es, literalmente, el mapa: de un vistazo se entiende qué hay y cómo llegar.',
          'A diferencia del topbar, que es accesorio, el header es estructural: sin él, un sitio se siente perdido. Por eso se repite igual en cada página y cambia lo menos posible —la constancia es justo lo que lo hace útil—. Piensa en la señalización de un edificio: aburrida a propósito, porque su trabajo es que nunca te pierdas.',
        ]}
      />
    </div>
  </section>

  {/* ── 2) ¿PARA QUÉ SIRVE? — función e importancia ── */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Función e importancia"
        title="¿Para qué sirve?"
        desc="Hace tres trabajos a la vez: orientar, mostrar la marca y dejar la conversión siempre a mano."
        body={[
          'Su función es ser el sistema de orientación del sitio. Mientras el hero presenta y el contenido convence, el header responde en todo momento a tres preguntas que el visitante trae consigo: «¿de quién es esto?», «¿a dónde puedo ir?» y «¿cómo doy el paso?». Tenerlas resueltas, en cada página, es lo que mantiene a la gente navegando en vez de abandonando.',
          'Y ahí está su importancia: el header es el elemento que más se mira y más se usa de todo el sitio. Una navegación confusa o un logo que no lleva a la home cuestan visitas de inmediato. Bien resuelto, en cambio, es invisible: la gente lo usa sin pensar, que es exactamente la señal de que funciona.',
        ]}
      />
      <div class="bene">
        {beneficios.map((b) => (
          <article class="bene__card">
            <h3 class="bene__title">{b.titulo}</h3>
            <p class="bene__desc">{b.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ── 3) ¿QUÉ LLEVA? — anatomía con ejemplo en vivo ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Anatomía"
        title="¿Qué va en el header?"
        desc="Cuatro piezas: la marca, la navegación, sus paneles desplegables y un botón de conversión."
        body={[
          'Cada pieza cumple un papel claro. El logotipo ancla la identidad y devuelve a la home; la navegación reparte hacia las secciones; los paneles ordenan lo que tiene hijos; y el CTA deja la conversión siempre a la vista. Ni una sobra, ni una compite con otra.',
          'Abajo lo ves montado con los datos reales de la plantilla. Cada punto numerado se desglosa en su tarjeta —qué resuelve y de qué dato de site.ts sale—, para que distingas de un vistazo qué es diseño y qué es contenido.',
        ]}
      />

      {/* Ejemplo estático del header (réplica con los datos reales de site.ts). */}
      <div class="hdx" role="img" aria-label="Ejemplo de header: logotipo, navegación, panel y CTA">
        <span class="hdx__logo">
          <span class="hdx__n">1</span>
          <span class="hdx__mark" aria-hidden="true">{SITE.brand.charAt(0)}</span>
          <span class="hdx__word">{SITE.brand}</span>
        </span>
        <span class="hdx__sp"></span>
        <nav class="hdx__nav" aria-hidden="true">
          <span class="hdx__lnk"><span class="hdx__n">2</span>{NAV[0]?.label}</span>
          <span class="hdx__lnk">{NAV[1]?.label} <span class="hdx__chev">▾</span><span class="hdx__n">3</span></span>
          <span class="hdx__lnk hdx__lnk--mute">{NAV[2]?.label}</span>
        </nav>
        <span class="hdx__cta"><span class="hdx__n">4</span>Cotizar</span>
      </div>

      <div class="partes">
        {partes.map((p) => (
          <article class="parte">
            <span class="parte__num">{p.n}</span>
            <div class="parte__body">
              <h3 class="parte__nombre">{p.nombre}</h3>
              <p class="parte__que">{p.que}</p>
              <p class="parte__dato"><span>Dato</span> <code>{p.dato}</code></p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ── 3b) VARIANTES — otros diseños y aplicaciones (galería en vivo) ── */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Variantes"
        title="Otros diseños y aplicaciones"
        desc="El de esta plantilla es un header clásico, pero la cabecera adopta muchas formas según el negocio."
        body={[
          'No hay un único header: hay una barra de cabecera que cada tipo de sitio adapta a su objetivo. Una tienda añade buscador y carrito; una marca centra el logo; una aplicación pone acciones de usuario. Mismo lugar, prioridades distintas.',
          'Abajo, seis variantes reales —cada una con su réplica en vivo y el tipo de proyecto donde brilla—. Sirven para reconocer cuál te conviene y para ver cómo el mismo molde se reescribe sin perder su sitio.',
        ]}
      />

      <GaleriaDisenos ariaLabel="Variantes de header">
        {/* 0 · Clásico: logo · nav · CTA (la de esta plantilla) */}
        <DisenoCard {...disenos[0]}>
          <div class="hdv hdv--clasico" role="img" aria-label="Header clásico: logo a la izquierda, navegación y botón">
            <span class="hdv__logo"><span class="hdv__mark">O</span>Marca</span>
            <span class="hdv__sp"></span>
            <span class="hdv__nav"><span>Inicio</span><span>Productos</span><span>Servicios</span></span>
            <span class="hdv__cta">Cotizar</span>
          </div>
        </DisenoCard>

        {/* 1 · Logo centrado, navegación partida */}
        <DisenoCard {...disenos[1]}>
          <div class="hdv hdv--centrado" role="img" aria-label="Header con logo centrado y navegación a los lados">
            <span class="hdv__nav"><span>Tienda</span><span>Historia</span></span>
            <span class="hdv__logo hdv__logo--c"><span class="hdv__mark">O</span>Marca</span>
            <span class="hdv__nav"><span>Blog</span><span>Contacto</span></span>
          </div>
        </DisenoCard>

        {/* 2 · Mega-menú por categorías */}
        <DisenoCard {...disenos[2]}>
          <div class="hdv hdv--mega" role="img" aria-label="Header con mega-menú de categorías abierto">
            <span class="hdv__logo"><span class="hdv__mark">O</span>Marca</span>
            <span class="hdv__nav"><span class="hdv__on">Categorías ▾</span><span>Ofertas</span></span>
            <span class="hdv__sp"></span>
            <span class="hdv__cta">Cuenta</span>
            <span class="hdv__panel" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
          </div>
        </DisenoCard>

        {/* 3 · Buscador, cuenta y carrito */}
        <DisenoCard {...disenos[3]}>
          <div class="hdv hdv--shop" role="img" aria-label="Header de e-commerce con buscador, cuenta y carrito">
            <span class="hdv__logo"><span class="hdv__mark">O</span>Tienda</span>
            <span class="hdv__search" aria-hidden="true">⌕ Buscar productos…</span>
            <span class="hdv__ic" aria-hidden="true">♡</span>
            <span class="hdv__ic" aria-hidden="true">🛒</span>
          </div>
        </DisenoCard>

        {/* 4 · Header de aplicación */}
        <DisenoCard {...disenos[4]}>
          <div class="hdv hdv--app" role="img" aria-label="Header de aplicación con buscador y acciones de usuario">
            <span class="hdv__ic" aria-hidden="true">≡</span>
            <span class="hdv__logo"><span class="hdv__mark">O</span>App</span>
            <span class="hdv__search hdv__search--sm" aria-hidden="true">⌕ Buscar…</span>
            <span class="hdv__ic" aria-hidden="true">◔</span>
            <span class="hdv__av" aria-hidden="true">A</span>
          </div>
        </DisenoCard>

        {/* 5 · Transparente sobre el hero */}
        <DisenoCard {...disenos[5]}>
          <div class="hdv hdv--overlay" role="img" aria-label="Header transparente sobre una imagen de fondo">
            <span class="hdv__logo hdv__logo--w"><span class="hdv__mark hdv__mark--w">O</span>Marca</span>
            <span class="hdv__sp"></span>
            <span class="hdv__nav hdv__nav--w"><span>Inicio</span><span>Tour</span><span>Precios</span></span>
            <span class="hdv__cta hdv__cta--ghost">Entrar</span>
          </div>
        </DisenoCard>
      </GaleriaDisenos>
    </div>
  </section>

  {/* ── 3c) RESPONSIVE Y MÓVIL — patrones + recetas comentadas ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Responsive y móvil"
        title="Cómo se comporta en el teléfono"
        desc="En móvil la navegación no cabe en una fila: se colapsa, se prioriza y se acerca al pulgar."
        body={[
          'La barra de menú de escritorio no entra en un teléfono, así que el header se replantea: la marca se queda, y la navegación se pliega tras un botón ☰ que abre un panel. Es el patrón que todo el mundo ya conoce, y por eso funciona —no hay que enseñar a usarlo—.',
          'A partir de ahí, manda la ergonomía: las secciones con hijos se vuelven acordeón, los destinos clave pueden bajar a una barra inferior en la «zona del pulgar», y el header puede condensarse al hacer scroll para ceder pantalla. Abajo, cuatro patrones, cada uno con su vista en el teléfono y una receta comentada.',
        ]}
      />

      <div class="pats">
        {/* 1 · Hamburguesa + panel (drawer) */}
        <article class="pat">
          <div class="pat__demo">
            <MarcoMovil ariaLabel="Header móvil: la navegación se abre en un panel desde el botón ☰">
              <div class="hdm hdm--header">
                <span class="hdm__mark" aria-hidden="true">O</span>
                <span class="hdm__brand">Marca</span>
                <span class="hdm__sp"></span>
                <span class="hdm__ic hdm__ic--on" aria-hidden="true">☰</span>
              </div>
              <div class="hdm-drawer" aria-hidden="true">
                <span>Inicio</span><span>Productos</span><span>Servicios</span><span>Blog</span><span>Contacto</span>
                <span class="hdm-drawer__cta">Cotizar por WhatsApp</span>
              </div>
            </MarcoMovil>
          </div>
          <div class="pat__info">
            <h3 class="pat__title">1 · Hamburguesa + panel</h3>
            <p class="pat__desc">El estándar: en móvil la barra de enlaces se oculta y aparece el botón ☰, que abre un panel a pantalla con las mismas secciones —generadas del mismo NAV—. Bloquea el scroll del fondo mientras está abierto.</p>
            <Receta titulo="CSS + JS · drawer con ☰" lang="css" code={recetaHamburguesa} />
          </div>
        </article>

        {/* 2 · Acordeón en el panel */}
        <article class="pat">
          <div class="pat__demo">
            <MarcoMovil ariaLabel="Panel móvil con una sección expandida en acordeón">
              <div class="hdm hdm--header">
                <span class="hdm__mark" aria-hidden="true">O</span>
                <span class="hdm__brand">Marca</span>
                <span class="hdm__sp"></span>
                <span class="hdm__ic" aria-hidden="true">✕</span>
              </div>
              <div class="hdm-drawer" aria-hidden="true">
                <span class="hdm-acc__on">Productos ▾</span>
                <span class="hdm-sub">Categoría A</span>
                <span class="hdm-sub">Categoría B</span>
                <span>Servicios ▸</span>
                <span>Contacto ▸</span>
              </div>
            </MarcoMovil>
          </div>
          <div class="pat__info">
            <h3 class="pat__title">2 · Secciones en acordeón</h3>
            <p class="pat__desc">Las entradas con hijos (los mega/dropdown del escritorio) se vuelven acordeón: un toque expande sus subsecciones; solo una abierta a la vez para no abrumar. Misma taxonomía, otra presentación.</p>
            <Receta titulo="JS · acordeón del panel" lang="js" code={recetaAcordeon} />
          </div>
        </article>

        {/* 3 · Barra inferior (bottom nav) */}
        <article class="pat">
          <div class="pat__demo">
            <MarcoMovil ariaLabel="Navegación inferior estilo app, en la zona del pulgar">
              <div class="hdm hdm--header">
                <span class="hdm__mark" aria-hidden="true">O</span>
                <span class="hdm__brand">App</span>
                <span class="hdm__sp"></span>
                <span class="hdm__av" aria-hidden="true">A</span>
              </div>
              <div class="skel"><span></span><span></span><span></span><span></span></div>
              <div class="hdm-bottom" aria-hidden="true">
