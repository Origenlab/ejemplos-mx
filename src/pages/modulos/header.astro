    <ModResponsive>
      <ModPattern
        title="1 · Hamburguesa + panel"
        desc="Por debajo de 1024 px, la fila de enlaces desaparece y aparece el botón ☰, que abre un panel a pantalla completa con las mismas secciones —generadas del mismo NAV—. Un detalle que se olvida y se nota: mientras el panel está abierto, hay que bloquear el scroll del fondo."
        receta={{ titulo: 'HTML + JS · drawer con ☰', lang: 'html', code: recetaHamburguesa }}
      >
        <MarcoMovil ariaLabel="Header móvil: la navegación se abre en un panel desde el botón ☰">
          <div class="hdm hdm--header">
            <span class="hdm__mark" aria-hidden="true">O</span>
            <span class="hdm__brand">Marca</span>
            <span class="hdm__sp"></span>
            <span class="hdm__ic hdm__ic--on" aria-hidden="true">☰</span>
          </div>
          <div class="hdm-drawer" aria-hidden="true">
            <span>Inicio</span><span>Productos</span><span>Servicios</span><span>Blog</span><span>Contacto</span>
            <span class="hdm-drawer__cta">Cotizar por WhatsApp</span>
          </div>
        </MarcoMovil>
      </ModPattern>

      <ModPattern
        title="2 · Secciones en acordeón"
        desc="Las entradas con hijos (los mega y dropdown del escritorio) se vuelven acordeón: un toque expande sus subsecciones, y solo una queda abierta a la vez para no abrumar. La transición de altura se resuelve con un truco de CSS moderno, sin medir píxeles."
        receta={{ titulo: 'CSS · acordeón con grid 0fr → 1fr', lang: 'css', code: recetaAcordeon }}
      >
        <MarcoMovil ariaLabel="Panel móvil con una sección expandida en acordeón">
          <div class="hdm hdm--header">
            <span class="hdm__mark" aria-hidden="true">O</span>
            <span class="hdm__brand">Marca</span>
            <span class="hdm__sp"></span>
            <span class="hdm__ic" aria-hidden="true">✕</span>
          </div>
          <div class="hdm-drawer" aria-hidden="true">
            <span class="hdm-acc__on">Productos ▾</span>
            <span class="hdm-sub">Categoría A</span>
            <span class="hdm-sub">Categoría B</span>
            <span>Servicios ▸</span>
            <span>Contacto ▸</span>
          </div>
        </MarcoMovil>
      </ModPattern>

      <ModPattern
        title="3 · Barra inferior (zona del pulgar)"
        desc="En apps y catálogos con pocos destinos clave, la navegación baja al borde inferior —lo más cómodo de alcanzar con una mano—, con entre tres y cinco íconos, objetivos de 44 px y respeto por el área segura del iPhone."
        receta={{ titulo: 'CSS · bottom-nav + safe-area', lang: 'css', code: recetaBottomNav }}
      >
        <MarcoMovil ariaLabel="Navegación inferior estilo app, en la zona del pulgar">
          <div class="hdm hdm--header">
            <span class="hdm__mark" aria-hidden="true">O</span>
            <span class="hdm__brand">App</span>
            <span class="hdm__sp"></span>
            <span class="hdm__av" aria-hidden="true">A</span>
          </div>
          <div class="skel"><span></span><span></span><span></span><span></span></div>
          <div class="hdm-bottom" aria-hidden="true">
            <span class="hdm-bottom__i hdm-bottom__i--on"><b>⌂</b>Inicio</span>
            <span class="hdm-bottom__i"><b>▦</b>Catálogo</span>
            <span class="hdm-bottom__i"><b>⌕</b>Buscar</span>
            <span class="hdm-bottom__i"><b>○</b>Cuenta</span>
          </div>
        </MarcoMovil>
      </ModPattern>

      <ModPattern
        title="4 · Se condensa al hacer scroll"
        desc="Al bajar, el header encoge —menos alto, una sombra sutil— para cederle pantalla al contenido; al volver arriba, recupera su tamaño. Da aire en lecturas largas sin esconder del todo la navegación."
        receta={{ titulo: 'CSS · header condensado (+ toggle JS)', lang: 'css', code: recetaCondensado }}
      >
        <MarcoMovil ariaLabel="Header que se condensa al hacer scroll">
          <div class="hdm hdm--header hdm--shrink">
            <span class="hdm__mark hdm__mark--sm" aria-hidden="true">O</span>
            <span class="hdm__brand">Marca</span>
            <span class="hdm__sp"></span>
            <span class="hdm__ic" aria-hidden="true">☰</span>
          </div>
          <div class="skel skel--shift"><span></span><span></span><span></span><span></span><span></span></div>
          <span class="hdm-updown" aria-hidden="true">↑ condensado al bajar</span>
