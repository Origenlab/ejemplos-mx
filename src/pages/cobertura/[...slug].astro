---
// ============================================================================
// /cobertura/<slug> — Detalle de zona (página de SEO local).
// ----------------------------------------------------------------------------
// Ruta dinámica generada desde COVERAGE_STATES (TAXONOMY en site.ts, SSoT) —
// "manda el menú": los slugs son los de COVERAGE_STATES (cdmx · edomex), los
// mismos que enlaza el dropdown del Header. Contenido de apoyo DEMO en el archivo.
// ============================================================================
import PageLayout from '@layouts/PageLayout.astro'
import Hero from '@components/Hero.astro'
import SectionHeading from '@components/SectionHeading.astro'
import GuiaNota from '@components/GuiaNota.astro'
import FAQAccordion from '@components/FAQAccordion.astro'
import SectionMenu from '@components/SectionMenu.astro'
import { getCollection, render } from 'astro:content'
import { COVERAGE_STATES, SERVICES, waUrl, WA_MESSAGES } from '@config/site'

export async function getStaticPaths() {
  // Datos RICOS de cada zona en la colección `zonas` (un .md por zona, nombrado
  // con el MISMO slug que en COVERAGE_STATES). NAV/rutas siguen saliendo de
  // COVERAGE_STATES (sync) → no rompe el menú; la colección solo enriquece.
  const entries = await getCollection('zonas', ({ data }) => !data.draft)
  return COVERAGE_STATES.map((z) => ({
    params: { slug: z.slug },
    props: { zona: z, entry: entries.find((e) => e.id === z.slug) ?? null },
  }))
}

const { zona, entry } = Astro.props
const { slug, label, type } = zona
const tipo = type === 'operativo' ? 'operativa' : 'comercial'

// Riqueza de la zona desde la colección (colonias, tiempos, cuerpo Markdown).
const colonias = entry?.data.colonias ?? []
const deliveryTime = entry?.data.delivery?.time
const deliveryNote = entry?.data.delivery?.note
const ZoneContent = entry ? (await render(entry)).Content : null

const faqs = [
  { question: `¿Atienden a domicilio en ${label}?`, answer: `Sí. Coordinamos la visita o el servicio en ${label} según tu necesidad. Escríbenos por WhatsApp con tu dirección y te damos fecha y condiciones.` },
  { question: '¿Qué diferencia hay entre zona operativa y comercial?', answer: 'En una zona operativa damos servicio directo en sitio; en una comercial atendemos a distancia o con cobertura parcial. El tipo sale de COVERAGE_STATES en site.ts.' },
  { question: `¿Atienden fuera de ${label}?`, answer: 'Escríbenos tu ubicación por WhatsApp y te confirmamos la cobertura. Muchos servicios se prestan a distancia sin importar la zona.' },
]

const otras = COVERAGE_STATES.filter((z) => z.slug !== slug)
const cierreItems = [
  ...otras.map((z) => ({ label: z.label, href: `/cobertura/${z.slug}`, sub: 'Otra zona' })),
  { label: 'Toda la cobertura', href: '/cobertura', sub: 'Volver al mapa' },
  { label: 'Servicios', href: '/servicios', sub: 'Lo que ofrecemos' },
]
const cierreCta = { label: `Cotizar en ${label}`, href: waUrl(WA_MESSAGES.cotizar), sub: 'Respuesta inmediata', external: true }
---

<PageLayout
  title={`Cobertura en ${label}`}
  description={`Cobertura ${tipo} en ${label}: servicios disponibles, alcance y contacto directo por WhatsApp. Cotiza en ${label}.`}
  pageType="page"
  schemaData={{ areaServed: [label], faqs }}
  breadcrumbs={[{ label: 'Cobertura', href: '/cobertura' }, { label }]}
  guia={false}
>
  <Hero
    badge={`Zona ${tipo}`}
    title="Cobertura en"
    accent={label}
    subtitle={`Atendemos ${label} con el mismo estándar de servicio. Conoce el alcance en tu zona y cotiza directo por WhatsApp.`}
    descRight={[
      `Damos servicio en ${label} como zona ${tipo}. Aquí ves qué incluye la atención en tu ubicación y cómo solicitarla.`,
      'Cuéntanos dónde estás y qué necesitas: te confirmamos cobertura, tiempos y la mejor forma de atenderte.',
    ]}
  />

  <section class="section">
    <div class="container">
      <GuiaNota titulo="Qué es esta página (zona · SEO local)" archivo="src/pages/cobertura/[...slug].astro">
        <p>
          Una sola ruta dinámica (<code>[...slug].astro</code>) genera la página de <strong>todas</strong>
          las zonas. Los slugs son los de <code>COVERAGE_STATES</code> en <code>site.ts</code>
          (cdmx · edomex), los mismos del menú. El texto es DEMO; en un sitio real conviene moverlo a la
          Content Collection <code>zonas</code> con esos slugs para enriquecer cada ubicación.
        </p>
      </GuiaNota>

      <SectionHeading
        layout="duo"
        eyebrow="Qué cubrimos"
        title={`Servicio en ${label}`}
        desc="El alcance del servicio en esta zona: colonias cubiertas, tiempos y cómo solicitarlo."
        body={[
          `Atendemos ${label} como zona ${tipo}: aquí detallamos las colonias o municipios cubiertos, los tiempos de respuesta y la modalidad de atención en tu ubicación.`,
          '¿No ves tu colonia o municipio? Escríbenos por WhatsApp y te confirmamos si llegamos y en qué condiciones.',
        ]}
      />

      {colonias.length > 0 && (
        <div class="zona-colonias">
          <p class="zona-colonias__lead">{tipo === 'operativa' ? 'Cubrimos, entre otras:' : 'Atendemos, entre otros:'}</p>
          <ul class="chips">
            {colonias.map((c) => <li><span class="chip chip--static">{c}</span></li>)}
          </ul>
          {(deliveryTime || deliveryNote) && (
            <p class="zona-delivery">
              {deliveryTime && <strong>Tiempos: {deliveryTime}. </strong>}
              {deliveryNote}
            </p>
          )}
        </div>
      )}

      {ZoneContent && (
        <div class="prose">
          <ZoneContent />
        </div>
      )}

      <div class="servicios-zona">
        <p class="servicios-zona__lead">Servicios disponibles en {label}:</p>
        <ul class="chips">
          {SERVICES.map((s) => (
            <li><a class="chip" href={`/servicios/${s.id}`}>{s.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <FAQAccordion items={faqs} title={`Preguntas sobre la cobertura en ${label}`} openFirst />
    </div>
  </section>

  <SectionMenu items={cierreItems} cta={cierreCta} ariaLabel="Otras zonas y servicios" />
</PageLayout>

<style>
  .container { max-width: var(--container-max); margin-inline: auto; padding-inline: var(--container-px); }
  .section { padding: var(--sp-8) 0; }
  .section--surface { background: var(--c-surface); }
  @media (min-width: 768px) { .section { padding: var(--sp-10) 0; } }

  .servicios-zona { margin-top: var(--sp-6); }
  .servicios-zona__lead { font-weight: var(--weight-semibold); color: var(--c-ink); margin: 0 0 var(--sp-3); }
  .chips { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: var(--sp-2); }
  .chip {
    display: inline-flex; padding: var(--sp-2) var(--sp-4); border-radius: var(--radius-full);
    background: var(--c-white); border: 1px solid var(--c-border); color: var(--c-ink-2);
    font-size: var(--text-sm); font-weight: var(--weight-medium); text-decoration: none; transition: border-color .15s, color .15s;
  }
  .chip:hover { border-color: var(--c-primary); color: var(--c-primary); }

  .zona-colonias { margin-top: var(--sp-6); }
  .zona-colonias__lead { font-weight: var(--weight-semibold); color: var(--c-ink); margin: 0 0 var(--sp-3); }
  .chip--static { cursor: default; }
  .chip--static:hover { border-color: var(--c-border); color: var(--c-ink-2); }
  .zona-delivery { margin: var(--sp-4) 0 0; font-size: var(--text-sm); color: var(--c-muted); }
  .prose { margin-top: var(--sp-6); max-width: 65ch; }
  .prose :global(h2) { font-family: var(--font-heading); font-size: var(--text-xl); color: var(--c-ink); margin: var(--sp-5) 0 var(--sp-2); }
  .prose :global(p) { color: var(--c-ink-2); line-height: var(--leading-relaxed); margin: 0 0 var(--sp-3); }
  .prose :global(strong) { color: var(--c-ink); }
</style>
