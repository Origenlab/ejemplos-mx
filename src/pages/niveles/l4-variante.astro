// ── 2 RECETAS DEL «CÓMO ESTÁ CONSTRUIDO» ──
const recetaEstructura = `---
// DOS formas de modelar el L4:
// (A) RUTA ANIDADA — una página por variante (URL propia, para SEO).
//     src/pages/productos/[categoria]/[producto].astro
// (B) VARIANTES EN EL FRONTMATTER del L3 — un selector, sin URLs nuevas
//     (cuando las variantes NO merecen indexarse por separado).
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const productos = await getCollection('productos')
  // Genera L4 SOLO para variantes con contenido propio:
  return productos.flatMap((p) =>
    (p.data.variantes ?? [])
      .filter((v) => v.contenidoPropio)          // ← la regla: nada de thin content
      .map((v) => ({
        params: { categoria: p.data.categoria, producto: \`\${p.id}-\${v.slug}\` },
        props: { entry: p, variante: v },
      }))
  )
}
const { entry, variante } = Astro.props
---

{/* Migas de TRES niveles: la hoja tiene bisabuelo, abuelo y padre. */}
<PageLayout
  title={\`\${entry.data.title} — \${variante.nombre}\`}
  pageType="page" schemaType="Product"
  breadcrumbs={[
    { label: 'Productos', href: '/productos' },
    { label: entry.data.title, href: \`/productos/\${entry.id}\` },
    { label: variante.nombre },
  ]}
>
  {/* galería + specs ESPECÍFICAS de la variante */}
</PageLayout>`

const recetaCanonical = `---
// CANONICAL + schema de variante — el SEO seguro del L4.
// Si varias variantes comparten casi todo, el canonical apunta a la
// PRINCIPAL (o al L3 padre) para no canibalizar. La variante emite su
// Product con el atributo distintivo; el ProductGroup las agrupa.
const principal = \`/productos/\${entry.id}\`      // la ficha L3 padre
const esCasiIdentica = !variante.contenidoPropio
---

{/* En <head> (vía PageLayout): si la variante no se diferencia, */}
{/* su canonical apunta al padre para concentrar la señal SEO.   */}
<link rel="canonical" href={esCasiIdentica ? principal : Astro.url.pathname} />

{/* Schema: Product de la variante (color/size/sku), agrupable en */}
{/* un ProductGroup. Un emisor por página (regla B3) — sin duplicar */}
{/* el Organization del layout ni el ItemList del índice.          */}`
