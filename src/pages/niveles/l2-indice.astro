<style>
  /* Estructura (tokens.css = fuente única; scoped por página) */
  .container { max-width: var(--container-max); margin-inline: auto; padding-inline: var(--container-px); }
  .section { padding: var(--sp-8) 0; }
  .section--surface { background: var(--c-surface); }
  @media (min-width: 768px) { .section { padding: var(--sp-10) 0; } }

  /* ── Anatomía (piezas) ── */
  .piezas { display: grid; gap: var(--sp-5); margin: var(--sp-6) 0 0; padding: 0; list-style: none; }
  .pieza { display: grid; grid-template-columns: 48px 1fr; gap: var(--sp-4); align-items: start; padding: var(--sp-5); background: var(--c-white); border: 1px solid var(--c-border); border-radius: var(--radius-md); }
  .pieza__n { display: grid; place-items: center; width: 48px; height: 48px; border-radius: var(--radius-md); background: var(--c-primary); color: #fff; font-family: var(--font-heading); font-weight: var(--weight-black); font-size: 1.25rem; }
  .pieza__nombre { margin: 0 0 var(--sp-2); font-family: var(--font-heading); font-size: var(--text-lg); font-weight: var(--weight-semibold); color: var(--c-ink); }
