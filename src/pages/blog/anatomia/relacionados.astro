@media (max-width: 640px) {
  .rel__grid { grid-template-columns: 1fr; }   /* una tarjeta por fila */
  .rel__card { min-height: 44px; padding: var(--sp-4); }
}`

const recetaTres = `/* Limitar a 3 para no alargar el cierre en móvil.
