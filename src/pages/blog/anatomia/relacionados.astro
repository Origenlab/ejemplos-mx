.post__body { grid-template-columns: 1fr; }   /* una columna en móvil */

/* El artículo va antes que el sidebar en el HTML, de modo que
   los relacionados quedan al final sin tocar nada. */
@media (max-width: 1023px) {
  .post__sidebar { order: 2; }   /* después del contenido */
}`

const recetaFull = `/* MÓVIL · cada relacionado ocupa el ancho completo y es táctil.
   La rejilla pasa a una columna y la tarjeta entera es el área
