  },
]

const sis = [
  'Mantén un conjunto corto y estable de etiquetas, reutilizable entre artículos.',
  'Asegura que cada etiqueta agrupe varios artículos: si solo aparece una vez, no merece archivo.',
  'Escribe los tags en minúscula y de forma consistente («astro», no «Astro» ni «AstroJS»).',
