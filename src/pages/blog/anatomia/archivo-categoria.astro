  description="Archivo de categoría del blog: la página /blog/categoria/<cat> que agrupa los artículos de un tema. Ruta dinámica generada por cada categoría usada, con su listado y su SEO de archivo."
  pageType="page"
  schemaType="TechArticle"
  guia={false}
  breadcrumbs={[{ label: 'Blog', href: '/blog' }, { label: 'Anatomía', href: '/blog/anatomia' }, { label: 'Archivo de categoría' }]}
>
