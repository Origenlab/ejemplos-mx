          <div class="sbv" role="img" aria-label="Sidebar como índice del artículo, con anclas a los encabezados">
            <span class="sbv__main"></span>
            <span class="sbv__aside sbv__aside--toc"><b></b><i></i><i></i><i></i><i></i></span>
          </div>
        </DisenoCard>

        {/* 5 · Franja al pie (sin columna) */}
        <DisenoCard {...disenos[5]}>
          <div class="sbv sbv--foot" role="img" aria-label="Sin columna lateral: los widgets en una franja al pie del contenido">
