          <span class="sbx__h">Temas</span>
          <span class="sbx__tags"><i>#astro</i><i>#seo</i><i>#schema</i><i>#ux</i></span>
        </div>
        <div class="sbx__w">
          <span class="sbx__n">3</span>
          <span class="sbx__h">Lecturas recomendadas</span>
          <span class="sbx__line"></span>
          <span class="sbx__line sbx__line--s"></span>
        </div>
        <div class="sbx__w">
          <span class="sbx__n">4</span>
          <span class="sbx__h">Explora el sitio</span>
