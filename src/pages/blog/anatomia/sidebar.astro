          <div class="sbv" role="img" aria-label="Sidebar con una caja de búsqueda en la parte superior">
            <span class="sbv__main"></span>
            <span class="sbv__aside"><i class="sbv__search"></i><i></i><i class="sbv__cta"></i></span>
          </div>
        </DisenoCard>

        {/* 4 · Índice del artículo (TOC) */}
