// ── Recetas de implementación (las pinta <Receta>) ───────────────────────────
const recetaPaths = `---
// /blog/pagina/[page].astro · genera las páginas 2..N en build.
import { getCollection } from 'astro:content'
import { PAGE_SIZE } from '@lib/blog'

export async function getStaticPaths() {
  const articulos = (await getCollection('articulos', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

  const total = Math.ceil(articulos.length / PAGE_SIZE)

  // La página 1 es /blog (canónica); aquí solo 2..N.
  const paths = []
  for (let p = 2; p <= total; p++) {
    paths.push({
      params: { page: String(p) },
      props: {
        items: articulos.slice((p - 1) * PAGE_SIZE, p * PAGE_SIZE),
        current: p, total,
      },
    })
  }
  return paths
}
---`

const recetaSlice = `---
// /blog/index.astro · la PÁGINA 1 = los primeros PAGE_SIZE artículos.
// El mismo cuerpo (BlogListing) se reutiliza en /blog y en /blog/pagina/<n>.
import { PAGE_SIZE, blogSidebarData } from '@lib/blog'

const total     = Math.max(1, Math.ceil(articulos.length / PAGE_SIZE))
const pageItems = articulos.slice(0, PAGE_SIZE)
const sidebar   = blogSidebarData(articulos)   // listas del sidebar (todas las entradas)
---

<BlogListing articulos={pageItems} current={1} total={total} sidebar={sidebar} />`

const recetaNav = `---
// PaginationNav.astro · la página 1 es /blog; el resto, /blog/pagina/<n>.
const url  = (p) => (p <= 1 ? '/blog' : \`/blog/pagina/\${p}\`)
const prev = current > 1     ? url(current - 1) : null
const next = current < total ? url(current + 1) : null
---

<nav aria-label="Paginación de artículos">
  {prev && <a href={prev} rel="prev">← Anteriores</a>}
  {/* …números: la actual con aria-current, las demás enlazadas… */}
  {next && <a href={next} rel="next">Siguientes →</a>}
</nav>`

// ── Recetas de los patrones móviles ──────────────────────────────────────────
const recetaWrap = `/* MÓVIL · los controles se envuelven y se centran (default).
   La barra es flex con wrap: si los números no caben en una
   línea, saltan a la siguiente sin romper el layout. */

.pag       { display: flex; flex-wrap: wrap; justify-content: center; gap: var(--sp-2); }
.pag__nums { display: flex; flex-wrap: wrap; gap: var(--sp-1); }`

const recetaCompacta = `/* MÓVIL · esconder números, dejar prev/next + contador (extensión).
   En pantallas muy estrechas, los números estorban; basta con
   los dos extremos y un "Página X de Y". */

@media (max-width: 480px) {
  .pag__nums { display: none; }
  .pag::after {
    content: 'Página ' attr(data-current) ' de ' attr(data-total);
    font-size: var(--text-sm); color: var(--c-muted);
  }
}`

const recetaTap = `/* Área táctil cómoda: cada control ≥ 44 px de alto en el teléfono.
   Se toca con el dedo, no con un cursor. */

@media (max-width: 768px) {
  .pag__num, .pag__edge { min-height: 44px; }
}`
---

<PageLayout
  title="La Paginación del blog — partir el listado sin perder SEO"
  description="Paginación del blog: página 1 en /blog y el resto en /blog/pagina/<n>, con enlaces reales y rel prev/next. Generada en build con getStaticPaths, sin JavaScript."
  pageType="page"
  schemaType="TechArticle"
  guia={false}
  breadcrumbs={[{ label: 'Blog', href: '/blog' }, { label: 'Anatomía', href: '/blog/anatomia' }, { label: 'Paginación' }]}
>
  <Hero
    badge="Complemento del blog · Paginación"
    title="La Paginación:"
    accent="partir el listado sin perder SEO"
    subtitle="Cuando los artículos crecen, una sola página interminable se vuelve lenta y difícil de recorrer. La paginación la parte en tramos navegables —página 1 en /blog, el resto en /blog/pagina/<n>— con enlaces reales que el buscador entiende."
    descRight={[
      'Esta página no es una ficha técnica: es el complemento entero, abierto y explicado. Qué problema resuelve, de qué piezas se compone, cómo se comporta en el teléfono, dónde encaja y, al final, cómo está construido —del criterio de diseño a la línea de código—.',
      'Con un matiz propio que conviene marcar: aquí la paginación NO vive en la raíz del blog, porque /blog/<slug> ya la ocupan los artículos. La página 1 es /blog y las demás cuelgan de /blog/pagina/<n>. Se generan en build, son HTML estático y no dependen de JavaScript.',
    ]}
  />

  {/* ── 1) ¿QUÉ ES? ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Definición"
        title="¿Qué es la paginación?"
        desc="El mecanismo que parte un listado largo en varias páginas más cortas, con controles para moverse entre ellas: anterior, números y siguiente."
        body={[
          'Paginar es dividir una lista —aquí, los artículos del blog— en tramos de tamaño fijo y darle a cada tramo su propia página y su URL. En vez de /blog con 50 entradas, tienes /blog (las primeras), /blog/pagina/2, /blog/pagina/3… Cada una carga un puñado y ofrece los controles para saltar a las demás.',
          'No se inventó aquí: es el patrón clásico de cualquier listado extenso —resultados de búsqueda, catálogos, archivos de blog—. La alternativa (mostrarlo todo de golpe, o cargar al hacer scroll) tiene su lugar, pero la paginación numerada sigue siendo la más predecible para la persona y la más amable con el buscador.',
        ]}
      />
    </div>
  </section>

  {/* ── 2) ¿PARA QUÉ SIRVE? ── */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Función e importancia"
        title="¿Para qué sirve?"
        desc="Hace tres trabajos: aligera cada página (rendimiento), mantiene el listado navegable e indexable, y todo sin JavaScript porque se genera en build."
        body={[
          'Su función es que un archivo que crece no se vuelva un lastre. Sin paginar, cada artículo nuevo hace la página del blog más pesada y más lenta —más HTML, más imágenes, peor Core Web Vitals—. Paginar mantiene cada página acotada y rápida, sin importar cuántos artículos haya en total.',
          'Y lo hace sin sacrificar el SEO ni la usabilidad. Cada página es una URL real e indexable, los controles son enlaces (no scripts), y la relación entre páginas se declara con rel="prev"/"next". El lector siempre sabe cuánto hay y dónde está; el buscador, cómo encadenar la serie.',
        ]}
      />
      <div class="bene">
        {beneficios.map((b) => (
          <article class="bene__card">
            <h3 class="bene__title">{b.titulo}</h3>
            <p class="bene__desc">{b.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ── 3) ¿QUÉ LLEVA? — anatomía con ejemplo en vivo ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Anatomía"
        title="¿Qué lleva la paginación?"
        desc="Cinco piezas: el enlace «Anteriores», los números de página, el enlace «Siguientes», la ruta partida (/blog + /blog/pagina/<n>) y el tamaño de página."
        body={[
          'Cada pieza cumple un papel claro. Los extremos (anterior/siguiente) son el par mínimo de navegación; los números dan contexto y acceso directo; la ruta partida resuelve el dónde viven las páginas; y el tamaño de página es la perilla que decide cuántas hay. Visibles arriba, invisibles abajo (ruta y tamaño), pero todas necesarias.',
          'Abajo, el ejemplo en vivo —réplica anotada del componente PaginationNav—. Cada punto numerado se desglosa en su tarjeta: qué resuelve y de qué dato sale. La página actual va marcada y sin enlace; los extremos se desactivan en la primera y la última.',
        ]}
      />

      {/* Ejemplo en vivo de la paginación (réplica del componente). */}
      <div class="pgx" role="img" aria-label="Ejemplo de paginación: Anteriores, números con la página 2 activa, y Siguientes">
        <span class="pgx__edge"><span class="pgx__n">1</span>← Anteriores</span>
        <span class="pgx__nums">
          <span class="pgx__num">1</span>
          <span class="pgx__num pgx__num--cur"><span class="pgx__n pgx__n--mid">2</span>2</span>
          <span class="pgx__num">3</span>
        </span>
        <span class="pgx__edge">Siguientes →<span class="pgx__n">3</span></span>
        <span class="pgx__meta">
          <span class="pgx__tag"><span class="pgx__n pgx__n--mid">4</span> /blog · /blog/pagina/2 · /blog/pagina/3</span>
          <span class="pgx__tag"><span class="pgx__n pgx__n--mid">5</span> PAGE_SIZE = 9</span>
        </span>
      </div>

      <div class="partes">
        {partes.map((p) => (
          <article class="parte">
            <span class="parte__num">{p.n}</span>
            <div class="parte__body">
              <h3 class="parte__nombre">{p.nombre}</h3>
              <p class="parte__que">{p.que}</p>
              <p class="parte__dato"><span>Dato</span> <code>{p.dato}</code></p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ── 3b) VARIANTES ── */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Variantes"
        title="Otros diseños y aplicaciones"
        desc="La de esta plantilla es numerada con prev/next, pero la paginación cambia según el contenido: minimal, con elipsis, «cargar más», scroll infinito o sticky."
        body={[
          'No hay un único modelo: hay una misma idea —partir un listado y dar controles para moverse— que cada caso ajusta. Pocas páginas piden solo prev/next; un archivo enorme, números con elipsis; un feed móvil, «cargar más»; una red social, scroll infinito (con red de seguridad).',
          'Abajo, seis variantes —dos son configuraciones reales del componente (ocultando números o fijándolo) y el resto, extensiones que requieren más lógica o JavaScript—. Cada una con su réplica en vivo y el tipo de proyecto donde rinde mejor.',
        ]}
      />

      <GaleriaDisenos ariaLabel="Variantes de paginación">
        {/* 0 · Numerada con prev/next (esta plantilla) */}
        <DisenoCard {...disenos[0]}>
          <div class="pgv" role="img" aria-label="Anteriores, números 1 2 3 y Siguientes">
            <span class="pgv__e">←</span>
            <span class="pgv__n">1</span><span class="pgv__n pgv__n--cur">2</span><span class="pgv__n">3</span>
            <span class="pgv__e">→</span>
          </div>
        </DisenoCard>

        {/* 1 · Solo Anterior / Siguiente */}
        <DisenoCard {...disenos[1]}>
          <div class="pgv pgv--minimal" role="img" aria-label="Solo Anterior y Siguiente">
            <span class="pgv__b">← Anteriores</span>
            <span class="pgv__b">Siguientes →</span>
          </div>
        </DisenoCard>

        {/* 2 · Numerada con elipsis */}
        <DisenoCard {...disenos[2]}>
          <div class="pgv" role="img" aria-label="Números con elipsis: 1, puntos, 6 7 8, puntos, 24">
            <span class="pgv__n">1</span><span class="pgv__dots">…</span>
            <span class="pgv__n">6</span><span class="pgv__n pgv__n--cur">7</span><span class="pgv__n">8</span>
            <span class="pgv__dots">…</span><span class="pgv__n">24</span>
          </div>
        </DisenoCard>

        {/* 3 · Cargar más */}
        <DisenoCard {...disenos[3]}>
          <div class="pgv pgv--more" role="img" aria-label="Listado con un botón Cargar más al final">
            <span class="pgv__row"></span><span class="pgv__row"></span>
            <span class="pgv__load">Cargar más</span>
          </div>
        </DisenoCard>

        {/* 4 · Scroll infinito */}
        <DisenoCard {...disenos[4]}>
          <div class="pgv pgv--inf" role="img" aria-label="Listado que sigue cargando al hacer scroll, con un spinner">
            <span class="pgv__row"></span><span class="pgv__row"></span><span class="pgv__row pgv__row--fade"></span>
            <span class="pgv__spin" aria-hidden="true">◴</span>
          </div>
        </DisenoCard>

        {/* 5 · Barra sticky al pie */}
        <DisenoCard {...disenos[5]}>
          <div class="pgv pgv--sticky" role="img" aria-label="Paginación fija al borde inferior del listado">
            <span class="pgv__row"></span><span class="pgv__row"></span>
            <span class="pgv__bar"><i>←</i><i class="pgv__bar--cur">2</i><i>→</i></span>
          </div>
        </DisenoCard>
      </GaleriaDisenos>
    </div>
  </section>

  {/* ── 3c) RESPONSIVE Y MÓVIL ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Responsive y móvil"
        title="Cómo se comporta en el teléfono"
        desc="En móvil la barra no se aprieta: los controles se envuelven y se centran. Si el espacio es mínimo, puede dejar solo prev/next con un contador, y siempre con área táctil cómoda."
        body={[
          'En escritorio la barra vive en una sola línea: «Anteriores», los números y «Siguientes». En el teléfono, esa línea no siempre cabe, así que la barra usa flex con wrap: los números saltan de línea y todo se centra, sin romperse ni desbordar. Es lo que ya hace el componente.',
          'A partir de ahí, dos ajustes según el caso: en pantallas muy estrechas, ocultar los números y dejar solo los extremos con un «Página X de Y»; y, en todos los casos, asegurar que cada control mida al menos 44 px para tocarse cómodo. Abajo, cada patrón con su vista y su receta.',
        ]}
      />

      <div class="pats">
        {/* 1 · Wrap (default) */}
        <article class="pat">
          <div class="pat__demo">
            <MarcoMovil ariaLabel="En móvil los controles de paginación se envuelven y se centran">
              <div class="pgm">
                <span class="pgm__row"></span><span class="pgm__row"></span>
                <span class="pgm__pag">
                  <i>←</i><i>1</i><i class="pgm__cur">2</i><i>3</i><i>→</i>
                </span>
              </div>
            </MarcoMovil>
          </div>
          <div class="pat__info">
            <h3 class="pat__title">1 · Controles que se envuelven (default)</h3>
            <p class="pat__desc">La barra es <code>flex-wrap: wrap</code> y se centra: si los números no caben en una línea, saltan a la siguiente sin desbordar. Es lo que hace el componente de fábrica, sin tocar nada.</p>
            <Receta titulo="CSS · barra que envuelve" lang="css" code={recetaWrap} />
          </div>
        </article>

        {/* 2 · Compacta */}
        <article class="pat">
          <div class="pat__demo">
            <MarcoMovil ariaLabel="En pantallas muy estrechas, solo Anterior y Siguiente con un contador">
              <div class="pgm">
                <span class="pgm__row"></span><span class="pgm__row"></span>
                <span class="pgm__pag pgm__pag--compact">
                  <i>← Ant.</i><b>Pág. 2 de 3</b><i>Sig. →</i>
                </span>
              </div>
            </MarcoMovil>
          </div>
          <div class="pat__info">
            <h3 class="pat__title">2 · Solo prev/next + contador (extensión)</h3>
            <p class="pat__desc">En pantallas muy estrechas, los números estorban; basta con los dos extremos y un «Página X de Y». Se ocultan los números por CSS y el contador puede salir de atributos <code>data-*</code>, sin JavaScript.</p>
            <Receta titulo="CSS · compacta en móvil" lang="css" code={recetaCompacta} />
          </div>
        </article>

        {/* 3 · Táctil */}
        <article class="pat">
          <div class="pat__demo">
            <MarcoMovil ariaLabel="Cada control de paginación con al menos 44 píxeles de alto">
              <div class="pgm">
                <span class="pgm__row"></span>
                <span class="pgm__pag pgm__pag--tap">
                  <i>←</i><i>1</i><i class="pgm__cur">2</i><i>3</i><i>→</i>
                </span>
                <span class="pgm__ruler" aria-hidden="true">44px</span>
              </div>
            </MarcoMovil>
          </div>
          <div class="pat__info">
            <h3 class="pat__title">3 · Área táctil cómoda (≥44 px)</h3>
            <p class="pat__desc">En el teléfono se toca con el dedo: cada número y cada enlace prev/next mide al menos 44 px de alto, el objetivo táctil recomendado. Evita toques fallidos y respeta las pautas de accesibilidad.</p>
