---
// ============================================================================
// /blog/anatomia/tarjeta-articulo — PÁGINA DEL COMPLEMENTO «Tarjeta de artículo».
// ----------------------------------------------------------------------------
// De la serie /blog/anatomia/* (sidebar · paginacion · tarjeta-articulo · …),
// MISMO molde que /modulos/<slug>: hero → ¿qué es? → ¿para qué? → ¿qué lleva?
// (+demo) → variantes → responsive → ¿dónde va? → cómo se arma → buenas
// prácticas → cierre. NO documenta un componente nuevo: la tarjeta del listado
// del blog es la MISMA CategoryCard del catálogo, alimentada desde BlogListing
// con cada artículo (label=título, href=/blog/<id>, image=blogImage(id),
// badge=categoría legible, blurb=descripción, ctaLabel="Leer artículo", index=i).
// ============================================================================
import PageLayout from '@layouts/PageLayout.astro'
import Hero from '@components/Hero.astro'
import SectionHeading from '@components/SectionHeading.astro'
import SectionMenu from '@components/SectionMenu.astro'
import GaleriaDisenos from '@components/GaleriaDisenos.astro'
import DisenoCard from '@components/DisenoCard.astro'
import MarcoMovil from '@components/MarcoMovil.astro'
import Receta from '@components/Receta.astro'
import { WA_MESSAGES, waUrl } from '@config/site'
import { siblingsAnatomia } from '@lib/blogAnatomia'

const cierreItems = siblingsAnatomia('tarjeta-articulo')
const cierreCta = { label: 'Cotizar por WhatsApp', href: waUrl(WA_MESSAGES.cotizar), sub: 'Respuesta inmediata', external: true }

// Las 5 partes de la tarjeta — mapean con los pines del ejemplo en vivo.
const partes = [
  {
    n: 1,
    nombre: 'Imagen 16:10 (con alt)',
    que: 'La foto de cabecera, en proporción fija 16:10, recortada con object-fit para que ninguna deforme la rejilla. Lleva siempre alt descriptivo —no relleno— y dimensiones width/height fijas, así el navegador reserva el hueco antes de cargar y la página no salta (cero CLS). La imagen del pool entra optimizada (AVIF).',
    dato: 'image · imageAlt · width/height · index<4 ? eager : lazy',
  },
  {
    n: 2,
    nombre: 'Badge de categoría',
    que: 'La etiqueta corta sobre la esquina de la imagen con la categoría legible del artículo —Guías, Novedades…—. Da contexto de un vistazo y agrupa visualmente el listado por tema. Sale de un mapa categoría→etiqueta (CAT_LABEL), no del slug crudo, para que se lea en humano.',
    dato: 'badge · CAT_LABEL[a.data.category]',
  },
  {
    n: 3,
    nombre: 'Título H3 (enlace)',
    que: 'El título del artículo como encabezado H3 —respeta la jerarquía H1 hero → H2 sección → H3 card— y, a la vez, el enlace principal a la entrada. Es anchor text real hacia /blog/&lt;slug&gt;: bueno para el lector y para el enlazado interno que el buscador rastrea.',
    dato: 'label · href = /blog/${a.id}',
  },
  {
    n: 4,
    nombre: 'Blurb (descripción)',
    que: 'El resumen breve, una o dos frases, que adelanta de qué va el artículo y empuja a abrirlo. No se escribe aquí: es la description del frontmatter del .mdx, así que el resumen del listado y el de la metaetiqueta son la misma fuente —cero desincronización—.',
    dato: 'blurb · a.data.description',
  },
  {
    n: 5,
    nombre: 'CTA «Leer artículo»',
    que: 'La llamada a la acción al fondo de la tarjeta —siempre abajo, para que las alturas cuadren en la rejilla—. Un único botón, sin ambigüedad, que repite el destino del título. En el catálogo el texto por defecto es «Ver más»; en el blog se pasa «Leer artículo».',
    dato: 'ctaLabel="Leer artículo" · href = /blog/${a.id}',
  },
]

const beneficios = [
  {
    titulo: 'Vitrina escaneable, no un muro de títulos',
    desc: 'Una lista de enlaces a secas obliga a leer línea por línea; una rejilla de tarjetas se recorre de un vistazo. Imagen, categoría, título y resumen le dan al lector lo justo para decidir qué abrir en un segundo. La tarjeta convierte el archivo del blog en un escaparate, no en un índice.',
  },
  {
    titulo: 'Reutiliza el card del catálogo (cero diseño nuevo)',
    desc: 'No hay una «card de blog» aparte: es la misma CategoryCard de la vitrina de productos, alimentada con los datos del artículo. Una sola pieza significa una sola estética, un solo lugar que mantener y coherencia automática entre el catálogo y el blog. La lección de siempre: reusar antes que duplicar.',
  },
  {
    titulo: 'Rendimiento de fábrica (cero CLS, lazy/eager)',
    desc: 'La tarjeta trae width/height fijos, así que el navegador reserva el hueco de la imagen y la página no salta (cero CLS). Las primeras cuatro cargan eager —están en pantalla— y el resto lazy, por su index en la rejilla. Las fotos del pool entran en AVIF: livianas sin perder nitidez.',
  },
]

const sis = [
  'Pasa siempre un alt descriptivo (el título del artículo basta) — nunca lo dejes vacío.',
  'Conserva width/height para que el navegador reserve el hueco y no haya salto (cero CLS).',
  'Deja que las primeras cuatro carguen eager (van en pantalla) y el resto lazy, por su index.',
  'Mantén un solo CTA por tarjeta —«Leer artículo»— que repita el destino del título.',
  'Reutiliza CategoryCard alimentándola con los datos del artículo, no una card propia.',
  'Usa el badge para la categoría legible (CAT_LABEL), no el slug crudo.',
]
const nos = [
  'No estrenes una «card de blog» nueva: duplica estética y multiplica el mantenimiento.',
  'No quites width/height «porque la imagen es responsive»: vuelve el CLS y baja Core Web Vitals.',
  'No pongas dos o tres CTAs por tarjeta: un destino claro, no un ramo de botones.',
  'No cargues todas las imágenes eager: las de abajo deben ser lazy o pesa la primera carga.',
  'No metas el slug crudo en el badge: pásalo por CAT_LABEL para que se lea en humano.',
  'No escribas el resumen aparte: usa la description del .mdx para no desincronizar.',
]

// Variantes de la tarjeta (galería). Réplica en vivo abajo, mismo orden.
const disenos = [
  {
    nombre: 'Con imagen (estándar del blog)',
    tag: 'Blog · Listado',
    desc: 'La del listado /blog: imagen de cabecera con badge encima, título, resumen y «Leer artículo». Es la forma completa de la tarjeta y la que mejor convierte una lista en vitrina. Configuración real del componente, alimentada con los datos del artículo.',
  },
  {
    nombre: 'Sin imagen (solo texto)',
    tag: 'Notas · Cambios',
    desc: 'Cuando un artículo no trae foto, la tarjeta se sostiene igual: el badge pasa al cuerpo —inline, sobre el título— y manda el texto. El componente lo soporta de fábrica: si no recibe image, omite el bloque visual sin romper la rejilla.',
  },
  {
    nombre: 'Con chips de subcategorías',
    tag: 'Catálogo · Temas',
    desc: 'La misma tarjeta con una fila de chips bajo el resumen —subcategorías o temas, como enlaces—. Es el modo nativo de CategoryCard en la vitrina de productos; en el blog se activaría pasando subcategories para cruzar a archivos de etiqueta.',
  },
  {
    nombre: 'Destacada (primera, prioridad)',
    tag: 'Portada · Featured',
    desc: 'La primera de la rejilla, en mayor tamaño o ancho completo, como entrada destacada. No cambia el componente: es la misma tarjeta con index 0 (que ya carga su imagen eager / priority) y un poco más de espacio por CSS de la página.',
  },
  {
    nombre: 'Compacta (lista densa)',
    tag: 'Archivo · Sidebar',
    desc: 'Versión apretada sin imagen o con miniatura: título y poco más, en una columna densa. Útil en «lecturas recomendadas» del sidebar o en archivos largos donde caben más entradas por pantalla. Es CSS por encima de la misma tarjeta.',
  },
  {
    nombre: 'Card de archivo (categoría/etiqueta)',
    tag: 'Archivo · SEO',
    desc: 'La misma tarjeta exacta reutilizada en /blog/categoria/&lt;cat&gt; y /blog/tag/&lt;tag&gt;. No es una variante de diseño, sino de contexto: el archivo filtra los artículos y los pinta con la rejilla y la tarjeta del listado. Coherencia gratis.',
  },
]

// ── Recetas de implementación (las pinta <Receta>) ───────────────────────────
const recetaUso = `---
// USO · BlogListing recorre los artículos de la página y pinta una
// CategoryCard por cada uno. La misma card del catálogo, con los
// datos del artículo: NO hay una "card de blog" aparte.
import CategoryCard from '@components/CategoryCard.astro'
import { blogImage } from '@lib/blogImages'
import { CAT_LABEL } from '@lib/blog'
---

<div class="grid">
  {articulos.map((a, i) => (
    <CategoryCard
      label={a.data.title}                          {/* título → H3 */}
      href={\`/blog/\${a.id}\`}                         {/* título y CTA */}
      image={blogImage(a.id)}                        {/* foto del pool */}
      imageAlt={a.data.title}                        {/* alt descriptivo */}
      badge={CAT_LABEL[a.data.category] ?? a.data.category}
      blurb={a.data.description}                     {/* resumen del .mdx */}
      ctaLabel="Leer artículo"
      index={i}                                      {/* eager si i < 4 */}
    />
  ))}
</div>`

const recetaImagen = `---
// LA IMAGEN · no se guarda por artículo: se toma de un pool de fotos
// demo (AVIF) de forma estable por id, así cada entrada siempre
// muestra la misma y el listado se ve uniforme sin subir una por post.
import { blogImage } from '@lib/blogImages'

// blogImage(id) → ruta /images/... AVIF, determinista por el id del .mdx.
const src = blogImage('mi-articulo')   // p. ej. /images/articulos/....avif
---

<CategoryCard image={blogImage(a.id)} imageAlt={a.data.title} /* … */ />`

const recetaProps = `// LA INTERFACE · API de CategoryCard (presentacional: solo pinta lo
// que recibe). La tarjeta del blog es esta misma, con datos del artículo.
export type Sub = { label: string; href: string }

interface Props {
  label: string             // título de la tarjeta (H3)            [requerido]
  href: string              // destino del título y del CTA         [requerido]
  image?: string            // imagen de cabecera (16:10)
  imageAlt?: string         // alt descriptivo (cae a label)
  badge?: string            // etiqueta corta sobre la imagen (categoría)
  blurb?: string            // texto/resumen (1–2 frases)
  subcategories?: readonly Sub[]  // chips de enlaces hijos
  ctaLabel?: string         // texto del botón (default "Ver más")
  index?: number            // posición en la rejilla; index < 4 → imagen eager
  disabled?: boolean        // tarjeta sin enlace (evita 404s)
}`

// ── Recetas de los patrones móviles ──────────────────────────────────────────
const recetaRejilla = `/* MÓVIL · la rejilla crece de 1 a 2 (a 2/3) columnas (mobile-first).
   Arranca en una columna y suma columnas al ganar ancho; la card
   no cambia, solo cuántas caben por fila. */

.grid { display: grid; grid-template-columns: 1fr; gap: var(--sp-5); }

@media (min-width: 560px)  { .grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .grid { grid-template-columns: repeat(2, 1fr); } }
/* En el catálogo (sin sidebar) la misma card va a 3–4 por fila. */`

const recetaFluida = `/* MÓVIL · imagen fluida 16:10 sin deformar.
   La caja fija la proporción y object-fit recorta sin estirar:
   da igual el tamaño real de la foto, la card no se descuadra. */

.ccard__media { position: relative; aspect-ratio: 16 / 10; overflow: hidden; }
.ccard__img   { width: 100%; height: 100%; object-fit: cover; }

/* width/height en el <img> reservan el hueco antes de cargar (cero CLS). */`

const recetaTactil = `/* MÓVIL · toda la card invita al toque y el CTA cómodo (≥44 px).
   El título y el CTA enlazan al mismo destino; el botón mide
   al menos 44 px de alto, el objetivo táctil recomendado. */

.ccard__title a { text-decoration: none; color: inherit; }

@media (max-width: 768px) {
  .ccard__cta { min-height: 44px; }   /* se toca con el dedo, no con un cursor */
}`
---

<PageLayout
  title="La Tarjeta de artículo — la card del listado del blog"
  description="Tarjeta de artículo: la card del listado del blog. Reutiliza CategoryCard con los datos del artículo —imagen, badge, título, resumen y «Leer artículo»— con cero CLS."
  pageType="page"
  schemaType="TechArticle"
  guia={false}
  breadcrumbs={[{ label: 'Blog', href: '/blog' }, { label: 'Anatomía', href: '/blog/anatomia' }, { label: 'Tarjeta de artículo' }]}
>
  <Hero
    badge="Complemento del blog · Tarjeta de artículo"
    title="La Tarjeta de artículo:"
    accent="la card del listado del blog"
    subtitle="La cara de cada entrada en el listado: imagen, categoría, título, un resumen y «Leer artículo». Convierte la lista del blog en una vitrina que se recorre de un vistazo —y no es una pieza nueva, es la misma card del catálogo—."
    descRight={[
      'Esta página no es una ficha técnica: es el complemento entero, abierto y explicado. Qué problema resuelve y por qué gana su lugar en el listado, de qué partes se compone, cómo se comporta en el teléfono, dónde se reutiliza y, al final, cómo está construida —del criterio de diseño a la línea de código—.',
      'Con una particularidad que conviene marcar desde el principio: no hay una «tarjeta de blog» aparte. Es la misma CategoryCard de la vitrina de productos, alimentada con los datos de cada artículo. Una sola pieza, una sola estética y un solo lugar que mantener; coherencia entre catálogo y blog sin trabajo extra.',
    ]}
  />

  {/* ── 1) ¿QUÉ ES? ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Definición"
        title="¿Qué es la tarjeta de artículo?"
        desc="La unidad visual de cada entrada en el listado del blog: un bloque con imagen, badge de categoría, título, resumen y un enlace para leer. Una por artículo, en rejilla."
        body={[
          'La tarjeta de artículo (article card) es el rectángulo que representa una entrada en el listado del blog. Reúne lo justo para decidir si abrirla: una imagen de cabecera, la categoría como etiqueta, el título, un resumen breve y un botón «Leer artículo». Puestas en rejilla, varias tarjetas forman la vitrina del blog —el escaparate frente al índice de texto—.',
          'No se inventó aquí, y tampoco es un componente nuevo: es la misma CategoryCard que pinta la vitrina de productos, reutilizada con los datos del artículo. La página del listado (BlogListing) recorre los artículos y emite una tarjeta por cada uno; el componente solo pinta lo que recibe. Misma pieza, misma estética, dos usos.',
        ]}
      />
    </div>
  </section>

  {/* ── 2) ¿PARA QUÉ SIRVE? ── */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Función e importancia"
        title="¿Para qué sirve?"
        desc="Hace tres trabajos: vuelve escaneable el listado, reutiliza el card del catálogo (cero diseño nuevo) y aporta rendimiento de fábrica —cero CLS y carga de imagen por prioridad—."
        body={[
          'Su función es que el lector decida rápido. Un listado de títulos a secas obliga a leerlo todo; una rejilla de tarjetas se recorre de un vistazo —imagen, categoría, título, resumen— y el ojo salta a lo que interesa. La tarjeta convierte el archivo del blog en una vitrina, y de ahí salen los clics a los artículos.',
          'Y pesa más de lo que parece para su tamaño. Para el mantenimiento, es reutilizar una sola pieza (CategoryCard) en vez de inventar una card de blog: una estética, un lugar que tocar. Para el rendimiento, trae width/height fijos —cero CLS— y carga las imágenes por prioridad según su posición. Tres efectos, una misma tarjeta.',
        ]}
      />
      <div class="bene">
        {beneficios.map((b) => (
          <article class="bene__card">
            <h3 class="bene__title">{b.titulo}</h3>
            <p class="bene__desc">{b.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ── 3) ¿QUÉ LLEVA? — anatomía con ejemplo en vivo ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Anatomía"
        title="¿Qué lleva la tarjeta?"
        desc="Cinco partes: la imagen 16:10 con su alt, el badge de categoría encima, el título H3 (enlace), el blurb del frontmatter y el CTA «Leer artículo» al fondo."
        body={[
          'Cada parte cumple un papel claro. La imagen engancha y da contexto; el badge agrupa por tema; el título es a la vez encabezado y enlace principal; el blurb adelanta el contenido; y el CTA cierra con la acción, siempre abajo para que las alturas cuadren en la rejilla. Nada sobra, y el orden va de lo visual a lo accionable.',
          'Abajo, el ejemplo en vivo —réplica anotada a escala de una tarjeta real—. Cada punto numerado se desglosa en su tarjeta: qué resuelve y de qué prop o dato del artículo sale. Recuerda que ninguna parte es exclusiva del blog: son las props de CategoryCard, alimentadas aquí con el título, la categoría, la descripción y la imagen del .mdx.',
        ]}
      />

      {/* Ejemplo en vivo de la tarjeta (réplica a escala de CategoryCard). */}
      <div class="tcdx" role="img" aria-label="Ejemplo de tarjeta de artículo: imagen con badge de categoría, título, resumen y enlace «Leer artículo»">
        <div class="tcdx__card">
          <div class="tcdx__media">
            <span class="tcdx__n tcdx__n--media">1</span>
            <span class="tcdx__badge"><span class="tcdx__n tcdx__n--badge">2</span>Guías</span>
          </div>
          <div class="tcdx__body">
            <span class="tcdx__title"><span class="tcdx__n tcdx__n--mid">3</span>Plantilla Astro con Markdown</span>
            <span class="tcdx__blurb"><span class="tcdx__n tcdx__n--mid">4</span>Contenido separado del diseño: escribe en .mdx y publica.</span>
            <span class="tcdx__line"></span>
            <span class="tcdx__cta"><span class="tcdx__n tcdx__n--cta">5</span>Leer artículo →</span>
          </div>
        </div>
      </div>

      <div class="partes">
        {partes.map((p) => (
          <article class="parte">
            <span class="parte__num">{p.n}</span>
            <div class="parte__body">
              <h3 class="parte__nombre">{p.nombre}</h3>
              <p class="parte__que" set:html={p.que}></p>
              <p class="parte__dato"><span>Dato</span> <code>{p.dato}</code></p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ── 3b) VARIANTES ── */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Variantes"
        title="Otros diseños y aplicaciones"
        desc="La del blog es la tarjeta completa con imagen, pero la misma CategoryCard cambia de cara según el caso: sin imagen, con chips, destacada, compacta o como card de archivo."
        body={[
          'No hay un único modelo: hay una misma pieza —CategoryCard— que cada contexto ajusta sin reescribir nada. Un artículo sin foto cae a la forma «solo texto»; una entrada destacada usa el index 0 con más espacio; un sidebar denso pide la versión compacta; y los archivos de categoría y etiqueta reutilizan la tarjeta exacta del listado.',
          'Abajo, seis variantes —casi todas son configuraciones reales del componente (omitiendo image, pasando subcategories, o solo CSS de la página), y un par insinúan extensiones de contexto—. Cada una con su réplica en vivo y el tipo de uso donde rinde mejor.',
        ]}
      />

      <GaleriaDisenos ariaLabel="Variantes de tarjeta de artículo">
        {/* 0 · Con imagen (estándar del blog) */}
        <DisenoCard {...disenos[0]}>
          <div class="tcdv" role="img" aria-label="Tarjeta con imagen, badge, título, resumen y CTA">
            <span class="tcdv__img"><i class="tcdv__b"></i></span>
            <span class="tcdv__t"></span>
            <span class="tcdv__d"></span>
            <span class="tcdv__d tcdv__d--s"></span>
            <span class="tcdv__cta"></span>
          </div>
        </DisenoCard>

        {/* 1 · Sin imagen (solo texto) */}
        <DisenoCard {...disenos[1]}>
          <div class="tcdv tcdv--noimg" role="img" aria-label="Tarjeta sin imagen: badge inline sobre el título">
            <span class="tcdv__chip"></span>
            <span class="tcdv__t"></span>
            <span class="tcdv__d"></span>
            <span class="tcdv__d tcdv__d--s"></span>
            <span class="tcdv__cta"></span>
          </div>
        </DisenoCard>

        {/* 2 · Con chips de subcategorías */}
        <DisenoCard {...disenos[2]}>
          <div class="tcdv" role="img" aria-label="Tarjeta con una fila de chips bajo el resumen">
            <span class="tcdv__img"><i class="tcdv__b"></i></span>
            <span class="tcdv__t"></span>
            <span class="tcdv__d"></span>
            <span class="tcdv__chips"><i></i><i></i><i></i></span>
            <span class="tcdv__cta"></span>
          </div>
        </DisenoCard>

        {/* 3 · Destacada (primera, prioridad) */}
        <DisenoCard {...disenos[3]}>
          <div class="tcdv tcdv--feat" role="img" aria-label="Tarjeta destacada en mayor tamaño con etiqueta de prioridad">
            <span class="tcdv__img tcdv__img--feat"><i class="tcdv__b"></i><b class="tcdv__prio">eager</b></span>
            <span class="tcdv__t tcdv__t--feat"></span>
            <span class="tcdv__d"></span>
            <span class="tcdv__cta"></span>
          </div>
        </DisenoCard>

        {/* 4 · Compacta (lista densa) */}
        <DisenoCard {...disenos[4]}>
          <div class="tcdv tcdv--compact" role="img" aria-label="Lista densa de tarjetas compactas sin imagen">
            <span class="tcdv__rowc"><i class="tcdv__thumb"></i><i class="tcdv__rt"></i></span>
            <span class="tcdv__rowc"><i class="tcdv__thumb"></i><i class="tcdv__rt"></i></span>
            <span class="tcdv__rowc"><i class="tcdv__thumb"></i><i class="tcdv__rt"></i></span>
          </div>
        </DisenoCard>

        {/* 5 · Card de archivo (categoría/etiqueta) */}
        <DisenoCard {...disenos[5]}>
          <div class="tcdv tcdv--archive" role="img" aria-label="La misma tarjeta reutilizada en una página de archivo por categoría o etiqueta">
            <span class="tcdv__crumb">/blog/categoria/guias</span>
            <span class="tcdv__grid"><i></i><i></i></span>
          </div>
        </DisenoCard>
      </GaleriaDisenos>
    </div>
  </section>

  {/* ── 3c) RESPONSIVE Y MÓVIL ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Responsive y móvil"
        title="Cómo se comporta en el teléfono"
        desc="En móvil la rejilla pasa a una columna y la tarjeta ocupa el ancho; la imagen mantiene su proporción sin deformar y toda la card es táctil, con el CTA cómodo de tocar."
        body={[
          'En escritorio las tarjetas se reparten en dos (o, en el catálogo sin sidebar, tres o cuatro) por fila. En el teléfono no hay ancho para varias columnas, así que la rejilla cae a una sola y cada tarjeta ocupa todo el ancho. La pieza no cambia: solo cuántas caben por fila, controlado por media queries —mobile-first—.',
          'A partir de ahí, tres patrones que la tarjeta ya trae: la rejilla que crece de 1 a 2/3 columnas, la imagen fluida en 16:10 que recorta sin estirar (con width/height para cero CLS) y el área táctil —título y CTA al mismo destino, botón de al menos 44 px—. Cada uno, abajo, con su vista en el teléfono y su receta.',
        ]}
      />

      <div class="pats">
        {/* 1 · Rejilla 1→2→(2/3) columnas */}
        <article class="pat">
          <div class="pat__demo">
            <MarcoMovil ariaLabel="En móvil las tarjetas se apilan en una sola columna">
              <div class="tcdm">
                <span class="tcdm__card"><b class="tcdm__img"></b><i></i><i class="tcdm__s"></i></span>
                <span class="tcdm__card"><b class="tcdm__img"></b><i></i><i class="tcdm__s"></i></span>
              </div>
            </MarcoMovil>
          </div>
          <div class="pat__info">
            <h3 class="pat__title">1 · Rejilla que crece (mobile-first)</h3>
            <p class="pat__desc">El grid arranca en <code>1fr</code> y suma columnas al ganar ancho: 2 en pantallas medianas, 2–3 en escritorio según haya sidebar. La tarjeta es la misma; solo cambia cuántas caben por fila. El listado se apila limpio en el teléfono sin tocar el componente.</p>
            <Receta titulo="CSS · la rejilla 1→2→(2/3) columnas" lang="css" code={recetaRejilla} />
          </div>
        </article>

        {/* 2 · Imagen fluida 16:10 */}
        <article class="pat">
          <div class="pat__demo">
            <MarcoMovil ariaLabel="La imagen mantiene su proporción 16:10 sin deformarse">
              <div class="tcdm">
                <span class="tcdm__card tcdm__card--one">
                  <b class="tcdm__img"><small>16:10</small></b>
                  <i></i><i class="tcdm__s"></i>
                </span>
              </div>
            </MarcoMovil>
          </div>
          <div class="pat__info">
            <h3 class="pat__title">2 · Imagen fluida sin deformar (16:10)</h3>
            <p class="pat__desc">La caja fija la proporción con <code>aspect-ratio: 16 / 10</code> y <code>object-fit: cover</code> recorta sin estirar: da igual el tamaño real de la foto, la card no se descuadra. Los <code>width</code>/<code>height</code> del <code>&lt;img&gt;</code> reservan el hueco antes de cargar — cero CLS.</p>
            <Receta titulo="CSS · imagen fluida 16:10" lang="css" code={recetaFluida} />
          </div>
        </article>

        {/* 3 · Área táctil */}
        <article class="pat">
          <div class="pat__demo">
            <MarcoMovil ariaLabel="Toda la tarjeta es táctil y el CTA mide al menos 44 píxeles">
              <div class="tcdm">
                <span class="tcdm__card tcdm__card--one">
                  <b class="tcdm__img"></b><i></i>
                  <span class="tcdm__cta">Leer artículo</span>
                </span>
                <span class="tcdm__ruler" aria-hidden="true">44px</span>
              </div>
            </MarcoMovil>
          </div>
          <div class="pat__info">
            <h3 class="pat__title">3 · Área táctil cómoda (CTA ≥44 px)</h3>
            <p class="pat__desc">En el teléfono se toca con el dedo: el título y el CTA llevan al mismo destino, y el botón «Leer artículo» mide al menos 44 px de alto —el objetivo táctil recomendado—. Evita toques fallidos y respeta las pautas de accesibilidad, sin agrandar el resto de la card.</p>
            <Receta titulo="CSS · objetivo táctil 44px" lang="css" code={recetaTactil} />
          </div>
        </article>
      </div>
    </div>
  </section>

  {/* ── 4) ¿DÓNDE VA? ── */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Posición"
        title="¿Dónde se coloca?"
        desc="Dentro de la rejilla del listado, una por artículo, en la columna de contenido —no en el sidebar—. Aparece en /blog, en /blog/pagina/<n> y en los archivos de categoría y etiqueta."
        body={[
          'La tarjeta vive en la rejilla del listado, dentro de BlogListing: una por artículo de la página actual, en la columna principal (a la izquierda del sidebar). Es la unidad que se repite; la rejilla decide cuántas por fila y la paginación, cuántas por página. No se usa suelta ni en el chrome: siempre en una rejilla de contenido.',
          'Y se reutiliza tal cual en cada vista de listado: la página 1 (/blog), las paginadas (/blog/pagina/<n>) y los archivos por categoría (/blog/categoria/<cat>) y etiqueta (/blog/tag/<tag>). En todas es la misma CategoryCard con los mismos datos del artículo, así que el blog entero se ve coherente sin escribir layout nuevo por sección.',
        ]}
      />
      <p class="rl">Piezas cercanas: <a href="/blog/anatomia/archivo-categoria">el archivo de categoría</a> (reusa esta tarjeta filtrada por tema), <a href="/blog/anatomia/paginacion">la paginación</a> (cómo se parte la rejilla de tarjetas) y <a href="/modulos/category-card">la card del catálogo</a> (la misma pieza en la vitrina de productos).</p>
    </div>
  </section>

  {/* ── 5) CÓMO SE ARMA ── */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Implementación"
        title="Cómo está construida"
        desc="No es una pieza nueva: es CategoryCard (presentacional) alimentada desde BlogListing con los datos de cada artículo y una imagen estable del pool. El componente solo pinta lo que recibe."
        body={[
          'El componente vive en CategoryCard.astro y expone una API pequeña a propósito: label, href, image, imageAlt, badge, blurb, subcategories, ctaLabel e index. No sabe nada del blog —no llama a getCollection ni inventa datos—: solo recorre las props y pinta la tarjeta. Esa separación es justo lo que permite reusarla igual en el catálogo y en el blog.',
          'El trabajo de datos vive en BlogListing, no en el componente. Recorre los artículos de la página y, por cada uno, mapea sus campos a las props: el título a label y al H3, /blog/<id> a href, la description a blurb, la categoría legible (CAT_LABEL) al badge y blogImage(id) a la imagen del pool. El index marca la prioridad de carga —las cuatro primeras eager, el resto lazy—.',
        ]}
      />

      <div class="recetas">
        <Receta titulo="Astro · uso desde BlogListing (articulos.map → CategoryCard)" lang="astro" code={recetaUso} />
        <Receta titulo="TypeScript · la imagen del pool (blogImage)" lang="ts" code={recetaImagen} />
        <Receta titulo="TypeScript · la interface Props de CategoryCard" lang="ts" code={recetaProps} />
      </div>

      <div class="prose">
        <p>
          En concreto: la imagen solo se pinta si llega <code>image</code>; si no, la tarjeta omite el
          bloque visual y el badge pasa al cuerpo (<code>inline</code>, sobre el título), de modo que un
          artículo sin foto no deja un hueco roto. El <code>alt</code> cae a <code>label</code> cuando no se
          pasa <code>imageAlt</code>, y los <code>width</code>/<code>height</code> del <code>&lt;img&gt;</code>
          van fijos para reservar el hueco —cero CLS—.
        </p>
        <p>
          La prioridad de carga sale del <code>index</code>: <code>eager = index &lt; 4</code>, así las cuatro
          primeras (las que se ven al entrar) cargan sin <code>lazy</code> y el resto se difiere. El CTA es un
          <code>&lt;a href&gt;</code> al fondo (<code>margin-top: auto</code>) para que todas las tarjetas de la
          rejilla cierren a la misma altura. Cero JavaScript: es HTML + CSS estático generado en build.
        </p>
      </div>
    </div>
  </section>

  {/* ── 6) BUENAS PRÁCTICAS ── */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Buenas prácticas"
        title="Qué hacer y qué evitar"
        desc="La diferencia entre una tarjeta que ayuda y una que estorba cabe en un puñado de hábitos —empezando por reutilizar CategoryCard en vez de inventar una card propia—."
        body={[
          'Ninguno de estos hábitos es capricho: salen de mirar dónde tropieza un listado cuando las tarjetas se diseñan a la ligera. Una tarjeta sana reutiliza la pieza del catálogo, conserva sus dimensiones para no provocar saltos, carga las imágenes por prioridad y cierra con un solo CTA. Una que estorba duplica diseño, quita el width/height o llena la card de botones.',
          'La buena noticia es que casi todo se sostiene solo cuando la tarjeta es CategoryCard y los datos salen del frontmatter del artículo. Abajo, lo que conviene y lo que conviene evitar, enfrentados.',
        ]}
      />
      <div class="dodont">
        <article class="dd dd--si">
          <h3 class="dd__title"><span class="dd__icon" aria-hidden="true">✓</span> Sí conviene</h3>
          <ul class="dd__list">{sis.map((s) => <li>{s}</li>)}</ul>
        </article>
        <article class="dd dd--no">
          <h3 class="dd__title"><span class="dd__icon" aria-hidden="true">✕</span> Mejor evita</h3>
          <ul class="dd__list">{nos.map((s) => <li>{s}</li>)}</ul>
        </article>
      </div>
    </div>
  </section>

  {/* Cierre */}
  <SectionMenu items={cierreItems} cta={cierreCta} ariaLabel="Sigue explorando" />
</PageLayout>

<style>
  /* Utilidades estructurales (tokens.css = fuente única; scoped por página). */
  .container { max-width: var(--container-max); margin-inline: auto; padding-inline: var(--container-px); }
  .section { padding: var(--sp-8) 0; }
  .section--surface { background: var(--c-surface); }
  @media (min-width: 768px) { .section { padding: var(--sp-10) 0; } }

  /* Related-links inline · interlinking natural entre páginas. */
  .rl { margin: var(--sp-5) 0 0; font-size: var(--text-sm); color: var(--c-ink-2); line-height: var(--leading-relaxed); }
  .rl a { color: var(--c-primary); text-decoration: underline; text-underline-offset: 2px; }
  .rl a:hover { color: var(--c-primary-dark); }

  /* ── Beneficios ── */
  .bene { display: grid; grid-template-columns: 1fr; gap: var(--sp-4); margin-top: var(--sp-6); }
  @media (min-width: 768px) { .bene { grid-template-columns: repeat(3, 1fr); } }
  .bene__card { background: var(--c-white); border: 1px solid var(--c-border); border-radius: var(--radius-md); padding: var(--sp-5); }
  .bene__title { margin: 0 0 var(--sp-2); font-family: var(--font-heading); font-size: var(--text-lg); font-weight: var(--weight-semibold); color: var(--c-ink); }
  .bene__desc { margin: 0; font-size: var(--text-sm); line-height: var(--leading-relaxed); color: var(--c-ink-2); }

  /* ── Ejemplo en vivo de la tarjeta (réplica a escala de CategoryCard) ── */
  .tcdx { display: flex; justify-content: center; margin-top: var(--sp-6); }
  .tcdx__card {
    width: 100%; max-width: 22rem;
    display: flex; flex-direction: column;
    background: var(--c-white); border: 1px solid var(--c-border);
    border-radius: var(--radius-lg); overflow: hidden;
  }
  .tcdx__media {
    position: relative; aspect-ratio: 16 / 10;
    background: linear-gradient(135deg, var(--c-surface) 0%, var(--c-border) 100%);
  }
  .tcdx__badge {
    position: absolute; top: var(--sp-3); left: var(--sp-3);
    display: inline-flex; align-items: center; gap: 6px;
    font-size: var(--text-xs); font-weight: var(--weight-bold);
    letter-spacing: .04em; text-transform: uppercase; color: #fff;
    background: var(--c-primary); padding: .25em .6em; border-radius: var(--radius-sm);
  }
  .tcdx__body { display: flex; flex-direction: column; gap: var(--sp-3); padding: var(--sp-5); }
  .tcdx__title { position: relative; font-family: var(--font-heading); font-size: var(--text-lg); font-weight: var(--weight-semibold); line-height: var(--leading-snug); color: var(--c-ink); padding-left: 26px; }
  .tcdx__blurb { position: relative; font-size: var(--text-sm); line-height: var(--leading-normal); color: var(--c-ink-2); padding-left: 26px; }
  .tcdx__line { height: 8px; width: 55%; border-radius: 4px; background: var(--c-surface); }
  .tcdx__cta {
    position: relative; align-self: flex-start; margin-top: var(--sp-2); padding: .6em 1.1em .6em calc(1.1em + 22px);
    font-family: var(--font-heading); font-weight: var(--weight-semibold); font-size: var(--text-sm);
    color: #fff; background: var(--c-primary); border-radius: var(--radius-md);
  }
  /* Pines numerados del ejemplo en vivo. */
  .tcdx__n {
    display: inline-grid; place-items: center; width: 18px; height: 18px;
    border-radius: var(--radius-full); background: var(--c-primary); color: #fff;
    font-family: var(--font-heading); font-weight: var(--weight-bold); font-size: .6875rem;
  }
  .tcdx__n--media { position: absolute; top: 8px; right: 8px; background: var(--c-ink); }
  .tcdx__n--badge { width: 15px; height: 15px; background: #fff; color: var(--c-primary); }
  .tcdx__n--mid { position: absolute; left: 0; top: 0; }
  .tcdx__n--cta { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); background: #fff; color: var(--c-primary); }

  /* ── Cards de las 5 partes ── */
  .partes { display: grid; grid-template-columns: 1fr; gap: var(--sp-4); margin-top: var(--sp-6); }
  @media (min-width: 600px) { .partes { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) { .partes { grid-template-columns: repeat(3, 1fr); } }
  .parte { display: flex; gap: var(--sp-3); align-items: start; background: var(--c-white); border: 1px solid var(--c-border); border-radius: var(--radius-md); padding: var(--sp-4); }
  .parte__num { flex-shrink: 0; display: inline-grid; place-items: center; width: 26px; height: 26px; border-radius: var(--radius-full); background: var(--c-primary); color: #fff; font-family: var(--font-heading); font-weight: var(--weight-bold); font-size: var(--text-sm); }
  .parte__body { display: grid; gap: 4px; min-width: 0; }
  .parte__nombre { margin: 0; font-family: var(--font-heading); font-size: var(--text-base); font-weight: var(--weight-semibold); color: var(--c-ink); }
  .parte__que { margin: 0; font-size: var(--text-sm); line-height: var(--leading-normal); color: var(--c-ink-2); }
  .parte__dato { margin: 4px 0 0; display: flex; align-items: center; gap: var(--sp-2); flex-wrap: wrap; font-size: var(--text-xs); color: var(--c-muted); }
  .parte__dato span { text-transform: uppercase; letter-spacing: .06em; font-weight: var(--weight-semibold); }
  .parte__dato code, .prose code, .pat__desc code {
    font-family: ui-monospace, 'SFMono-Regular', 'Menlo', monospace; font-size: .85em;
    background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--radius-sm);
    padding: .05em .4em; color: var(--c-primary-dark);
  }

  /* ── Recetas «Cómo se arma» ── */
  .recetas { display: grid; gap: var(--sp-4); margin-top: var(--sp-6); }

  /* ── Prose técnica ── */
  .prose { max-width: 75ch; margin-top: var(--sp-6); }
  .prose p { margin: 0 0 var(--sp-4); font-size: var(--text-base); line-height: var(--leading-relaxed); color: var(--c-ink-2); }
  .prose strong { color: var(--c-ink); font-weight: var(--weight-semibold); }

  /* ── Sí / No ── */
  .dodont { display: grid; grid-template-columns: 1fr; gap: var(--sp-4); margin-top: var(--sp-6); }
  @media (min-width: 768px) { .dodont { grid-template-columns: 1fr 1fr; } }
  .dd { background: var(--c-white); border: 1px solid var(--c-border); border-radius: var(--radius-md); padding: var(--sp-5); }
  .dd__title { margin: 0 0 var(--sp-3); display: flex; align-items: center; gap: var(--sp-2); font-family: var(--font-heading); font-size: var(--text-lg); font-weight: var(--weight-semibold); color: var(--c-ink); }
  .dd__icon { display: inline-grid; place-items: center; width: 24px; height: 24px; border-radius: var(--radius-full); font-size: var(--text-sm); }
  .dd--si .dd__icon { background: rgba(34,197,94,.14); color: #16a34a; }
  .dd--no .dd__icon { background: rgba(239,68,68,.12); color: #dc2626; }
  .dd__list { margin: 0; padding: 0; list-style: none; display: grid; gap: var(--sp-2); }
  .dd__list li { position: relative; padding-left: var(--sp-5); font-size: var(--text-sm); line-height: var(--leading-normal); color: var(--c-ink-2); }
  .dd__list li::before { content: ''; position: absolute; left: 0; top: .55em; width: 6px; height: 6px; border-radius: var(--radius-full); background: var(--c-muted); }

  /* ── Mockups de variantes (dentro de <GaleriaDisenos>) ── */
  .tcdv {
    display: flex; flex-direction: column; gap: 6px; width: 100%; min-height: 150px;
    padding: 8px; background: var(--c-white); border: 1px solid var(--c-border); border-radius: var(--radius-md);
  }
  .tcdv__img { position: relative; aspect-ratio: 16 / 10; border-radius: var(--radius-sm); background: var(--c-surface); border: 1px solid var(--c-border); }
  .tcdv__b { position: absolute; top: 5px; left: 5px; width: 28px; height: 9px; border-radius: 3px; background: var(--c-primary); }
  .tcdv__t { height: 11px; width: 85%; border-radius: 4px; background: var(--c-ink); opacity: .8; }
  .tcdv__d { height: 7px; border-radius: 4px; background: var(--c-surface); }
  .tcdv__d--s { width: 60%; }
  .tcdv__cta { margin-top: auto; align-self: flex-start; width: 56px; height: 16px; border-radius: var(--radius-sm); background: var(--c-primary); }
  /* sin imagen: chip de badge inline */
  .tcdv__chip { align-self: flex-start; width: 40px; height: 13px; border-radius: var(--radius-full); background: var(--c-surface); border: 1px solid var(--c-border); }
  /* con chips de subcategorías */
  .tcdv__chips { display: flex; gap: 4px; }
  .tcdv__chips i { width: 26px; height: 12px; border-radius: var(--radius-full); background: var(--c-surface); border: 1px solid var(--c-border); }
  /* destacada */
  .tcdv__img--feat { aspect-ratio: 16 / 8; }
  .tcdv__prio { position: absolute; top: 5px; right: 5px; font-style: normal; font-size: 8px; font-weight: 700; color: #fff; background: var(--c-ink); border-radius: 3px; padding: 1px 5px; }
  .tcdv__t--feat { height: 14px; width: 95%; }
  /* compacta: lista densa con miniatura */
  .tcdv--compact { gap: 6px; justify-content: flex-start; }
  .tcdv__rowc { display: flex; align-items: center; gap: 6px; padding: 5px; background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--radius-sm); }
  .tcdv__thumb { flex: 0 0 34px; height: 24px; border-radius: 4px; background: var(--c-white); border: 1px solid var(--c-border); }
  .tcdv__rt { flex: 1; height: 9px; border-radius: 4px; background: var(--c-white); border: 1px solid var(--c-border); }
  /* card de archivo */
  .tcdv--archive { justify-content: flex-start; gap: 8px; }
  .tcdv__crumb { font-size: 9px; font-family: ui-monospace, Menlo, monospace; color: var(--c-muted); background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--radius-sm); padding: 3px 7px; align-self: flex-start; }
  .tcdv__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .tcdv__grid i { aspect-ratio: 16 / 11; border-radius: var(--radius-sm); background: var(--c-surface); border: 1px solid var(--c-border); }

  /* ── Sección Responsive: teléfono | explicación + receta ── */
  .pats { display: grid; gap: var(--sp-8); margin-top: var(--sp-6); }
  .pat { display: grid; grid-template-columns: 1fr; gap: var(--sp-5); align-items: center; }
  @media (min-width: 900px) { .pat { grid-template-columns: 254px 1fr; gap: var(--sp-6); } }
  .pat__title { margin: 0 0 var(--sp-2); font-family: var(--font-heading); font-size: var(--text-lg); font-weight: var(--weight-semibold); color: var(--c-ink); }
  .pat__desc { margin: 0 0 var(--sp-4); font-size: var(--text-sm); line-height: var(--leading-relaxed); color: var(--c-ink-2); }

  /* ── Mockups MÓVIL (dentro de <MarcoMovil>) ── */
  .tcdm { padding: 10px; display: grid; gap: 10px; }
  .tcdm__card { display: grid; gap: 6px; padding: 8px; background: var(--c-white); border: 1px solid var(--c-border); border-radius: 8px; }
  .tcdm__card--one { margin: 0 auto; width: 86%; }
  .tcdm__img { position: relative; aspect-ratio: 16 / 10; border-radius: 6px; background: var(--c-surface); }
  .tcdm__img small { position: absolute; inset: 0; display: grid; place-items: center; font-size: 9px; font-weight: 700; color: var(--c-muted); }
  .tcdm__card i { height: 8px; border-radius: 4px; background: var(--c-surface); }
  .tcdm__card .tcdm__s { width: 60%; }
  .tcdm__cta { margin-top: 2px; padding: 8px 10px; text-align: center; font-size: 10px; font-weight: var(--weight-semibold); color: #fff; background: var(--c-primary); border-radius: 6px; }
  .tcdm__ruler { justify-self: center; font-size: 9px; font-weight: 700; color: var(--c-primary); background: var(--c-surface); border: 1px solid var(--c-border); border-radius: 4px; padding: 1px 6px; }
</style>
