---
// ============================================================================
// index.astro — HOME del SITIO PLANTILLA (modo guía), auto-documentada.
// ----------------------------------------------------------------------------
// DOBLE FUNCIÓN: es una home demo real de un negocio genérico Y, a la vez, una
// guía — cada bloque lleva una <GuiaNota> que dice qué hace y dónde editarlo.
// Base: pagina-home.astro del vault (orquestador limpio, pageType="home").
// Cero datos de negocio hardcodeados: todo sale de src/config/site.ts y de las
// Content Collections. Importaciones con alias @ (tsconfig + astro.config).
// ============================================================================
import PageLayout from "@layouts/PageLayout.astro";
import Hero from "@components/Hero.astro";
import SectionMenu from "@components/SectionMenu.astro";
import SectionHeading from "@components/SectionHeading.astro";
import CategoryCard from "@components/CategoryCard.astro";
import ReviewCard from "@components/ReviewCard.astro";
import CategoryDetail from "@components/CategoryDetail.astro";
import CompanyAbout from "@components/CompanyAbout.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import ContactForm from "@components/ContactForm.astro";
import GuiaNota from "@components/GuiaNota.astro";
import MarcoMovil from "@components/MarcoMovil.astro";
import Receta from "@components/Receta.astro";
import { SITE, KEYWORDS, NAV, SERVICES, WA_MESSAGES, MODULOS, waUrl } from "@config/site";
import { MODULE_CARD_META, MODULE_AFONDO, moduleGallery } from "@lib/modules";
import { buildKeywordTitle, buildKeywordDescription, metaAudit } from "@lib/seo";

// ── WhatsApp: SIEMPRE vía waUrl() (regla D4, nunca número hardcodeado) ──
const waLink = waUrl();

// ── Módulos REALES del sitio (SSoT: MODULOS en site.ts). La vitrina «el sistema»
//    de la home muestra los 'listo'; cada card enlaza a su página /modulos/<slug>.
//    Misma fuente que el dropdown del header y el índice /modulos → coherencia. ──
const modulosHome = MODULOS.filter((m) => m.estado === "listo");

// ── Recetas de la sección «Responsive y móvil» — strings reales del sistema
//    (extraídos de src/styles/mobile.css y tokens.css). Los pinta <Receta>. ──
const recetaBreakpoints = `/* tokens.css · ancho fluido + breakpoints unificados.
   En ≤768 el container pasa a 100%: el ÚNICO margen lo da
   --container-px (antes 90% + padding = gutter DOBLE en móvil). */
@media (max-width: 768px) {
  :root { --container-max: 100%; }
}
@media (max-width: 640px) {
  :root { --header-height: 58px; --topbar-height: 34px; }
}
/* Escala canónica de cortes: 1024 · 768 · 640 · 480 · 380 */`;

const recetaTouch = `/* mobile.css · área táctil mínima 44px (Apple HIG · WCAG 2.5.5). */
@media (max-width: 1024px) {
  .mob-direct, .mob-item__trigger { min-height: 48px; }
  .mob-item__link { min-height: 44px; display: flex; align-items: center; }
  a, button, label { -webkit-tap-highlight-color: rgba(91, 61, 245, .15); }
}`;

const recetaInputs = `/* mobile.css · formularios sin zoom en iOS.
   Safari hace zoom si el campo mide < 16px → forzamos 16px. */
@media (max-width: 640px) {
  .cform input, .cform textarea, .cform select {
    font-size: 16px;       /* clave anti-zoom */
    min-height: 48px;
  }
  .cform__submit { width: 100%; min-height: 50px; }
}`;

const recetaSafeArea = `/* mobile.css · respeta el notch/gestos iOS y ancla el FAB.
   El <meta viewport> ya incluye viewport-fit=cover. */
@supports (padding: max(0px)) {
  @media (max-width: 768px) {
    .container {
      padding-left:  max(var(--container-px), env(safe-area-inset-left));
      padding-right: max(var(--container-px), env(safe-area-inset-right));
    }
  }
}
@media (max-width: 640px) {
  .wa-float {            /* botón flotante de WhatsApp */
    width: 52px; height: 52px;
    bottom: max(1rem, env(safe-area-inset-bottom));
    right:  max(1rem, env(safe-area-inset-right));
  }
}`;

// ── Demo de la regla de metas (keyword-first) — se alimenta de KEYWORDS ──
// Reproduce la generación real del <title> y la description de la home para
// mostrarla en vivo, más un contra-ejemplo que la misma regla detecta.
const metaTitle = buildKeywordTitle(KEYWORDS);
const metaDesc = buildKeywordDescription(KEYWORDS, SITE.seo.description);
const metaOk = metaAudit(KEYWORDS, metaTitle, metaDesc);
const kwLabels = ["kw1 · principal", "kw2 · secundaria", "kw3 · variante"] as const;

const malTitle = `Plantilla web astro | diseño web astro | página web astro | ${SITE.name}`;
const malDesc =
  "Plantilla web astro: la mejor plantilla web astro. Diseño web astro y página web astro. Plantilla web astro para todo tu sitio web astro.";
const metaMal = metaAudit(KEYWORDS, malTitle, malDesc);

// El bloque «categorías a fondo» de la home muestra ahora los MISMOS 15 módulos
// que la vitrina de arriba (no las 4 categorías del catálogo): el copy vive en
// MODULE_AFONDO y la galería en moduleGallery() (src/lib/modules.ts, SSoT),
// compartidos con el índice /modulos.

// ── Sobre la empresa (módulo de confianza: qué/cómo + cifras) ──
// Contenido DEMO de la plantilla-guía. En un sitio real: cifras REALES (nunca
// inventadas, regla del sistema) y datos del negocio desde site.ts.
const empresa = {
  eyebrow: "La empresa",
  title: "Qué hacemos y cómo lo hacemos",
  lead: "El bloque que cuenta quién está detrás del negocio: a qué se dedica, cómo trabaja y por qué se puede confiar en él. Es de los más decisivos de la página —la gente le compra a quien entiende y le da confianza—.",
  body: [
    "Es el bloque donde el negocio deja de ser una marca anónima y se vuelve alguien con nombre, trayectoria y forma de trabajar. Antes de pedir precio o agendar, la gente quiere saber con quién trata: aquí se lo dices en tres movimientos —qué haces, cómo lo haces y con qué lo respaldas— para que la decisión deje de ser un salto al vacío.",
    "Lo que convierte es la concreción: años en el oficio, proyectos entregados, tiempos reales, garantías que se pueden verificar —contados con voz de persona, no de folleto corporativo—. Es el contenido de experiencia y confianza que sostiene tu reputación dentro y fuera del sitio. Redáctalo una vez, con datos reales, y tendrás el argumento que más pesa cuando alguien duda entre tú y la competencia.",
  ],
  que: {
    title: "Qué hacemos",
    body: [
      "Aquí va, en lenguaje claro y sin tecnicismos, a qué se dedica el negocio y para quién: el producto o servicio principal, el problema que resuelve y el tipo de cliente al que sirve. Dos o tres frases bastan para que cualquiera entienda en segundos qué ofreces y si está en el lugar correcto.",
      "Es la base de la confianza: nadie le compra a lo que no entiende. Habla de beneficios concretos, no de una lista de tareas, e incluye con naturalidad la palabra clave de tu actividad.",
    ],
  },
  como: {
    title: "Cómo lo hacemos",
    pillars: [
      { title: "El método", desc: "Resume tu forma de trabajar en pasos claros: cómo entregas, en qué te apoyas y qué te hace distinto del resto." },
      { title: "La prueba", desc: "Respáldalo con hechos —procesos, materiales, tiempos, garantías— en vez de adjetivos vacíos como «los mejores»." },
      { title: "La cercanía", desc: "Habla como una persona, no como un folleto: trato directo, lenguaje claro y solo la promesa que de verdad puedes cumplir." },
    ],
  },
  stats: [
    { value: "+10", label: "años de experiencia" },
    { value: "+500", label: "proyectos entregados" },
    { value: "98%", label: "clientes que repiten" },
    { value: "24 h", label: "tiempo de respuesta" },
  ],
};

// ── Por qué elegirnos (beneficios como cards CategoryCard: foto + badge + texto) ──
// Reusa el MISMO card aprobado del catálogo (CategoryCard), sin componente propio.
// Contenido DEMO: las fotos son AVIF ya optimizadas que reusamos del catálogo.
// En un sitio real: diferenciadores REALES (hechos, no adjetivos) con foto propia.
const beneficios = {
  eyebrow: "Por qué elegirnos",
  title: "Los beneficios: di por qué elegirte",
  desc: "De tres a seis razones concretas —beneficios para el cliente, no adjetivos— que responden, de un vistazo, «¿por qué tú y no otro?». Cada una en el mismo card del catálogo: foto, dato (badge) y una frase que lo respalda.",
  body: [
    "Aquí le das al visitante los motivos para quedarse, sin presumir. Cada tarjeta convierte tu propuesta en algo que se entiende en segundos —qué gana al elegirte, no una lista de lo que haces—. Bien resuelto, es de los bloques que más inclinan la balanza.",
    "Fíjate en los badges de las tarjetas: «Respuesta el mismo día», «Garantía 12 meses», «Sin cargos ocultos». Son datos, y por eso convencen sin necesidad de gritar que eres «el mejor». Reusan el card del catálogo para no inventar diseño; en un sitio real, cambia estas razones y sus fotos por las tuyas.",
  ],
  items: [
    { image: "/images/servicios/soporte-mantenimiento-web-astro.avif", imageAlt: "Atención al cliente con respuesta el mismo día (imagen de ejemplo)", badge: "Respuesta el mismo día", title: "Respuesta el mismo día", desc: "Escríbenos y te contestamos en horas, no en días. Recibes un primer diagnóstico claro y los siguientes pasos desde el primer mensaje, sin filtros ni esperas.", subs: [{ label: "Diagnóstico inicial", href: waLink }, { label: "Sin formularios", href: waLink }, { label: "Seguimiento", href: waLink }] },
    { image: "/images/casos/caso-exito-proyecto-web-astro.avif", imageAlt: "Trabajo terminado y respaldado por garantía por escrito (imagen de ejemplo)", badge: "Garantía 12 meses", title: "Garantía por escrito", desc: "Cada trabajo queda respaldado por una garantía clara y por escrito. Si algo falla dentro del periodo, volvemos y lo resolvemos sin costo ni discusiones.", subs: [{ label: "Por escrito", href: waLink }, { label: "Sin letra chica", href: waLink }, { label: "Sin costo", href: waLink }] },
    { image: "/images/productos/desarrollo-web-astro-profesional.avif", imageAlt: "Cotización detallada y transparente, sin sorpresas (imagen de ejemplo)", badge: "Sin cargos ocultos", title: "Precio transparente", desc: "Recibes una cotización detallada antes de empezar: materiales, mano de obra y tiempos. Lo que acordamos es exactamente lo que pagas, sin extras de última hora.", subs: [{ label: "Cotización detallada", href: waLink }, { label: "Sin anticipos", href: waLink }, { label: "Precio cerrado", href: waLink }] },
    { image: "/images/servicios/consultoria-desarrollo-web-astro.avif", imageAlt: "Asesoría directa, persona a persona, sin intermediarios (imagen de ejemplo)", badge: "Trato 1 a 1", title: "Trato directo", desc: "Hablas siempre con quien hace el trabajo, no con un conmutador. Una sola persona te acompaña de la cotización a la entrega, con comunicación clara en cada paso.", subs: [{ label: "Una sola persona", href: waLink }, { label: "De inicio a fin", href: waLink }, { label: "Comunicación clara", href: waLink }] },
    { image: "/images/productos/sitio-web-rapido-astro.avif", imageAlt: "Resultado de calidad, verificable y bajo norma (imagen de ejemplo)", badge: "100% bajo norma", title: "Calidad comprobada", desc: "Usamos materiales y procesos que cumplen la norma aplicable. Te mostramos evidencia del avance y del resultado para que lo verifiques, no para que confíes a ciegas.", subs: [{ label: "Con evidencia", href: waLink }, { label: "Verificable", href: waLink }, { label: "Materiales certificados", href: waLink }] },
    { image: "/images/zonas/cobertura-desarrollo-web-ciudad-de-mexico.avif", imageAlt: "Cobertura local del servicio en tu zona (imagen de ejemplo)", badge: "Cobertura local", title: "Cobertura local", desc: "Trabajamos en tu área y conocemos sus accesos y tiempos. Llegamos puntuales y damos seguimiento de cerca, con presencia real donde estás.", subs: [{ label: "Tu zona", href: waLink }, { label: "Puntualidad", href: waLink }, { label: "Seguimiento cercano", href: waLink }] },
  ],
};

// ── Reseñas / prueba social (testimonios con ReviewCard) ──
// Contenido DEMO de la plantilla-guía. REGLA DURA: usa reseñas REALES (con
// permiso); NUNCA inventes testimonios para publicarlos. Mezcla empresas y
// personas, y no todas de 5★ (la imperfección da credibilidad).
const resenas = {
  eyebrow: "Reseñas",
  title: "Lo que dicen quienes ya confiaron",
  desc: "Prueba social: testimonios concretos de clientes y negocios. Una cita específica —con nombre y rol— convence más que diez adjetivos sobre ti mismo.",
  body: [
    "La gente confía en la gente. Antes de decidir, tu visitante busca una señal de que alguien como él ya te eligió y le fue bien. Por eso pesa tanto una reseña: una frase concreta —«me entregaron en tres días», «no me cobraron de más»— vale más que cualquier promesa que tú hagas sobre tu propio trabajo.",
    "Para que funcionen tienen que ser creíbles: nombre, rol o negocio, y un detalle específico que solo un cliente verdadero diría. Mezcla voces —empresas y personas— y no las pongas todas en cinco estrellas: una reseña de cuatro da más credibilidad que un muro de dieces. Y la regla que no se negocia: usa reseñas REALES, nunca inventadas.",
  ],
  items: [
    { quote: "Pedí mi sitio un martes y el viernes ya estaba en línea. Lo que más me gustó es que me explicaron cada paso sin tecnicismos. A las dos semanas empecé a recibir pedidos por WhatsApp.", name: "Laura Méndez", role: "Dueña · Ferretería del Centro", rating: 5 },
    { quote: "Llevábamos años con una página que nadie encontraba. Ahora aparecemos en Google cuando buscan en la zona y las llamadas subieron de verdad; no es para presumir, es lo que pasó.", name: "Carlos Rentería", role: "Gerente · Clima Norte", rating: 5 },
    { quote: "Tenía miedo de que me cobraran de más a medio camino. No pasó: el presupuesto que me dieron fue exactamente lo que pagué al final. Eso ya casi no se ve.", name: "Mariana Soto", role: "Cliente particular", rating: 5 },
    { quote: "Trabajo serio y a tiempo. Le pongo cuatro porque al inicio quería más opciones de color, pero en cuanto lo pedí me lo resolvieron sin poner peros.", name: "Jorge Padilla", role: "Fundador · Estudio Raíz", rating: 4 },
    { quote: "Me respondieron una duda un domingo por la tarde. Para mí eso lo dice todo: hay alguien del otro lado a quien de verdad le importa que te vaya bien.", name: "Ana Gutiérrez", role: "Coordinadora · Colegio Sur", rating: 5 },
    { quote: "Soy malo para la tecnología y aun así puedo cambiar fotos y precios yo solo. Me enseñaron y me dejaron una guía corta. Cero depender de alguien para una tontería.", name: "Tomás Herrera", role: "Dueño · Taller Herrera", rating: 5 },
    { quote: "Comparé tres presupuestos. Éste no era el más barato, pero fue el único que se tomó el tiempo de explicarme el porqué de cada cosa. Pagué por confianza y no me arrepiento.", name: "Patricia Ramos", role: "Cliente particular", rating: 5 },
    { quote: "El sitio carga volando aunque la señal del local esté floja. Mis clientes ven el menú al instante; parece poca cosa, pero en hora pico se nota muchísimo.", name: "Diego Fuentes", role: "Socio · Mariscos La Marea", rating: 5 },
  ],
};

// ── Menú de secciones (barra "section nav" bajo el hero) ─────────────────────
// DATA-DRIVEN desde NAV (site.ts) — la MISMA fuente que alimenta el Header. Cada
// botón es una sección principal del sitio; el `sub` resume qué hay dentro. Se
// excluye "Contacto" porque su intención la cubre el CTA. El último botón NO sale
// de NAV: es el CTA de conversión por WhatsApp, armado con waUrl() (regla D4).
// Patrón meseci.com.mx: «el hero presenta, la franja convierte».
const menuSub: Record<string, string> = {
  Productos: "Catálogo del sitio",
  Servicios: "Lo que ofreces",
  Cobertura: "Zonas que atiendes",
  Blog: "Guías y artículos",
};
const menuSecciones = NAV.filter((n) => n.label !== "Contacto").map((n) => ({
  label: n.label,
  href: n.href,
  sub: menuSub[n.label] ?? n.items?.slice(0, 3).map((i) => i.label).join(" · ") ?? "Ver sección",
}));
const menuCta = {
  label: "Cotizar por WhatsApp",
  href: waUrl(WA_MESSAGES.cotizar),
  sub: "Respuesta inmediata",
  external: true,
};

// ── Menú de CIERRE (interlinking) — el MISMO SectionMenu, OTROS datos ──
// Va antes del footer. En vez de NAV (secciones grandes), enlaza a las FICHAS de
// servicio (SERVICES) + Contacto: las páginas internas que el menú del hero no
// toca → enlazado interno sin repetir un solo botón. El CTA usa otra intención de
// WhatsApp (WA_MESSAGES.contacto, no .cotizar). Edita aquí y el cierre se actualiza.
const menuCierreSub: Record<string, string> = {
  consultoria: "Define el alcance",
  implementacion: "Construcción del sitio",
  soporte: "Mejora continua",
};
const menuCierre = [
  ...SERVICES.map((s) => ({
    label: s.label,
    href: `/servicios/${s.id}`,
    sub: menuCierreSub[s.id] ?? "Ver servicio",
  })),
  { label: "Contacto", href: "/contacto", sub: "Hablemos de tu proyecto" },
];
const menuCierreCta = {
  label: "Atención personalizada",
  href: waUrl(WA_MESSAGES.contacto),
  sub: "Te respondemos hoy",
  external: true,
};

// ── Tipos de página del sistema (estado en esta plantilla) ──
const tiposPagina: { nombre: string; estado: "ok" | "next"; nivel: string }[] = [
  { nombre: "Home (esta página)", estado: "ok", nivel: "L1" },
  { nombre: "Categoría (catálogo)", estado: "next", nivel: "L2" },
  { nombre: "Producto (ficha)", estado: "next", nivel: "L4" },
  { nombre: "Servicio (ficha)", estado: "next", nivel: "L4" },
  { nombre: "Artículo de blog", estado: "next", nivel: "L3" },
  { nombre: "Directorio / Zona", estado: "next", nivel: "L3" },
];

// ── FAQ de cliente — dudas sobre el servicio (no sobre la plantilla) ──
// Contenido DEMO: cámbialas por las dudas reales de tu negocio. El <answer>
// admite HTML. Se muestran a la izquierda del módulo FAQ + Formulario.
const faqs: { question: string; answer: string }[] = [
  {
    question: "¿Cuánto tarda y cómo es el proceso?",
    answer:
      "Depende del alcance, pero la mayoría de los sitios quedan en línea en <strong>1 a 2 semanas</strong>. El proceso es simple: definimos lo que necesitas, armamos el contenido, lo revisas y publicamos. En cada paso te decimos qué sigue, sin tecnicismos.",
  },
  {
    question: "¿Cuánto cuesta y cómo cobran?",
    answer:
      "Primero entendemos qué necesitas y te damos una <strong>cotización detallada por escrito</strong>, sin cargos ocultos ni anticipos sorpresa. Lo que acordamos es lo que pagas. Escríbenos por WhatsApp y te pasamos un estimado el mismo día.",
  },
  {
    question: "¿Qué pasa si no tengo logo, textos o fotos?",
    answer:
      "No hay problema: te guiamos. Partimos de lo que tengas y te ayudamos a ordenar textos e imágenes; si falta algo, te decimos exactamente qué y cómo conseguirlo. No necesitas saber de diseño ni de tecnología.",
  },
  {
    question: "¿El sitio es mío? ¿Puedo editarlo yo después?",
    answer:
      "Sí, el sitio es <strong>tuyo</strong>. Lo dejamos listo para que cambies fotos, precios y textos por tu cuenta, y te enseñamos cómo con una guía corta. No quedas atado a nadie para una actualización sencilla.",
  },
  {
    question: "¿Dan garantía y soporte?",
    answer:
      "Sí. Cada trabajo va con <strong>garantía por escrito</strong>: si algo falla dentro del periodo, lo resolvemos sin costo. Y para dudas del día a día, nos escribes por WhatsApp y te respondemos rápido.",
  },
  {
    question: "¿En qué zonas trabajan?",
    answer:
      "Atendemos tu zona y damos seguimiento cercano. Como buena parte del trabajo es digital, también colaboramos a distancia sin problema. Cuéntanos dónde estás y te confirmamos.",
  },
];
---

<PageLayout
  keywords={KEYWORDS}
  pageType="home"
>
  {/* ═══ RIBBON "MODO PLANTILLA" — contexto del sitio + dónde editar ═══ */}
  <div class="ribbon" role="note" aria-label="Aviso de sitio plantilla">
    <div class="container ribbon__inner">
      <span class="ribbon__tag">MODO GUÍA</span>
      <p class="ribbon__text">
        Es una guía, no un sitio de cliente: cada bloque te dice QUÉ poner y DÓNDE
        editarlo. Los datos viven en <code>src/config/site.ts</code>.
      </p>
    </div>
  </div>

  {/* ═══ 1) HERO (guía) — el bloque ENSEÑA qué poner en un hero, con la forma real:
       IZQ = H1 único (title+accent) + subtítulo de apoyo; DER = "qué incluir" y
       "cómo hacerlo". En un sitio real, reemplaza estos textos por los del negocio. */}
  <Hero
    badge="Bloque 1 · Hero"
    title="El Hero: di en una frase qué haces y para"
    accent="quién"
    subtitle="Es lo primero que se ve. Un H1 único con tu propuesta (incluye ahí tu palabra clave principal) y, debajo, una sola línea que la resuma sin tecnicismos."
    descRight={[
      "Qué incluir. El hero es tu primera impresión y solo tienes unos segundos: en ese instante el visitante decide si se queda. Resuélvelo con un H1 único que diga, en lenguaje claro, qué ofreces y para quién —ahí va tu palabra clave principal, sin forzarla—. Debajo, una sola frase de apoyo que sume el beneficio concreto o despeje la duda más común. Cierra con una o dos acciones, la principal primero, para que el siguiente paso sea obvio. El logotipo vive en el Header: aquí manda el mensaje, no la marca.",
      "Cómo redactarlo. Escribe para una persona, no para un buscador: parte de una necesidad real y promete solo lo que puedas demostrar. Cambia los adjetivos por hechos —«entrega en 48 horas» convence más que «súper rápido»— y apóyate en verbos concretos. Léelo en voz alta: si suena a folleto, reescríbelo hasta que suene a alguien que de verdad sabe del tema. Evita varios H1, párrafos eternos, tecnicismos y promesas vagas; cuando dudes, recorta. Todo esto vive en el componente Hero —title, accent, subtitle y descRight—: esto que lees es, justamente, el ejemplo.",
    ]}
  />

  {/* ═══ MENÚ DE SECCIONES — barra "section nav" full-width bajo el hero ═══
       Reemplaza la antigua franja de badges. Botones que copan el ancho con las
       secciones clave del sitio + un CTA de WhatsApp. Es un componente aparte
       (SectionMenu) y se alimenta de `menuSecciones`/`menuCta` (derivados de NAV
       arriba). Va de borde a borde (100% del ancho), con los botones repartidos
       por % a lo largo de todo el viewport (estilo meseci.com.mx). */}
  <SectionMenu items={menuSecciones} cta={menuCta} />

  <section class="band">
    <div class="container">
      <GuiaNota titulo="Componente Hero" archivo="src/components/Hero.astro">
        <p>
          Dos columnas. <strong>Izquierda</strong>: <code>title</code> +
          <code>accent</code> (palabra resaltada) forman el <strong>H1 único</strong>,
          más <code>subtitle</code> como frase de apoyo. <strong>Derecha</strong>:
          <code>descRight[]</code> — aquí esos 2 párrafos te dicen <em>qué incluir</em>
          y <em>cómo hacerlo</em>; en un sitio real, reemplázalos por tu presentación.
          En móvil se apilan bajo el título.
        </p>
        <p>
          Los <code>ctas</code> ya NO viven en el hero: se movieron a la franja de
