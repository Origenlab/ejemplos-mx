// mostrarla en vivo, más un contra-ejemplo que la misma regla detecta.
const metaTitle = buildKeywordTitle(KEYWORDS);
const metaDesc = buildKeywordDescription(KEYWORDS, SITE.seo.description);
const metaOk = metaAudit(KEYWORDS, metaTitle, metaDesc);
const kwLabels = ["kw1 · principal", "kw2 · secundaria", "kw3 · variante"] as const;

const malTitle = `Plantilla web astro | diseño web astro | página web astro | ${SITE.name}`;
const malDesc =
  "Plantilla web astro: la mejor plantilla web astro. Diseño web astro y página web astro. Plantilla web astro para todo tu sitio web astro.";
const metaMal = metaAudit(KEYWORDS, malTitle, malDesc);

