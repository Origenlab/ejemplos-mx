---
// ============================================================================
// index.astro — HOME del SITIO PLANTILLA (modo guía), auto-documentada.
// ----------------------------------------------------------------------------
// DOBLE FUNCIÓN: es una home demo real de un negocio genérico Y, a la vez, una
// guía — cada bloque lleva una <GuiaNota> que dice qué hace y dónde editarlo.
// Base: pagina-home.astro del vault (orquestador limpio, pageType="home").
// Cero datos de negocio hardcodeados: todo sale de src/config/site.ts y de las
// Content Collections. Importaciones con alias @ (tsconfig + astro.config).
// ============================================================================
import PageLayout from "@layouts/PageLayout.astro";
import Hero from "@components/Hero.astro";
import SectionMenu from "@components/SectionMenu.astro";
import SectionHeading from "@components/SectionHeading.astro";
import CategoryCard from "@components/CategoryCard.astro";
import CategoryDetail from "@components/CategoryDetail.astro";
import ProductCard from "@components/ProductCard.astro";
import ServiceCard from "@components/ServiceCard.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import CTABanner from "@components/CTABanner.astro";
import GuiaNota from "@components/GuiaNota.astro";
import { SITE, KEYWORDS, NAV, WA_MESSAGES, SHOWCASE, waUrl } from "@config/site";
import { buildKeywordTitle, buildKeywordDescription, metaAudit } from "@lib/seo";
import { getCollection } from "astro:content";

// ── WhatsApp: SIEMPRE vía waUrl() (regla D4, nunca número hardcodeado) ──
const waLink = waUrl();

// ── Demo de la regla de metas (keyword-first) — se alimenta de KEYWORDS ──
// Reproduce la generación real del <title> y la description de la home para
// mostrarla en vivo, más un contra-ejemplo que la misma regla detecta.
const metaTitle = buildKeywordTitle(KEYWORDS);
const metaDesc = buildKeywordDescription(KEYWORDS, SITE.seo.description);
const metaOk = metaAudit(KEYWORDS, metaTitle, metaDesc);
const kwLabels = ["kw1 · principal", "kw2 · secundaria", "kw3 · variante"] as const;

const malTitle = `Plantilla web astro | diseño web astro | página web astro | ${SITE.name}`;
const malDesc =
  "Plantilla web astro: la mejor plantilla web astro. Diseño web astro y página web astro. Plantilla web astro para todo tu sitio web astro.";
const metaMal = metaAudit(KEYWORDS, malTitle, malDesc);

// ── Catálogo de ejemplo desde Content Collections (filtra borradores) ──
const productos = (await getCollection("productos", ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const servicios = (await getCollection("servicios", ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

// ── Detalle de la PRIMERA categoría (módulo "categoría a fondo" + galería) ──
// Amplía la 1.ª tarjeta del catálogo (SHOWCASE[0]). El título y la imagen
// principal salen de SHOWCASE para no duplicar; los párrafos, los puntos clave y
// la galería se definen aquí, junto al resto del contenido demo de la home.
const cat0 = SHOWCASE[0];
const cat0Detalle = {
  eyebrow: "La categoría a fondo",
  body: [
    "Esta es la primera tarjeta del catálogo vista por dentro. Una buena imagen de categoría no es decoración: es lo primero que mira el visitante y, en menos de un segundo, le confirma si está en el lugar correcto. Por eso conviene una foto real —no un genérico de banco— que muestre el producto o servicio tal como es y que pese poco para no hacer esperar.",
    "El texto alternativo (el atributo alt) es su pareja invisible: describe en una frase qué se ve, con la palabra clave de la categoría incluida con naturalidad. Ayuda a quien navega con lector de pantalla y da contexto a quien, por una conexión lenta, no alcanza a ver la foto. Si además fijas su ancho y alto, el hueco queda reservado y la página no «salta» mientras carga.",
  ],
  points: [
    "Foto real y propia, nunca un genérico de banco de imágenes",
    "Peso optimizado (AVIF/WebP) para que cargue al instante",
    "Texto alternativo descriptivo, con la palabra clave incluida",
    "Ancho y alto fijos para que la maqueta no salte al cargar",
  ],
  gallery: {
    main: { src: cat0.image, alt: "Imagen principal de la categoría, optimizada y con su texto alternativo" },
    thumbs: [
      { src: "/images/showcase/jerarquia-titulos-seo-pagina-web.avif", alt: "Segunda toma de la categoría dentro de la jerarquía de la página" },
      { src: "/images/showcase/texto-venta-contenido-markdown.avif", alt: "Detalle del texto de venta que acompaña a la categoría" },
    ],
  },
};

// ── Menú de secciones (barra "section nav" bajo el hero) ─────────────────────
// DATA-DRIVEN desde NAV (site.ts) — la MISMA fuente que alimenta el Header. Cada
// botón es una sección principal del sitio; el `sub` resume qué hay dentro. Se
// excluye "Contacto" porque su intención la cubre el CTA. El último botón NO sale
// de NAV: es el CTA de conversión por WhatsApp, armado con waUrl() (regla D4).
// Patrón meseci.com.mx: «el hero presenta, la franja convierte».
const menuSub: Record<string, string> = {
  Productos: "Catálogo del sitio",
  Servicios: "Lo que ofreces",
  Cobertura: "Zonas que atiendes",
  Blog: "Guías y artículos",
};
const menuSecciones = NAV.filter((n) => n.label !== "Contacto").map((n) => ({
  label: n.label,
  href: n.href,
  sub: menuSub[n.label] ?? n.items?.slice(0, 3).map((i) => i.label).join(" · ") ?? "Ver sección",
}));
const menuCta = {
  label: "Cotizar por WhatsApp",
  href: waUrl(WA_MESSAGES.cotizar),
  sub: "Respuesta inmediata",
  external: true,
};

// ── Las 7 estaciones de la fábrica de sitios (Selección → Deploy) ──
const estaciones: { paso: string; titulo: string; detalle: string }[] = [
  { paso: "1", titulo: "Selección", detalle: "Defines arquetipo (A/B/C/D) y alcance del sitio." },
  { paso: "2", titulo: "Scaffold", detalle: "Copias el esqueleto y llenas site.ts con datos reales." },
  { paso: "3", titulo: "Contenido", detalle: "Cargas productos, servicios y blog en Content Collections." },
  { paso: "4", titulo: "Metadatos", detalle: "Title, description, JSON-LD por tipo y sitemap por sección." },
  { paso: "5", titulo: "Diseño", detalle: "Ajustas tokens de marca y montas componentes." },
  { paso: "6", titulo: "Imágenes", detalle: "Optimizas a AVIF, nombras por keyword y conectas el CDN." },
  { paso: "7", titulo: "QA + Deploy", detalle: "Checklist en verde y publicación en Cloudflare Pages." },
];

// ── Paleta viva: leen los MISMOS tokens de src/styles/tokens.css ──
const swatches: { varName: string; label: string }[] = [
  { varName: "--c-primary", label: "Primary" },
  { varName: "--c-primary-dark", label: "Primary dark" },
  { varName: "--c-ink", label: "Ink" },
  { varName: "--c-muted", label: "Muted" },
  { varName: "--c-surface", label: "Surface" },
  { varName: "--c-border", label: "Border" },
];

// ── Tipos de página del sistema (estado en esta plantilla) ──
const tiposPagina: { nombre: string; estado: "ok" | "next"; nivel: string }[] = [
  { nombre: "Home (esta página)", estado: "ok", nivel: "L1" },
  { nombre: "Categoría (catálogo)", estado: "next", nivel: "L2" },
  { nombre: "Producto (ficha)", estado: "next", nivel: "L4" },
  { nombre: "Servicio (ficha)", estado: "next", nivel: "L4" },
  { nombre: "Artículo de blog", estado: "next", nivel: "L3" },
  { nombre: "Directorio / Zona", estado: "next", nivel: "L3" },
];

// ── FAQ sobre la plantilla (no sobre un negocio) ──
const faqs: { question: string; answer: string }[] = [
  {
    question: "¿Esto es un sitio de cliente?",
    answer:
      "No. Es una <strong>plantilla-guía</strong>: un sitio dummy de referencia para construir futuros sitios Astro. Los datos (teléfono, dirección, catálogo) son DEMO y se reemplazan en <code>site.ts</code>.",
  },
  {
    question: "¿Dónde edito los textos y los datos?",
    answer:
      "Casi todo vive en <code>src/config/site.ts</code> (identidad, contacto, taxonomía, mensajes de WhatsApp). El catálogo vive en <code>src/content/</code> y la marca (colores, tipografía) en <code>src/styles/tokens.css</code>.",
  },
  {
    question: "¿Cómo agrego una página o un producto?",
    answer:
      "Para catálogo, agrega un Markdown en <code>src/content/productos</code> o <code>src/content/servicios</code> y aparece solo. Para páginas nuevas, crea un <code>.astro</code> en <code>src/pages/</code> usando un layout de <code>src/layouts/</code>.",
  },
  {
    question: "¿Por qué WhatsApp y no un formulario?",
    answer:
      "El sistema prioriza la conversión por WhatsApp: respuesta inmediata, sin fricción y con mensaje pre-armado por intención (<code>WA_MESSAGES</code>). Todos los enlaces se generan con <code>waUrl()</code>.",
  },
  {
    question: "¿Cómo cambio la identidad visual?",
    answer:
      "Edita las variables de <code>src/styles/tokens.css</code> (sobre todo <code>--c-primary</code> y las fuentes). Todo el sitio se reviste solo: es la fuente única de diseño.",
  },
];
---

<PageLayout
  keywords={KEYWORDS}
  pageType="home"
>
  {/* ═══ RIBBON "MODO PLANTILLA" — contexto del sitio + dónde editar ═══ */}
  <div class="ribbon" role="note" aria-label="Aviso de sitio plantilla">
    <div class="container ribbon__inner">
      <span class="ribbon__tag">MODO GUÍA</span>
      <p class="ribbon__text">
        Es una guía, no un sitio de cliente: cada bloque te dice QUÉ poner y DÓNDE
        editarlo. Los datos viven en <code>src/config/site.ts</code>.
      </p>
    </div>
  </div>

  {/* ═══ 1) HERO (guía) — el bloque ENSEÑA qué poner en un hero, con la forma real:
       IZQ = H1 único (title+accent) + subtítulo de apoyo; DER = "qué incluir" y
       "cómo hacerlo". En un sitio real, reemplaza estos textos por los del negocio. */}
  <Hero
    badge="Bloque 1 · Hero"
    title="El Hero: di en una frase qué haces y para"
    accent="quién"
    subtitle="Es lo primero que se ve. Un H1 único con tu propuesta (incluye ahí tu palabra clave principal) y, debajo, una sola línea que la resuma sin tecnicismos."
    descRight={[
      "Qué incluir. El hero es tu primera impresión y solo tienes unos segundos: en ese instante el visitante decide si se queda. Resuélvelo con un H1 único que diga, en lenguaje claro, qué ofreces y para quién —ahí va tu palabra clave principal, sin forzarla—. Debajo, una sola frase de apoyo que sume el beneficio concreto o despeje la duda más común. Cierra con una o dos acciones, la principal primero, para que el siguiente paso sea obvio. El logotipo vive en el Header: aquí manda el mensaje, no la marca.",
      "Cómo redactarlo. Escribe para una persona, no para un buscador: parte de una necesidad real y promete solo lo que puedas demostrar. Cambia los adjetivos por hechos —«entrega en 48 horas» convence más que «súper rápido»— y apóyate en verbos concretos. Léelo en voz alta: si suena a folleto, reescríbelo hasta que suene a alguien que de verdad sabe del tema. Evita varios H1, párrafos eternos, tecnicismos y promesas vagas; cuando dudes, recorta. Todo esto vive en el componente Hero —title, accent, subtitle y descRight—: esto que lees es, justamente, el ejemplo.",
    ]}
  />

  {/* ═══ MENÚ DE SECCIONES — barra "section nav" full-width bajo el hero ═══
       Reemplaza la antigua franja de badges. Botones que copan el ancho con las
       secciones clave del sitio + un CTA de WhatsApp. Es un componente aparte
       (SectionMenu) y se alimenta de `menuSecciones`/`menuCta` (derivados de NAV
       arriba). Va de borde a borde (100% del ancho), con los botones repartidos
       por % a lo largo de todo el viewport (estilo meseci.com.mx). */}
  <SectionMenu items={menuSecciones} cta={menuCta} />

  <section class="band">
    <div class="container">
      <GuiaNota titulo="Componente Hero" archivo="src/components/Hero.astro">
        <p>
          Dos columnas. <strong>Izquierda</strong>: <code>title</code> +
          <code>accent</code> (palabra resaltada) forman el <strong>H1 único</strong>,
          más <code>subtitle</code> como frase de apoyo. <strong>Derecha</strong>:
          <code>descRight[]</code> — aquí esos 2 párrafos te dicen <em>qué incluir</em>
          y <em>cómo hacerlo</em>; en un sitio real, reemplázalos por tu presentación.
          En móvil se apilan bajo el título.
        </p>
        <p>
          Los <code>ctas</code> ya NO viven en el hero: se movieron a la franja de
          abajo (regla canónica «el hero presenta, la franja convierte»). El enlace
          de WhatsApp NO se escribe a mano: se genera con
          <code>waUrl(WA_MESSAGES.cotizar)</code>, que toma el número desde
          <code>CONTACT.whatsapp</code> en <code>site.ts</code> (regla D4).
        </p>
      </GuiaNota>

      <GuiaNota titulo="Componente SectionMenu" archivo="src/components/SectionMenu.astro">
        <p>
          La barra de botones que ves bajo el hero. Va <strong>justo debajo</strong>
          para que el visitante salte a la sección que busca sin volver al Header
          (patrón de sitios de catálogo como <code>meseci.com.mx</code>). Sustituye a
          la antigua franja de “garantías”: en vez de presumir cualidades, ofrece
          <strong>navegación</strong> útil.
        </p>
        <p>
          Es <strong>data-driven</strong>: los botones se generan desde
          <code>NAV</code> en <code>site.ts</code> (la misma fuente del Header), así
          que agregar o quitar una sección actualiza el menú y esta barra a la vez.
          El último botón es el <strong>CTA de conversión</strong> (WhatsApp), armado
          con <code>waUrl(WA_MESSAGES.cotizar)</code> — regla «el hero presenta, la
          franja convierte». Los botones copan el ancho y se apilan en móvil.
        </p>
      </GuiaNota>
    </div>
  </section>

  {/* ═══ 2) EL CATÁLOGO — vitrina de categorías (cards 4 por fila) ═══
       ORDEN CANÓNICO del index: Hero → SectionMenu → cards de secciones. Esta
       vitrina va SIEMPRE justo debajo del menú del hero. Cada categoría se presenta
       como producto: imagen + texto + atajos a subcategorías + CTA. Data-driven
       desde SHOWCASE (site.ts). */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Catálogo"
        title="El catálogo: agrupa tu oferta en categorías"
        desc="Cada tarjeta arma una categoría como si fuera un producto: imagen, título, un texto breve y atajos a las subcategorías. Las cuatro de abajo te muestran, parte por parte, qué poner en cada una y cómo redactarla."
        body={[
          "Aquí tu oferta deja de ser una lista larga y se vuelve un mapa: agrupas lo que vendes en pocas categorías que cualquiera entiende de un vistazo. Cada tarjeta funciona como una mini portada —una imagen real, un título con la palabra que la gente busca y una frase que adelanta qué hay dentro—, así el visitante pasa de «¿qué venden aquí?» a «esto es justo lo que necesito» en segundos. Es la diferencia entre una bodega amontonada y una tienda bien señalizada.",
          "Para que funcione, ordena las categorías como las piensa tu cliente, no como las archivas tú: agrupa por lo que la gente busca, nombra cada una con su término real y mantén el mismo criterio en todo el sitio. Redacta cada tarjeta para una persona —un beneficio concreto, la palabra clave sin forzar y un motivo para confiar— y deja que los atajos a las subcategorías hagan de guía. Bien armado, todos ganan: el visitante encuentra antes y los buscadores entienden tu estructura y llegan a tus páginas internas.",
        ]}
      />
      <div class="showcase">
        {SHOWCASE.map((cat, i) => (
          <CategoryCard
            label={cat.label}
            href={cat.href}
            image={cat.image}
            imageAlt={cat.imageAlt}
            badge={cat.badge}
            blurb={cat.blurb}
            subcategories={cat.subcategories}
            ctaLabel={cat.ctaLabel}
            index={i}
          />
        ))}
      </div>
      <GuiaNota titulo="Componente CategoryCard + datos SHOWCASE" archivo="src/config/site.ts · src/components/CategoryCard.astro">
        <p>
          Estas tarjetas (4 por fila en escritorio) se generan desde
          <code>SHOWCASE</code> en <code>site.ts</code>: una sola lista define
          imagen, título, texto, subcategorías y CTA de cada categoría. Agrega o
          quita una tarjeta ahí y la vitrina se actualiza sola (SSoT).
        </p>
        <p>
          Cada parte cumple una función: <code>imageAlt</code> describe la imagen
          (también para quien no la ve), el título es un <code>&lt;h3&gt;</code>
          (jerarquía H1→H2→H3), el texto une beneficio y palabra clave sin apilar, y
          las <strong>subcategorías son enlaces internos</strong> con texto real que
          llevan a las páginas hijas. En esta demo apuntan a <code>/productos/</code>;
          en un sitio real, cada subcategoría lleva a su propia URL.
        </p>
        <p>
          Aquí, a modo de guía, las 4 tarjetas <strong>enseñan las partes</strong> de
          una categoría (imagen, título, texto, enlaces). En tu sitio real,
          reemplázalas por tus categorías de verdad.
        </p>
      </GuiaNota>

      <GuiaNota titulo="Optimización y tratado de las imágenes (AVIF + SEO)" archivo="public/images/ · src/components/CategoryCard.astro · ProductCard.astro · ServiceCard.astro">
        <p>
          Las fotos no se publican tal cual: pasan por un tratado de rendimiento.
          Cada imagen se exporta a <strong>AVIF</strong> (códec AV1), que a igualdad
          de calidad pesa alrededor de la mitad que un JPEG y bastante menos que un
          WebP. En estas cards el resultado es de <strong>~40–60&nbsp;KB por foto</strong>
          (desde ~800&nbsp;KB de origen, cerca de un <strong>−94%</strong>), con un
          ancho máximo de <code>1280&nbsp;px</code> y sin reescalar hacia arriba: el
          tamaño justo para verse nítida en pantallas retina sin malgastar bytes ni
          castigar el <abbr title="Largest Contentful Paint">LCP</abbr>.
        </p>
        <p>
          La carga también está cuidada. Cada <code>&lt;img&gt;</code> declara
          <code>width</code> y <code>height</code> (relación 16:9), así el navegador
          reserva el hueco y se evita el salto de maquetación
          (<abbr title="Cumulative Layout Shift">CLS</abbr>). Las imágenes usan
          <code>loading="lazy"</code> y <code>decoding="async"</code>, y las primeras
          del catálogo se marcan <code>eager</code> con <code>fetchpriority="high"</code>
          y <code>sizes</code> por ser el recurso LCP de la página.
        </p>
        <p>
          El nombre del archivo es parte del <strong>SEO</strong>: descriptivo y con
          la palabra clave en español separada por guiones —p.&nbsp;ej.
          <code>desarrollo-web-astro-profesional.avif</code>—, que Google Imágenes lee
          como señal de contenido. El <code>alt</code> describe la escena incluyendo la
          keyword (accesibilidad y SEO de imagen, nunca relleno) y al exportar se
          elimina la metadata <code>EXIF</code> (privacidad y unos KB menos).
        </p>
        <p>
          Todo queda ordenado y es <strong>reproducible</strong>: las imágenes viven en
          <code>public/images/&lt;sección&gt;/</code> (showcase, productos, servicios,
          casos, articulos, zonas), espejando la taxonomía del sitio. La receta es un
          solo paso por lote —AVIF calidad ≈50, ancho máx 1280&nbsp;px, metadata
          removida—, de modo que reemplazar una foto real es: exportar con la misma
          receta, nombrar por keyword y apuntar la card. Es, en concreto, el
          <strong>paso 6 «Imágenes»</strong> del flujo de producción de arriba.
        </p>
      </GuiaNota>
    </div>
  </section>

  {/* ═══ 2b) CATEGORÍA A FONDO — detalle de la 1.ª categoría + galería ═══
       Amplía la primera tarjeta del catálogo: 2 columnas (info detallada a la
       izquierda + galería de 1 imagen grande y 2 debajo a la derecha). Componente
       CategoryDetail; los datos se definen arriba (cat0Detalle, desde SHOWCASE[0]). */}
  <section class="section">
    <div class="container">
      <CategoryDetail
        eyebrow={cat0Detalle.eyebrow}
        title={cat0.label}
        body={cat0Detalle.body}
        points={cat0Detalle.points}
        cta={{ label: "Ver la categoría", href: cat0.href }}
        gallery={cat0Detalle.gallery}
      />
      <GuiaNota titulo="Componente CategoryDetail (categoría a fondo)" archivo="src/components/CategoryDetail.astro">
        <p>
          Bloque de <strong>2 columnas</strong> para ampliar UNA categoría: a la
          izquierda la <strong>información detallada</strong> (título, párrafos,
          puntos clave y CTA) y a la derecha una <strong>galería</strong> con una
          imagen grande y dos debajo. Refuerza la categoría o servicio antes de que
          el visitante entre a su página.
        </p>
        <p>
          El título y la imagen principal salen de <code>SHOWCASE[0]</code> (la 1.ª
          tarjeta) para no duplicar datos; los párrafos, los puntos y la galería se
          definen junto al contenido de la home. Es reutilizable: pasa
          <code>reverse</code> para alternar el lado de la galería. En móvil se apila.
        </p>
      </GuiaNota>
    </div>
  </section>

  {/* ═══ 3) CÓMO USAR — las 7 estaciones de la fábrica ═══ */}
  <section class="section">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Flujo de producción"
        title="Cómo se construye un sitio"
        desc="Siete pasos, de definir el alcance hasta publicar. Síguelos en orden: cada paso deja listo el siguiente, así no rehaces trabajo ni se te olvida nada."
        body={[
          "Piénsalo como una línea de montaje, no como una lista que atacas al azar. Cada estación le entrega a la siguiente lo que necesita: defines el alcance antes que el contenido, el contenido antes que los metadatos, el diseño antes que las imágenes. Si te saltas un paso, lo pagas al final —contenido sin estructura, diseño sin nada que vestir—.",
          "El orden también cuida tu tiempo, que casi siempre es el recurso corto. Avanzar en secuencia significa tocar cada archivo una vez y seguir, en vez de regresar a arreglar lo que un paso anterior dejó a medias. Para cuando llegas a QA y deploy ya no hay sorpresas: es una revisión, no un rescate.",
        ]}
      />
      <ol class="estaciones">
        {estaciones.map((e) => (
          <li class="estacion">
            <span class="estacion__num" aria-hidden="true">{e.paso}</span>
            <div class="estacion__body">
              <p class="estacion__titulo">{e.titulo}</p>
              <p class="estacion__detalle">{e.detalle}</p>
            </div>
          </li>
        ))}
      </ol>
      <GuiaNota titulo="Cómo seguir este flujo">
        <p>
          Construye en este orden: Selección → Scaffold → Contenido → Metadatos →
          Diseño → Imágenes → QA → Deploy. Cada etapa prepara la siguiente; saltarte
