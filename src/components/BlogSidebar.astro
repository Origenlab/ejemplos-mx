---
// ============================================================================
// BlogSidebar.astro — Barra lateral del blog (interlinking).
// ----------------------------------------------------------------------------
// QUÉ ES
// Columna secundaria, junto al contenido principal del blog, con bloques de
// navegación ("widgets"): categorías, temas (tags), artículos a destacar,
// accesos al resto del sitio y un CTA. NO es decoración: es el motor de
// ENLAZADO INTERNO de la sección — conecta cada artículo con los archivos de
// categoría/tag y con las páginas de conversión (servicios, productos…).
//
// POR QUÉ ASÍ (SEO + UX):
//   • <aside> con aria-label → landmark secundario, no compite con <main>.
//   • Cada widget es <section> con <h2> → estructura escaneable y semántica.
//   • Enlaces con ANCHOR TEXT real (no "clic aquí") → reparten autoridad y
//     describen el destino. Las categorías/tags llevan conteo (señal de volumen).
//   • Sticky en escritorio → sigue visible al hacer scroll, sin estorbar en móvil
//     (ahí baja DEBAJO del contenido, nunca lo tapa).
//
// DATA-DRIVEN: no inventa nada; pinta lo que /blog le calcula desde la colección
// `articulos` y la config del sitio. Presentacional y reutilizable.
//
// PROPS
//   categorias → [{label, href, count}]  archivos de categoría + nº de artículos.
//   temas      → [{label, href, count}]  tags más usados (nube).
//   posts      → [{label, href}]         artículos a destacar (featured/recientes).
//   enlaces    → [{label, href, desc?}]  accesos al resto del sitio (cross-link).
//   cta        → {label, href}           llamada a la acción (WhatsApp).
// ============================================================================
export interface LinkCount { label: string; href: string; count?: number }
export interface LinkDesc { label: string; href: string; desc?: string }
interface Props {
  categorias?: LinkCount[]
  temas?: LinkCount[]
  posts?: LinkDesc[]
  enlaces?: LinkDesc[]
  cta?: { label: string; href: string } | null
  ariaLabel?: string
}
const {
  categorias = [],
  temas = [],
  posts = [],
  enlaces = [],
  cta = null,
  ariaLabel = 'Explora más del blog',
} = Astro.props
---

<aside class="bsb" aria-label={ariaLabel}>
  {categorias.length > 0 && (
    <section class="bsb__w" aria-labelledby="bsb-cat">
      <h2 class="bsb__h" id="bsb-cat">Categorías</h2>
      <ul class="bsb__list">
        {categorias.map((c) => (
          <li class="bsb__row">
            <a href={c.href}>{c.label}</a>
            {typeof c.count === 'number' && <span class="bsb__count" aria-label={`${c.count} artículos`}>{c.count}</span>}
          </li>
        ))}
      </ul>
    </section>
  )}

  {temas.length > 0 && (
    <section class="bsb__w" aria-labelledby="bsb-tags">
      <h2 class="bsb__h" id="bsb-tags">Temas</h2>
      <ul class="bsb__tags">
        {temas.map((t) => (
          <li>
            <a class="bsb__tag" href={t.href}>
              #{t.label}{typeof t.count === 'number' && <span class="bsb__tagn">{t.count}</span>}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {posts.length > 0 && (
    <section class="bsb__w" aria-labelledby="bsb-posts">
      <h2 class="bsb__h" id="bsb-posts">Lecturas recomendadas</h2>
      <ul class="bsb__posts">
        {posts.map((p) => (
          <li>
            <a class="bsb__post" href={p.href}>
              <span class="bsb__post-title">{p.label}</span>
              {p.desc && <span class="bsb__post-desc">{p.desc}</span>}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {enlaces.length > 0 && (
    <nav class="bsb__w" aria-labelledby="bsb-site">
      <h2 class="bsb__h" id="bsb-site">Explora el sitio</h2>
      <ul class="bsb__posts">
        {enlaces.map((e) => (
          <li>
            <a class="bsb__post" href={e.href}>
              <span class="bsb__post-title">{e.label}</span>
              {e.desc && <span class="bsb__post-desc">{e.desc}</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  {cta && (
    <section class="bsb__w bsb__w--cta" aria-labelledby="bsb-cta">
      <h2 class="bsb__h" id="bsb-cta">¿Te quedó una duda?</h2>
      <p class="bsb__cta-text">Cuéntanos tu caso y te orientamos sin compromiso.</p>
      <a class="bsb__btn" href={cta.href} target="_blank" rel="noopener">{cta.label}</a>
    </section>
  )}
</aside>

<style>
  /* Pila de widgets. El sticky lo aplica el grid de la página en ≥1024. */
  .bsb { display: grid; gap: var(--sp-5); align-content: start; }

  .bsb__w {
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    padding: var(--sp-5);
  }
  .bsb__h {
    margin: 0 0 var(--sp-4);
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--c-ink);
    padding-bottom: var(--sp-3);
    border-bottom: 1px solid var(--c-border);
  }

  /* Lista categorías: nombre + conteo */
  .bsb__list { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--sp-1); }
  .bsb__row { display: flex; align-items: center; justify-content: space-between; gap: var(--sp-2); }
  .bsb__row a {
    color: var(--c-ink-2); text-decoration: none; font-size: var(--text-sm);
    padding: var(--sp-2) 0; flex: 1;
  }
  .bsb__row a:hover, .bsb__row a:focus-visible { color: var(--c-primary); }
  .bsb__count {
    font-size: var(--text-xs); font-weight: var(--weight-bold); color: var(--c-muted);
    background: var(--c-surface); border-radius: var(--radius-full);
    min-width: 1.6em; text-align: center; padding: .15em .5em;
  }

  /* Nube de tags */
  .bsb__tags { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: var(--sp-2); }
  .bsb__tag {
    display: inline-flex; align-items: center; gap: .3em;
    font-size: var(--text-xs); font-weight: var(--weight-medium);
    color: var(--c-ink-2); text-decoration: none;
    background: var(--c-surface);
    border: 1px solid var(--c-border); border-radius: var(--radius-full);
    padding: .35em .75em;
  }
  .bsb__tag:hover, .bsb__tag:focus-visible {
    color: #fff; background: var(--c-primary); border-color: var(--c-primary); outline: none;
  }
  .bsb__tag:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }
  .bsb__tagn { opacity: .7; font-weight: var(--weight-bold); }

  /* Listas de artículos / accesos */
  .bsb__posts { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--sp-1); }
  .bsb__post {
    display: grid; gap: .15em; text-decoration: none;
    padding: var(--sp-2) var(--sp-2); margin-inline: calc(var(--sp-2) * -1);
    border-radius: var(--radius-md);
  }
  .bsb__post:hover, .bsb__post:focus-visible { background: var(--c-surface); outline: none; }
  .bsb__post-title {
    font-size: var(--text-sm); font-weight: var(--weight-medium);
    color: var(--c-ink); line-height: var(--leading-snug);
  }
  .bsb__post:hover .bsb__post-title, .bsb__post:focus-visible .bsb__post-title { color: var(--c-primary); }
  .bsb__post-desc { font-size: var(--text-xs); color: var(--c-muted); line-height: var(--leading-normal); }

  /* CTA */
  .bsb__w--cta { background: var(--c-surface); }
  .bsb__cta-text { margin: 0 0 var(--sp-4); font-size: var(--text-sm); color: var(--c-ink-2); }
  .bsb__btn {
    display: block; text-align: center; text-decoration: none;
    font-family: var(--font-heading); font-weight: var(--weight-semibold); font-size: var(--text-sm);
    color: #fff; background: var(--c-primary);
    padding: .7em 1em; border-radius: var(--radius-md);
    transition: background var(--transition, .15s ease);
  }
  .bsb__btn:hover { background: var(--c-primary-dark); }
  .bsb__btn:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }

  @media (prefers-reduced-motion: reduce) { .bsb__btn { transition: none; } }
</style>
