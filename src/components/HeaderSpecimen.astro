---
// HeaderSpecimen.astro — Réplica ESTÁTICA del Header para la guía de anatomía.
// ============================================================================
// Es una "foto" del header, NO el header real: sin JavaScript y sin los ids de
// panel (navp-*) que usaría el Header real, para no colisionar con él. Decorativa
// (aria-hidden). La usa <GuiaAnatomia> en los slots `specimen` y `demo`.
//
// Props:
//   device → 'desktop' (default) | 'mobile': en móvil colapsa nav + CTA y muestra
//            el botón ☰ (replica el estado < 1024px sin depender del viewport).
//   pins   → muestra los pines numerados (1–4) que mapean a la anatomía.
// ============================================================================
import { SITE } from '@config/site'

export interface Props {
  device?: 'desktop' | 'mobile'
  pins?: boolean
}
const { device = 'desktop', pins = false } = Astro.props

// Labels de muestra (réplica didáctica; el menú real se itera desde NAV).
const NAV_DEMO = ['Productos', 'Servicios', 'Cobertura', 'Blog', 'Contacto']
---

<div class:list={['hspec', { 'is-mobile': device === 'mobile' }]} aria-hidden="true">
  <div class="hspec__inner">
    <span class="hspec__logo">
      {pins && <span class="hspec__pin">1</span>}
      <span class="hspec__mark">{SITE.brand.charAt(0)}</span>
      <span class="hspec__word">{SITE.brand}<span class="hspec__tld">.mx</span></span>
    </span>

    <nav class="hspec__nav">
      {NAV_DEMO.map((label, i) => (
        <span class="hspec__link">
          {pins && i === 0 && <span class="hspec__pin">2</span>}
          {label}
          {i < 3 && (
            <svg class="hspec__chev" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          )}
          {pins && i === 1 && <span class="hspec__pin hspec__pin--chev">3</span>}
        </span>
      ))}
    </nav>

    <span class="hspec__cta">
      {pins && <span class="hspec__pin">4</span>}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
      Cotizar
    </span>

    <span class="hspec__burger" aria-hidden="true"><span></span><span></span><span></span></span>
  </div>
</div>

<style>
  .hspec { background: var(--c-white); border: 1px solid var(--c-border); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); min-width: 0; }
  .hspec__inner { display: flex; align-items: center; gap: var(--sp-4); height: 56px; padding-inline: var(--sp-4); }

  .hspec__logo { display: inline-flex; align-items: center; gap: .5rem; position: relative; flex-shrink: 0; }
  .hspec__mark { display: grid; place-items: center; width: 32px; height: 32px; border-radius: 9px; background: var(--c-primary); color: #fff; font-family: var(--font-heading); font-weight: var(--weight-black); font-size: 1.05rem; line-height: 1; }
  .hspec__word { font-family: var(--font-heading); font-weight: var(--weight-black); font-size: 1.1rem; letter-spacing: -.01em; color: var(--c-ink); line-height: 1; }
  .hspec__tld { color: var(--c-primary); }

  .hspec__nav { display: flex; align-items: center; gap: var(--sp-4); margin-left: auto; min-width: 0; }
  .hspec__link { display: inline-flex; align-items: center; gap: .2rem; position: relative; font-size: var(--text-sm); font-weight: var(--weight-medium); color: var(--c-ink-2); white-space: nowrap; }
  .hspec__chev { opacity: .5; flex-shrink: 0; }

  .hspec__cta { display: inline-flex; align-items: center; gap: .4rem; flex-shrink: 0; padding: .5rem 1rem; background: var(--c-primary); color: #fff; font-size: var(--text-sm); font-weight: var(--weight-semibold); border-radius: var(--radius-md); position: relative; white-space: nowrap; }

  .hspec__burger { display: none; flex-direction: column; gap: 4px; flex-shrink: 0; }
  .hspec__burger span { display: block; width: 20px; height: 2px; background: var(--c-ink-2); border-radius: 2px; }

  /* Pines numerados (mismo lenguaje que el espécimen del Topbar). */
  .hspec__pin {
    position: absolute; top: -9px; left: -9px; z-index: 2;
    display: inline-grid; place-items: center;
    width: 18px; height: 18px; border-radius: var(--radius-full);
    background: var(--c-primary); color: #fff;
    font-family: var(--font-heading); font-weight: var(--weight-bold); font-size: .6875rem;
    box-shadow: 0 0 0 2px #fff;
  }
  .hspec__pin--chev { left: auto; right: -9px; }

  /* Variante móvil: replica el estado < 1024px (logo + ☰). */
  .hspec.is-mobile .hspec__nav,
  .hspec.is-mobile .hspec__cta { display: none; }
  .hspec.is-mobile .hspec__burger { display: flex; margin-left: auto; }
</style>
