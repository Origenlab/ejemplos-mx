---
// Hero.astro — Hero oscuro reutilizable: gradiente + glow radial, badge con punto, H1 con acento de marca, columna derecha y CTAs opcionales. ORIGEN: PROYECTORED/src/components/sections/Hero.astro (estructura 2 columnas + CTAs) fusionado con el fondo canónico de MESECI/HeroBase (gradiente 155deg + radial rojo).
// CTAs OPCIONALES: el patrón canónico MESECI (REGLA HeroBase) recomienda "el hero presenta, NavRapida/QuickLinks convierte". Pásalos sólo en L1/L2 si el negocio lo requiere. waUrl() desde config para el CTA de WhatsApp.
interface HeroCTA {
  text: string
  href: string
  variant?: 'primary' | 'outline'
  whatsapp?: boolean   // true → ícono WA + target _blank
}
interface Props {
  badge?: string
  title: string
  /** Última(s) palabra(s) del título resaltadas con color de marca. */
  accent?: string
  subtitle?: string
  /** Párrafos de la columna derecha (presentación). En móvil se apilan bajo el título. */
  descRight?: string[]
  ctas?: HeroCTA[]
  ariaLabel?: string
}
const { badge, title, accent, subtitle, descRight = [], ctas = [], ariaLabel = 'Encabezado principal' } = Astro.props

const WA_PATH = 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'
---

<section class="hero" aria-label={ariaLabel}>
  <div class="hero__inner">
    <div class="hero__left">
      {badge && <span class="hero__badge"><span class="hero__badge-dot" aria-hidden="true"></span>{badge}</span>}
      <h1 class="hero__title">{title}{accent && <span class="hero__accent"> {accent}</span>}</h1>
      {subtitle && <p class="hero__subtitle">{subtitle}</p>}
      {ctas.length > 0 && (
        <div class="hero__ctas">
          {ctas.map((cta) => (
            <a
              href={cta.href}
              class:list={['hero__btn', cta.variant === 'outline' ? 'hero__btn--outline' : 'hero__btn--primary']}
              target={cta.whatsapp || cta.href.startsWith('http') ? '_blank' : undefined}
              rel={cta.whatsapp || cta.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              {cta.whatsapp && <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={WA_PATH}/></svg>}
              {cta.text}
            </a>
          ))}
        </div>
      )}
    </div>
    {descRight.length > 0 && (
      <div class="hero__right">
        {descRight.map((p) => <p class="hero__desc">{p}</p>)}
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(155deg, #0C0C0C 0%, #180A0D 55%, #0C0C0C 100%);
    padding-block: clamp(3rem, 6vw, 5rem);
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 70% at 75% 40%, color-mix(in srgb, var(--color-red, #C41E24) 22%, transparent) 0%, transparent 60%),
      linear-gradient(transparent 59px, rgba(255,255,255,.025) 60px) 0 0 / 60px 60px,
      linear-gradient(90deg, transparent 59px, rgba(255,255,255,.025) 60px) 0 0 / 60px 60px;
    pointer-events: none;
  }
  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
    max-width: var(--container-max, 1400px);
    margin-inline: auto;
    padding-inline: var(--container-px, 1.5rem);
  }
  .hero__badge {
    display: inline-flex; align-items: center; gap: var(--sp-2, .5rem);
    padding: var(--sp-2, .5rem) var(--sp-4, 1rem);
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: var(--radius-full, 9999px);
    font-size: var(--text-sm, .875rem);
    font-weight: var(--weight-medium, 500);
    color: rgba(255,255,255,.9);
    margin-bottom: var(--sp-5, 1.25rem);
  }
  .hero__badge-dot {
    width: 6px; height: 6px; background: var(--color-red-light, #E8213F); border-radius: 50%; flex-shrink: 0;
    animation: hero-pulse 2s ease-in-out infinite;
  }
  @keyframes hero-pulse { 0%, 100% { opacity: 1; } 50% { opacity: .4; } }
  @media (prefers-reduced-motion: reduce) { .hero__badge-dot { animation: none; } }
  .hero__title {
    font-size: var(--text-4xl, clamp(2.5rem, 4.5vw, 3.75rem));
    font-weight: var(--weight-black, 800);
    line-height: var(--leading-tight, 1.2);
    color: #fff;
    margin-bottom: var(--sp-5, 1.25rem);
    letter-spacing: -.02em;
  }
  .hero__accent { color: var(--color-red-light, #E8213F); }
  .hero__subtitle {
    font-size: var(--text-base, 1.0625rem);
    color: rgba(255,255,255,.75);
    line-height: var(--leading-relaxed, 1.7);
    max-width: 52ch;
    margin-bottom: var(--sp-8, 2rem);
  }
  .hero__ctas { display: flex; flex-wrap: wrap; gap: var(--sp-3, .75rem); }
  .hero__btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .8125rem 1.625rem;
    font-size: var(--text-sm, .9375rem); font-weight: var(--weight-bold, 700);
    border-radius: var(--radius-md, 6px); text-decoration: none;
    transition: all .18s ease;
  }
  .hero__btn--primary { background: var(--color-red, #C41E24); color: #fff; border: 2px solid var(--color-red, #C41E24); }
  .hero__btn--primary:hover { background: var(--color-red-dark, #A01820); border-color: var(--color-red-dark, #A01820); }
  .hero__btn--outline { background: transparent; color: rgba(255,255,255,.9); border: 2px solid rgba(255,255,255,.35); }
  .hero__btn--outline:hover { border-color: rgba(255,255,255,.7); background: rgba(255,255,255,.08); color: #fff; }
  .hero__btn:focus-visible { outline: 2px solid #fff; outline-offset: 3px; }
  .hero__right { display: flex; flex-direction: column; gap: var(--sp-5, 1.25rem); }
  .hero__desc { font-size: var(--text-base, 1.0625rem); color: rgba(255,255,255,.75); line-height: var(--leading-relaxed, 1.7); margin: 0; }
  @media (max-width: 768px) {
    .hero__inner { grid-template-columns: 1fr; }
    /* La columna derecha lleva los 2 párrafos PRINCIPALES de la empresa:
       en móvil se apila bajo el título (NO se oculta). */
    .hero__right { gap: var(--sp-4, 1rem); }
  }
  @media (max-width: 560px) {
    .hero__ctas { flex-direction: column; }
    .hero__btn { width: 100%; justify-content: center; }
  }
</style>
