---
// ============================================================================
// CompanyAbout.astro — Módulo "Sobre la empresa": quién está detrás del negocio.
// ----------------------------------------------------------------------------
// QUÉ ES
// Bloque de confianza, de los más indispensables de un sitio: dice QUÉ hace el
// negocio, CÓMO lo hace y por qué se puede confiar en él. Apoya marketing
// (propuesta de valor + prueba social) y la confianza/experiencia que pesan en
// el posicionamiento (es el hogar natural del schema de Organización).
//
// DISTRIBUCIÓN. El TÍTULO de la sección va APARTE con el complemento
// SectionHeading layout="duo" (regla del sistema: todos los títulos en duo).
// Este componente es el CUERPO, de arriba a abajo:
//   1. Dos columnas  → "Qué hacemos" (párrafos) · "Cómo lo hacemos" (pilares num.).
//   2. Cifras        → tira de señales de confianza (números reales del negocio).
//   3. CTA           → una sola acción principal.
//
// Reutilizable y data-driven: la página pasa el contenido (no hay datos
// hardcodeados). Mobile-first; en móvil las columnas y las cifras se apilan.
//
// PROPS
//   que   → { title, body: string[] }                "Qué hacemos".
//   como  → { title, pillars: {title,desc}[] }        "Cómo lo hacemos".
//   stats → { value, label }[]   cifras de confianza (REALES, nunca inventadas).
//   cta   → { label, href, external? }                acción principal.
//
// ESTILO: tokens de src/styles/tokens.css. A11y: encabezados jerárquicos, listas
// reales, foco visible.
// ============================================================================
export type Pillar = { title: string; desc: string };
export type Stat = { value: string; label: string };
interface Props {
  que: { title: string; body: string[] };
  como: { title: string; pillars: Pillar[] };
  stats?: Stat[];
  cta?: { label: string; href: string; external?: boolean };
}
const { que, como, stats = [], cta } = Astro.props;
---

<div class="company">
  <div class="company__cols">
    <section class="company__card">
      <h3 class="company__sub">{que.title}</h3>
      {que.body.map((p: string) => <p class="company__p">{p}</p>)}
    </section>

    <section class="company__card company__card--como">
      <h3 class="company__sub">{como.title}</h3>
      <ol class="company__pillars">
        {como.pillars.map((p: Pillar, i: number) => (
          <li class="company__pillar">
            <span class="company__pillar-num" aria-hidden="true">{i + 1}</span>
            <div class="company__pillar-body">
              <p class="company__pillar-title">{p.title}</p>
              <p class="company__pillar-desc">{p.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>
  </div>

  {stats.length > 0 && (
    <ul class="company__stats" aria-label="Cifras de la empresa">
      {stats.map((s: Stat) => (
        <li class="company__stat">
          <span class="company__stat-value">{s.value}</span>
          <span class="company__stat-label">{s.label}</span>
        </li>
      ))}
    </ul>
  )}

  {cta && (
    <a
      class="company__cta"
      href={cta.href}
      target={cta.external ? '_blank' : undefined}
      rel={cta.external ? 'noopener noreferrer' : undefined}
    >
      {cta.label}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  )}
</div>

<style>
  .company { display: flex; flex-direction: column; gap: var(--sp-6); }

  /* ── Dos columnas: Qué / Cómo ── */
  .company__cols { display: grid; grid-template-columns: 1fr; gap: var(--sp-5); }
  .company__card {
    background: var(--c-surface); border: 1px solid var(--c-border);
    border-radius: var(--radius-lg); padding: var(--sp-6);
    display: flex; flex-direction: column; gap: var(--sp-3);
  }
  .company__card--como { background: var(--c-white); }
  .company__sub {
    margin: 0 0 var(--sp-1); font-family: var(--font-heading);
    font-size: var(--text-xl); font-weight: var(--weight-bold); color: var(--c-ink);
  }
  .company__p { margin: 0; font-size: var(--text-base); line-height: var(--leading-relaxed); color: var(--c-ink-2); }

  /* ── Pilares numerados (Cómo lo hacemos) ── */
  .company__pillars { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--sp-4); }
  .company__pillar { display: flex; align-items: flex-start; gap: var(--sp-3); }
  .company__pillar-num {
    flex-shrink: 0; display: grid; place-items: center; width: 30px; height: 30px;
    border-radius: var(--radius-full); background: var(--c-primary); color: #fff;
    font-family: var(--font-heading); font-weight: var(--weight-bold); font-size: var(--text-sm);
  }
  .company__pillar-body { display: flex; flex-direction: column; gap: 2px; }
  .company__pillar-title { margin: 0; font-weight: var(--weight-semibold); color: var(--c-ink); }
  .company__pillar-desc { margin: 0; font-size: var(--text-sm); line-height: var(--leading-normal); color: var(--c-muted); }

  /* ── Cifras de confianza ── */
  .company__stats {
    list-style: none; margin: 0; padding: var(--sp-6);
    display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--sp-5);
    background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--radius-lg);
  }
  .company__stat { display: flex; flex-direction: column; gap: 2px; text-align: center; }
  .company__stat-value {
    font-family: var(--font-heading); font-weight: var(--weight-black);
    font-size: var(--text-3xl); line-height: 1; color: var(--c-primary);
  }
  .company__stat-label { font-size: var(--text-sm); color: var(--c-muted); }

  /* ── CTA ── */
  .company__cta {
    align-self: flex-start;
    display: inline-flex; align-items: center; gap: var(--sp-2);
    padding: .7em 1.2em;
    font-family: var(--font-heading); font-weight: var(--weight-semibold); font-size: var(--text-sm);
    color: #fff; text-decoration: none;
    background: var(--c-primary); border-radius: var(--radius-md);
    transition: background var(--transition), gap var(--transition);
  }
  .company__cta:hover { background: var(--c-primary-dark); gap: var(--sp-3); }
  .company__cta:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }

  /* ── Escritorio ── */
  @media (min-width: 768px) {
    .company__cols { grid-template-columns: 1fr 1fr; gap: var(--sp-6); }
    .company__stats { grid-template-columns: repeat(4, 1fr); }
    .company__stat { border-left: 1px solid var(--c-border); }
    .company__stat:first-child { border-left: 0; }
  }

  @media (prefers-reduced-motion: reduce) { .company__cta { transition: none; } }
</style>
