---
// ============================================================================
// CategoryCard.astro — Tarjeta de categoría para la vitrina de la home.
// ----------------------------------------------------------------------------
// QUÉ ES
// Tarjeta "categoría como producto" al estilo de catálogos profesionales
// (meseci.com.mx): imagen + etiqueta de gancho + título + texto de venta +
// accesos directos a SUBCATEGORÍAS + CTA. Pensada para un grid de 4 por fila.
//
// POR QUÉ ESTÁ ARMADA ASÍ (marketing + SEO):
//   • <article> con <h3>  → jerarquía correcta (H1 hero → H2 sección → H3 card).
//   • imagen con `alt` descriptivo → SEO de imágenes + accesibilidad (no relleno).
//     width/height fijos → evita CLS (Core Web Vitals).
//   • blurb breve y escaneable → beneficio + keyword + confianza; convierte.
//   • subcategorías = enlaces con ANCHOR TEXT real → enlazado interno que reparte
//     autoridad a las páginas hijas y da al usuario el atajo exacto.
//   • un solo CTA claro por tarjeta → acción principal sin ambigüedad.
//
// DATA-DRIVEN: la home le pasa cada objeto de `SHOWCASE` (src/config/site.ts).
// El componente no inventa datos: solo pinta lo que recibe (con demo por defecto
// para poder renderizar suelto).
//
// PROPS
//   label          → título de la tarjeta (H3).  [requerido]
//   href           → destino del título y del CTA (landing de la categoría).
//   image, imageAlt→ imagen de cabecera + texto alternativo descriptivo.
//   badge          → etiqueta corta sobre la imagen (entrega, certificación…).
//   blurb          → texto de venta (1–2 frases).
//   subcategories  → [{ label, href }] enlaces hijos (chips).
//   ctaLabel       → texto del botón principal (default "Ver más").
//   index          → posición en el grid; los primeros cargan la imagen `eager`.
//
// ESTILO: tokens de src/styles/tokens.css. Alturas iguales en el grid (flex col +
// CTA al fondo). Mobile-first; hover con elevación. A11y: foco visible, aria.
// ============================================================================
export type Sub = { label: string; href: string };
interface Props {
  label: string;
  href: string;
  image?: string;
  imageAlt?: string;
  badge?: string;
  blurb?: string;
  subcategories?: readonly Sub[];
  ctaLabel?: string;
  index?: number;
  disabled?: boolean; // tarjeta sin enlace (p. ej. módulo 'próximo'); muestra badge en el cuerpo si no hay imagen.
}
const {
  label,
  href,
  image,
  imageAlt,
  badge,
  blurb,
  subcategories = [],
  ctaLabel = "Ver más",
  index = 99,
  disabled = false,
} = Astro.props;
const eager = index < 4; // las 4 primeras tarjetas (1.ª fila) cargan imagen sin lazy.
// 'disabled' (p. ej. módulo 'próximo'): ni la imagen ni los chips enlazan (evita 404s).
const MediaTag = disabled ? "div" : "a";
const ChipTag = disabled ? "span" : "a";
---

<article class="ccard">
  {image && (
    <MediaTag class="ccard__media-link" href={disabled ? undefined : href} tabindex={disabled ? undefined : "-1"} aria-hidden="true">
      <div class="ccard__media">
        <img
          src={image}
          alt={imageAlt ?? label}
          width="640" height="400"
          loading={eager ? "eager" : "lazy"}
          decoding="async"
          class="ccard__img"
        />
        <span class="ccard__overlay" aria-hidden="true"></span>
        {badge && <span class="ccard__badge">{badge}</span>}
      </div>
    </MediaTag>
  )}

  <div class="ccard__body">
    {badge && !image && (
      <span class:list={["ccard__badge", "ccard__badge--inline", { "ccard__badge--soon": disabled }]}>{badge}</span>
    )}
    <h3 class="ccard__title">
      {disabled ? <span>{label}</span> : <a href={href}>{label}</a>}
    </h3>
    {blurb && <p class="ccard__desc">{blurb}</p>}

    {subcategories.length > 0 && (
      <ul class="ccard__subs" aria-label={`Subcategorías de ${label}`}>
        {subcategories.map((s) => (
          <li>
            <ChipTag class="ccard__sub" href={disabled ? undefined : s.href}>{s.label}</ChipTag>
          </li>
        ))}
      </ul>
    )}

    {disabled ? (
      <span class="ccard__cta ccard__cta--soon">Próximamente</span>
    ) : (
      <a class="ccard__cta" href={href}>
        {ctaLabel}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    )}
  </div>
</article>

<style>
  /* Card ESTÁTICA: sin animaciones ni transiciones (regla de motion). */
  .ccard {
    display: flex; flex-direction: column; height: 100%;
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  /* Imagen de cabecera */
  .ccard__media-link { display: block; }
  .ccard__media {
    position: relative; aspect-ratio: 16 / 10; overflow: hidden;
    background: var(--c-surface);
  }
  .ccard__img { width: 100%; height: 100%; object-fit: cover; }
  .ccard__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 55%, rgba(0,0,0,.18) 100%); }
  .ccard__badge {
    position: absolute; top: var(--sp-3); left: var(--sp-3);
    font-size: var(--text-xs); font-weight: var(--weight-bold);
    letter-spacing: .04em; text-transform: uppercase; color: #fff;
    background: var(--c-primary); padding: .25em .6em; border-radius: var(--radius-sm);
  }
  /* Badge en el cuerpo (cuando la tarjeta no lleva imagen, p. ej. módulos). */
  .ccard__badge--inline { position: static; align-self: flex-start; }
  .ccard__badge--soon { color: var(--c-muted); background: var(--c-surface); border: 1px solid var(--c-border); }

  /* Cuerpo */
  .ccard__body { display: flex; flex-direction: column; flex-grow: 1; gap: var(--sp-3); padding: var(--sp-5); }
  .ccard__title {
    margin: 0; font-family: var(--font-heading);
    font-size: var(--text-lg); font-weight: var(--weight-semibold);
    line-height: var(--leading-snug); color: var(--c-ink);
  }
  .ccard__title a { color: inherit; text-decoration: none; }
  .ccard__desc {
    margin: 0; font-size: var(--text-sm); color: var(--c-ink-2);
    line-height: var(--leading-normal);
  }

  /* Chips de subcategorías (enlaces) */
  .ccard__subs {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: var(--sp-2);
  }
  .ccard__sub {
    display: inline-flex; align-items: center;
    font-size: var(--text-xs); font-weight: var(--weight-medium);
    color: var(--c-ink-2); text-decoration: none;
    background: var(--c-surface);
    border: 1px solid var(--c-border); border-radius: var(--radius-full);
    padding: .3em .8em;
  }
  .ccard__sub:hover, .ccard__sub:focus-visible {
    color: #fff; background: var(--c-primary); border-color: var(--c-primary);
    outline: none;
  }
  .ccard__sub:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }

  /* CTA principal — al fondo de la tarjeta (alturas iguales en el grid) */
  .ccard__cta {
    margin-top: auto;
    display: inline-flex; align-items: center; gap: var(--sp-2);
    align-self: flex-start;
    padding: .6em 1.1em;
    font-family: var(--font-heading); font-weight: var(--weight-semibold);
    font-size: var(--text-sm); color: #fff; text-decoration: none;
    background: var(--c-primary); border-radius: var(--radius-md);
    transition: background var(--transition), gap var(--transition);
  }
  .ccard__cta:hover { background: var(--c-primary-dark); gap: var(--sp-3); }
  .ccard__cta:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }
  /* CTA inactivo para tarjetas 'próximo' (no enlaza). */
  .ccard__cta--soon { background: var(--c-surface); color: var(--c-muted); border: 1px solid var(--c-border); cursor: default; }
  .ccard__cta--soon:hover { background: var(--c-surface); gap: var(--sp-2); }

  /* Único elemento con transición: el botón CTA. */
  @media (prefers-reduced-motion: reduce) {
    .ccard__cta { transition: none; }
  }
</style>
