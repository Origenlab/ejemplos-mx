---
// FAQAccordion.astro — Acordeón de preguntas frecuentes accesible con <details>/<summary>. ORIGEN: MESECI/src/components/FAQ.astro (acordeón nativo, primer item abierto) + FaqCotizacionIndex de PROYECTORED.
// JSON-LD FAQPage: emitSchema=false por defecto. El patrón canónico centraliza el schema en seo.ts (anti-duplicación). Actívalo SÓLO si esta es la única fuente de las FAQs de la página y seo.ts no las emite.
export interface FAQItem {
  question: string
  answer: string   // admite HTML (set:html)
}
interface Props {
  items: FAQItem[]
  title?: string
  headingId?: string
  /** true → emite <script type="application/ld+json"> FAQPage. Default false (lo hace seo.ts). */
  emitSchema?: boolean
  /** Abrir el primer item por defecto. */
  openFirst?: boolean
  /** true → sin <section> con padding/centrado; para incrustar en una columna. */
  bare?: boolean
}
const { items = [], title = 'Preguntas frecuentes', headingId = 'faq-heading', emitSchema = false, openFirst = true, bare = false } = Astro.props

const faqSchema = emitSchema ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer.replace(/<[^>]+>/g, '') },
  })),
} : null
---

<section class:list={['faq', bare && 'faq--bare']} aria-labelledby={title ? headingId : undefined}>
  <div class="faq__inner">
    {title && <h2 id={headingId} class="faq__title">{title}</h2>}
    <div class="faq__list">
      {items.map((item, idx) => (
        <details class="faq__item" open={openFirst && idx === 0}>
          <summary class="faq__q">
            <span>{item.question}</span>
            <svg class="faq__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq__a"><p set:html={item.answer} /></div>
        </details>
      ))}
    </div>
  </div>
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</section>

<style>
  .faq { padding: var(--section-py, clamp(3rem, 6vw, 5rem)) 0; }
  .faq__inner { max-width: 820px; margin-inline: auto; padding-inline: var(--container-px, 1.5rem); }
  .faq__title { font-size: var(--text-3xl, clamp(2rem, 3.5vw, 3rem)); font-weight: var(--weight-bold, 700); margin: 0 0 var(--sp-8, 2rem); text-align: center; color: var(--c-ink, var(--color-gray-900, #111827)); }
  .faq__list { display: flex; flex-direction: column; gap: var(--sp-3, .75rem); }
  .faq__item { border: 1px solid var(--c-border, var(--border, #e8e8e8)); border-radius: var(--radius-lg, .75rem); overflow: hidden; background: var(--c-white, #fff); }
  .faq__q { display: flex; justify-content: space-between; align-items: center; gap: var(--sp-3, .75rem); padding: var(--sp-4, 1rem) var(--sp-5, 1.25rem); cursor: pointer; background: var(--color-gray-50, #fafafa); font-weight: var(--weight-semibold, 600); color: var(--c-ink, var(--color-gray-900, #111827)); list-style: none; }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q:hover { background: var(--color-gray-100, #f4f4f5); }
  .faq__item[open] .faq__q { background: color-mix(in srgb, var(--c-primary, #6d28d9) 8%, #fff); }
  /* Modo "bare": sin section-padding ni centrado — para incrustar en una columna */
  .faq--bare { padding: 0; }
  .faq--bare .faq__inner { max-width: none; padding-inline: 0; }
  .faq__chevron { flex-shrink: 0; transition: transform .2s ease; color: var(--color-red, var(--c-primary, #C41E24)); }
  .faq__item[open] .faq__chevron { transform: rotate(180deg); }
  .faq__a { padding: var(--sp-4, 1rem) var(--sp-5, 1.25rem); color: var(--c-ink-2, var(--color-gray-700, #374151)); line-height: var(--leading-relaxed, 1.7); border-top: 1px solid var(--c-border, var(--border, #e8e8e8)); }
  .faq__a :global(p) { margin: 0; }
  .faq__a :global(a) { color: var(--color-red, var(--c-primary, #C41E24)); }
  @media (prefers-reduced-motion: reduce) { .faq__chevron { transition: none; } }
</style>
