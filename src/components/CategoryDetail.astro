---
// ============================================================================
// CategoryDetail.astro — Módulo "categoría a fondo": amplía UNA categoría/servicio.
// ----------------------------------------------------------------------------
// QUÉ ES
// Bloque de 2 columnas para dar MÁS información de una categoría (o servicio) que
// ya aparece resumida en una tarjeta del catálogo. Refuerza la categoría con texto
// detallado + una galería de apoyo, antes de que el visitante entre a su página.
//
//   • Columna IZQ (info) → eyebrow + título + párrafos + puntos clave + CTA.
//   • Columna DER (galería) → 1 imagen GRANDE arriba y 2 más pequeñas debajo.
//
// Reutilizable y data-driven: la página le pasa el contenido (no hay datos
// hardcodeados). `reverse` invierte el orden de columnas en escritorio para
// alternar bloques. En móvil se apila (info arriba, galería debajo).
//
// PROPS
//   eyebrow  → etiqueta corta con barra de acento (ej. "La categoría a fondo").
//   title    → título del bloque (H2 por defecto; `as` lo cambia a H3).  [requerido]
//   body     → párrafos de la descripción detallada. string[].
//   points   → lista de puntos clave (con check). string[]. Opcional.
//   cta      → { label, href, external? } botón principal. Opcional.
//   gallery  → { main:{src,alt}, thumbs:[{src,alt}, ...] }.  [requerido]
//   reverse  → true: galería a la izquierda en escritorio.
//   id, as   → id del título / etiqueta semántica (h2|h3).
//
// ESTILO: tokens de src/styles/tokens.css. Imágenes con width/height para evitar
// saltos de maqueta (CLS). A11y: <figure>, alt descriptivo, foco visible.
// ============================================================================
export type GalleryImg = { src: string; alt: string };
export interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  body?: string[];
  points?: string[];
  cta?: { label: string; href: string; external?: boolean };
  gallery: { main: GalleryImg; thumbs: readonly GalleryImg[] };
  reverse?: boolean;
  as?: 'h2' | 'h3';
}
const { id, eyebrow, title, body = [], points = [], cta, gallery, reverse = false, as = 'h2' } = Astro.props;
const Tag = as;
---

<div class:list={['cdetail', { 'cdetail--reverse': reverse }]}>
  <div class="cdetail__info">
    {eyebrow && <p class="cdetail__eyebrow"><span class="cdetail__bar" aria-hidden="true"></span>{eyebrow}</p>}
    <Tag class="cdetail__title" id={id}>{title}</Tag>
    {body.map((p: string) => <p class="cdetail__p">{p}</p>)}

    {points.length > 0 && (
      <ul class="cdetail__points">
        {points.map((pt: string) => (
          <li class="cdetail__point">
            <span class="cdetail__check" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
            <span>{pt}</span>
          </li>
        ))}
      </ul>
    )}

    {cta && (
      <a
        class="cdetail__cta"
        href={cta.href}
        target={cta.external ? '_blank' : undefined}
        rel={cta.external ? 'noopener noreferrer' : undefined}
      >
        {cta.label}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    )}
  </div>

  <div class="cdetail__gallery">
    <figure class="cdetail__main">
      <img src={gallery.main.src} alt={gallery.main.alt} width="800" height="600" loading="lazy" decoding="async" />
    </figure>
    {gallery.thumbs.length > 0 && (
      <div class="cdetail__thumbs">
        {gallery.thumbs.map((t: GalleryImg) => (
          <figure class="cdetail__thumb">
            <img src={t.src} alt={t.alt} width="400" height="300" loading="lazy" decoding="async" />
          </figure>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  /* 2 columnas, centradas verticalmente entre sí. Mobile-first: apila. */
  .cdetail {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    align-items: center;
  }

  /* ── Columna de info ── */
  .cdetail__info { display: flex; flex-direction: column; gap: var(--sp-4); }
  .cdetail__eyebrow {
    display: inline-flex; align-items: center; gap: var(--sp-2);
    margin: 0; font-size: var(--text-xs); font-weight: var(--weight-bold);
    text-transform: uppercase; letter-spacing: .08em; color: var(--c-primary);
  }
  .cdetail__bar { width: 20px; height: 2px; background: currentColor; border-radius: 2px; }
  .cdetail__title {
    margin: 0; font-family: var(--font-heading);
    font-size: var(--text-3xl); font-weight: var(--weight-black);
    line-height: var(--leading-tight); letter-spacing: -.02em; color: var(--c-ink);
  }
  .cdetail__p { margin: 0; font-size: var(--text-base); line-height: var(--leading-relaxed); color: var(--c-ink-2); }

  .cdetail__points { list-style: none; margin: var(--sp-1) 0 0; padding: 0; display: flex; flex-direction: column; gap: var(--sp-3); }
  .cdetail__point { display: flex; align-items: flex-start; gap: var(--sp-3); font-size: var(--text-base); color: var(--c-ink-2); line-height: var(--leading-normal); }
  .cdetail__check {
    flex-shrink: 0; display: grid; place-items: center; margin-top: .1em;
    width: 22px; height: 22px; border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--c-primary) 14%, transparent); color: var(--c-primary);
  }

  .cdetail__cta {
    align-self: flex-start; margin-top: var(--sp-2);
    display: inline-flex; align-items: center; gap: var(--sp-2);
    padding: .7em 1.2em;
    font-family: var(--font-heading); font-weight: var(--weight-semibold); font-size: var(--text-sm);
    color: #fff; text-decoration: none;
    background: var(--c-primary); border-radius: var(--radius-md);
    transition: background var(--transition), gap var(--transition);
  }
  .cdetail__cta:hover { background: var(--c-primary-dark); gap: var(--sp-3); }
  .cdetail__cta:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }

  /* ── Galería: 1 grande arriba + 2 debajo ── */
  .cdetail__gallery { display: flex; flex-direction: column; gap: var(--sp-3); }
  .cdetail__main, .cdetail__thumb {
    margin: 0; overflow: hidden; background: var(--c-surface);
    border: 1px solid var(--c-border);
  }
  .cdetail__main { border-radius: var(--radius-lg); aspect-ratio: 4 / 3; box-shadow: var(--shadow-md); }
  .cdetail__thumbs { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-3); }
  .cdetail__thumb { border-radius: var(--radius-md); aspect-ratio: 4 / 3; box-shadow: var(--shadow-sm); }
  .cdetail__main img, .cdetail__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ── Escritorio: 2 columnas ── */
  @media (min-width: 768px) {
    .cdetail { grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); }
    .cdetail--reverse .cdetail__info { order: 2; }
    .cdetail--reverse .cdetail__gallery { order: 1; }
  }

  @media (prefers-reduced-motion: reduce) { .cdetail__cta { transition: none; } }
</style>
