---
// ============================================================================
// ContactForm.astro — Formulario de contacto que ENVÍA a WhatsApp (sin backend).
// ----------------------------------------------------------------------------
// QUÉ ES
// Form accesible (nombre, asunto, mensaje) que, al enviar, COMPONE un mensaje y
// abre wa.me con el número del negocio para que el visitante lo mande desde su
// propio WhatsApp. Cero backend: todo ocurre en el navegador.
//
// REGLA D4: el número sale de CONTACT.whatsapp (config), NUNCA hardcodeado.
//
// PROPS
//   heading?  → título del formulario.
//   note?     → línea de confianza bajo el botón.
//   asuntos?  → opciones del <select> «Asunto».
//
// ESTILO: tokens de src/styles/tokens.css. Inputs a 16px (evita zoom en iOS).
// Botón verde WhatsApp (coherente con el botón flotante). A11y: labels + foco.
// ============================================================================
import { CONTACT } from "@config/site";
interface Props {
  heading?: string;
  note?: string;
  asuntos?: string[];
}
const {
  heading = "¿No está tu duda? Escríbenos",
  note = "Respuesta inmediata · Sin compromiso",
  asuntos = ["Quiero una cotización", "Tengo una duda", "Soporte", "Otro"],
} = Astro.props;
const waNumber = CONTACT.whatsapp;
---

<form class="cform" data-wa-number={waNumber}>
  <div class="cform__head">
    <h3 class="cform__title">{heading}</h3>
    <p class="cform__sub">Llena el formulario y se abrirá WhatsApp con tu mensaje listo para enviar.</p>
  </div>

  <div class="cform__field">
    <label for="cf-nombre">Nombre</label>
    <input id="cf-nombre" name="nombre" type="text" autocomplete="name" placeholder="Tu nombre" required />
  </div>

  <div class="cform__field">
    <label for="cf-asunto">Asunto</label>
    <div class="cform__select">
      <select id="cf-asunto" name="asunto">
        {asuntos.map((a) => <option value={a}>{a}</option>)}
      </select>
      <svg class="cform__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
    </div>
  </div>

  <div class="cform__field">
    <label for="cf-mensaje">Mensaje</label>
    <textarea id="cf-mensaje" name="mensaje" rows="4" placeholder="Cuéntanos qué necesitas…" required></textarea>
  </div>

  <button class="cform__submit" type="submit">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    Enviar por WhatsApp
  </button>

  <p class="cform__note">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    {note}
  </p>
</form>

<script>
  document.querySelectorAll('form.cform').forEach((node) => {
    const form = node as HTMLFormElement;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!form.checkValidity()) { form.reportValidity(); return; }
      const num = form.getAttribute('data-wa-number') || '';
      const data = new FormData(form);
      const nombre = String(data.get('nombre') || '').trim();
      const asunto = String(data.get('asunto') || '').trim();
      const mensaje = String(data.get('mensaje') || '').trim();
      const lineas = ['Hola, soy ' + nombre + '.'];
      if (asunto) lineas.push('Asunto: ' + asunto);
      lineas.push('', mensaje);
      const url = 'https://wa.me/' + num + '?text=' + encodeURIComponent(lineas.join('\n'));
      window.open(url, '_blank', 'noopener');
    });
  });
</script>

<style>
  .cform {
    display: flex; flex-direction: column; gap: var(--sp-4);
    background: var(--c-white); border: 1px solid var(--c-border);
    border-radius: var(--radius-lg); padding: var(--sp-6);
  }
  .cform__head { display: flex; flex-direction: column; gap: var(--sp-1); margin-bottom: var(--sp-1); }
  .cform__title { margin: 0; font-family: var(--font-heading); font-size: var(--text-xl); font-weight: var(--weight-bold); color: var(--c-ink); }
  .cform__sub { margin: 0; font-size: var(--text-sm); color: var(--c-muted); line-height: var(--leading-normal); }

  .cform__field { display: flex; flex-direction: column; gap: 6px; }
  .cform__field label { font-size: var(--text-sm); font-weight: var(--weight-semibold); color: var(--c-ink); }

  .cform input,
  .cform textarea,
  .cform select {
    width: 100%; font-family: var(--font-body); font-size: 16px; color: var(--c-ink);
    background: var(--c-surface); border: 1px solid var(--c-border);
    border-radius: var(--radius-md); padding: .7em .9em;
    transition: border-color var(--transition), box-shadow var(--transition);
  }
  .cform textarea { resize: vertical; min-height: 96px; line-height: var(--leading-normal); }
  .cform input::placeholder, .cform textarea::placeholder { color: var(--c-muted); }
  .cform input:focus, .cform textarea:focus, .cform select:focus {
    outline: none; border-color: var(--c-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--c-primary) 18%, transparent);
  }

  .cform__select { position: relative; }
  .cform__select select { appearance: none; -webkit-appearance: none; padding-right: 2.4em; cursor: pointer; }
  .cform__chevron { position: absolute; right: .8em; top: 50%; transform: translateY(-50%); color: var(--c-muted); pointer-events: none; }

  .cform__submit {
    display: inline-flex; align-items: center; justify-content: center; gap: var(--sp-2);
    width: 100%; margin-top: var(--sp-1); padding: .85em 1.2em;
    font-family: var(--font-heading); font-weight: var(--weight-bold); font-size: var(--text-base);
    color: #fff; background: #25d366; border: 0; border-radius: var(--radius-md);
    cursor: pointer; transition: background var(--transition), transform var(--transition);
  }
  .cform__submit:hover { background: #1ebe5b; transform: translateY(-1px); }
  .cform__submit:focus-visible { outline: 2px solid #1ebe5b; outline-offset: 2px; }

  .cform__note { display: flex; align-items: center; justify-content: center; gap: 6px; margin: 0; font-size: var(--text-xs); color: var(--c-muted); }

  @media (prefers-reduced-motion: reduce) {
    .cform input, .cform textarea, .cform select, .cform__submit { transition: none; }
    .cform__submit:hover { transform: none; }
  }
</style>
