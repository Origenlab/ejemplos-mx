---
// ServiceCard.astro — Tarjeta de servicio: ícono opcional + título + descripción + CTA (página interna o WhatsApp). ORIGEN: PROYECTORED .ccard de CatalogoServicios + ServiceCard de MESASPICNIC (icon/badge), normalizado a tokens.
// Si href apunta a WhatsApp, construye el href con waUrl(WA_MESSAGES.x) desde config y pasa whatsapp={true}. NUNCA número hardcodeado.
interface Props {
  title: string
  description: string
  href: string
  /** SVG inline (string) para el ícono. Opcional. */
  icon?: string
  /** Imagen de cabecera. Si se pasa, reemplaza al ícono superior. */
  image?: string
  imageAlt?: string
  badge?: string
  ctaLabel?: string
  /** true → CTA estilo WhatsApp (verde) + target _blank. */
  whatsapp?: boolean
}
const { title, description, href, icon, image, imageAlt, badge, ctaLabel = 'Ver servicio', whatsapp = false } = Astro.props
---

<article class="scard" aria-label={title}>
  {image ? (
    <div class="scard__media">
      <img src={image} alt={imageAlt ?? title} width="640" height="360" loading="lazy" decoding="async" class="scard__img" />
      <span class="scard__overlay" aria-hidden="true"></span>
      {badge && <span class="scard__badge">{badge}</span>}
    </div>
  ) : icon ? (
    <div class="scard__icon" aria-hidden="true"><Fragment set:html={icon} /></div>
  ) : null}

  <div class="scard__body">
    {badge && !image && <span class="scard__badge scard__badge--inline">{badge}</span>}
    <h3 class="scard__title">{title}</h3>
    <p class="scard__desc">{description}</p>
    <a
      href={href}
      class:list={['scard__cta', whatsapp && 'scard__cta--wa']}
      target={whatsapp || href.startsWith('http') ? '_blank' : undefined}
      rel={whatsapp || href.startsWith('http') ? 'noopener noreferrer' : undefined}
    >
      {whatsapp && <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>}
      {ctaLabel}
      {!whatsapp && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>}
    </a>
  </div>
</article>

<style>
  /* Card ESTÁTICA: sin animaciones ni transiciones (regla de motion). */
  .scard { display: flex; flex-direction: column; background: var(--c-white, #fff); border: 1px solid var(--c-border, var(--border, #e8e8e8)); border-radius: var(--radius-xl, 1rem); overflow: hidden; height: 100%; }
  .scard__media { position: relative; aspect-ratio: 16 / 9; overflow: hidden; background: var(--color-gray-100, #f4f4f5); }
  .scard__img { width: 100%; height: 100%; object-fit: cover; }
  .scard__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 55%, rgba(0,0,0,.18) 100%); }
  .scard__badge { position: absolute; top: var(--sp-3, .75rem); left: var(--sp-3, .75rem); font-size: var(--text-xs, .6875rem); font-weight: var(--weight-bold, 700); letter-spacing: .04em; text-transform: uppercase; color: #fff; background: var(--color-red, var(--c-primary, #C41E24)); padding: .25rem .55rem; border-radius: var(--radius-sm, .25rem); }
  .scard__badge--inline { position: static; display: inline-block; align-self: flex-start; margin-bottom: var(--sp-3, .75rem); }
  .scard__icon { display: flex; align-items: center; justify-content: center; width: 56px; height: 56px; margin: var(--sp-5, 1.25rem) var(--sp-5, 1.25rem) 0; border-radius: var(--radius-lg, .75rem); background: var(--color-red-light, #FEE2E2); color: var(--color-red, var(--c-primary, #C41E24)); }
  .scard__body { display: flex; flex-direction: column; flex-grow: 1; padding: var(--sp-5, 1.25rem); }
  .scard__title { font-size: var(--text-lg, 1.125rem); font-weight: var(--weight-semibold, 600); line-height: var(--leading-snug, 1.35); color: var(--c-ink, var(--color-gray-900, #111827)); margin: 0 0 var(--sp-2, .5rem); }
  .scard__desc { font-size: var(--text-sm, .9375rem); color: var(--text-muted, var(--c-muted, #6b7280)); line-height: var(--leading-normal, 1.5); margin: 0 0 auto; }
  /* Único elemento que anima: el botón CTA. */
  .scard__cta { display: inline-flex; align-items: center; gap: var(--sp-2, .5rem); margin-top: var(--sp-4, 1rem); font-size: var(--text-sm, .875rem); font-weight: var(--weight-semibold, 600); color: var(--color-red, var(--c-primary, #C41E24)); text-decoration: none; align-self: flex-start; transition: color var(--transition, .18s ease), gap var(--transition, .18s ease), background var(--transition, .18s ease); }
  .scard:hover .scard__cta:not(.scard__cta--wa) { gap: .65rem; color: var(--color-red-dark, var(--c-primary-dark, #A01820)); }
  .scard__cta--wa { color: #fff; background: #25D366; padding: .55rem 1rem; border-radius: var(--radius-md, 6px); }
  .scard__cta--wa:hover { background: #1ebe57; }
  .scard__cta:focus-visible { outline: 2px solid var(--color-red, var(--c-primary, #C41E24)); outline-offset: 2px; }
  @media (prefers-reduced-motion: reduce) { .scard__cta { transition: none; } }
</style>
